@model GamaxyWebApplication.Models.GameRatingViewModel
@{
    ViewData["Title"] = "Wire Match Challenge";
    Layout = "_layout3";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>Wire Match Challenge</title>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link href="~/css/matchthecolumn.css" rel="stylesheet" />
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
</head>
<body style="background-color:  #0a0a1e;">
    <div class="container py-4">
        <div class="game-page">
            <div class="header-section">
                <h1 class="game-title">WIRE MATCH CHALLENGE</h1>
                <div class="game-subtitle">CONNECT THE CIRCUITS</div>
            </div>

            <div class="game-container-wrapper">
                <div class="game-container">
                    <div class="circuit-bg"></div>
                    <div class="circuit-lines"></div>

                    <div class="game-panel">
                        <div class="panel-inner">
                            <div class="panel-top">
                                <div class="level-indicator">LEVEL <span id="level-num">1</span></div>
                                <div class="timer" id="timer">00:30</div>
                                <div class="score">SCORE: <span id="score">0</span></div>
                            </div>

                            <div class="panel-content">
                                <div class="wire-container" id="wire-container">
                                    <div class="wire-side left-side" id="left-side"></div>
                                    <div class="wire-path" id="wire-path"></div>
                                    <div class="wire-side right-side" id="right-side"></div>
                                </div>
                            </div>

                            <div class="panel-bottom">
                                <button class="btn btn-reset" id="reset-btn">Reset</button>
                                <button class="btn btn-next" id="next-btn" style="display: none;">Next Level</button>
                            </div>
                        </div>
                    </div>

                    <div class="level-complete" id="level-complete">
                        <h2>Level Complete!</h2>
                        <p>Time Bonus: <span id="time-bonus">0</span></p>
                        <button class="btn btn-next" id="next-level-btn">Next Level</button>
                    </div>

                    <div class="mobile-controls">
                        <div class="mobile-btn" id="mobile-reset-btn">Reset</div>
                    </div>
                </div>
            </div>

            <div class="controls">
                <p>Drag from left to right connectors to match colors • Reset to try again</p>
            </div>

            <div class="rating-section">
                <h2 class="rating-title">@Model.GameName</h2>
                <p class="rating-average">Average Rating: @Model.AverageRating.ToString("F1")</p>
                @if (Model.UserId.HasValue)
                {
                    <p class="rating-user">Your Rating: @(Model.ExistingRating > 0 ? Model.ExistingRating.ToString() : "Not rated yet")</p>
                    <form id="ratingForm" method="post" asp-action="RateGame">
                        <input type="hidden" name="gameName" value="@Model.GameName" />
                        <div class="star-rating">
                            <input type="radio" id="star5" name="rating" value="5" /><label for="star5">★</label>
                            <input type="radio" id="star4" name="rating" value="4" /><label for="star4">★</label>
                            <input type="radio" id="star3" name="rating" value="3" /><label for="star3">★</label>
                            <input type="radio" id="star2" name="rating" value="2" /><label for="star2">★</label>
                            <input type="radio" id="star1" name="rating" value="1" /><label for="star1">★</label>
                        </div>
                        <button type="submit" class="btn btn-rate">Submit Rating</button>
                    </form>
                }
                else
                {
                    <p class="rating-login">Please <a asp-action="Login">login</a> to rate this game.</p>
                }
            </div>
        </div>
    </div>

    <script>
        $(document).ready(function () {
            $('#ratingForm').submit(function (e) {
                e.preventDefault();
                $.ajax({
                    url: '@Url.Action("RateGame", "Home")',
                    type: 'POST',
                    data: $(this).serialize(),
                    headers: {
                        'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function (response) {
                        if (response.success) {
                            alert(response.message);
                            location.reload();
                        } else {
                            alert('Error: ' + response.message);
                        }
                    },
                    error: function () {
                        alert('An error occurred while submitting the rating.');
                    }
                });
            });
        });

        document.addEventListener('DOMContentLoaded', function() {
            const colors = [
                { name: 'red', bg: '#e63946', glow: 'rgba(230, 57, 70, 0.8)' },
                { name: 'blue', bg: '#4cc9f0', glow: 'rgba(76, 201, 240, 0.8)' },
                { name: 'green', bg: '#2a9d8f', glow: 'rgba(42, 157, 143, 0.8)' },
                { name: 'yellow', bg: '#e9c46a', glow: 'rgba(233, 196, 106, 0.8)' },
                { name: 'purple', bg: '#8338ec', glow: 'rgba(131, 56, 236, 0.8)' },
                { name: 'orange', bg: '#fb8500', glow: 'rgba(251, 133, 0, 0.8)' },
                { name: 'pink', bg: '#ff006e', glow: 'rgba(255, 0, 110, 0.8)' },
                { name: 'teal', bg: '#0096c7', glow: 'rgba(0, 150, 199, 0.8)' }
            ];

            let level = 1;
            let score = 0;
            let timeLeft = 30;
            let timerInterval;
            let wireCount = 4;
            let connections = [];
            let correctConnections = 0;
            let activeWire = null;
            let wireStartX, wireStartY;
            let isDragging = false;

            const leftSide = document.getElementById('left-side');
            const rightSide = document.getElementById('right-side');
            const wirePath = document.getElementById('wire-path');
            const wireContainer = document.getElementById('wire-container');
            const timerElement = document.getElementById('timer');
            const levelElement = document.getElementById('level-num');
            const scoreElement = document.getElementById('score');
            const resetBtn = document.getElementById('reset-btn');
            const nextBtn = document.getElementById('next-btn');
            const levelComplete = document.getElementById('level-complete');
            const nextLevelBtn = document.getElementById('next-level-btn');
            const timeBonusElement = document.getElementById('time-bonus');
            const mobileResetBtn = document.getElementById('mobile-reset-btn');

            initLevel();

            resetBtn.addEventListener('click', resetLevel);
            nextBtn.addEventListener('click', nextLevel);
            nextLevelBtn.addEventListener('click', nextLevel);
            mobileResetBtn.addEventListener('touchstart', (e) => {
                e.preventDefault();
                resetLevel();
            });

            function initLevel() {
                leftSide.innerHTML = '';
                rightSide.innerHTML = '';
                wirePath.innerHTML = '';
                connections = [];
                correctConnections = 0;

                levelElement.textContent = level;
                scoreElement.textContent = score;

                wireCount = Math.min(4 + Math.floor(level / 2), 8);
                const shuffledColors = [...colors].sort(() => Math.random() - 0.5).slice(0, wireCount);
                const rightSideColors = [...shuffledColors].sort(() => Math.random() - 0.5);

                shuffledColors.forEach((color, index) => {
                    const connector = createConnector(color, 'left', index);
                    leftSide.appendChild(connector);
                });

                rightSideColors.forEach((color, index) => {
                    const connector = createConnector(color, 'right', index);
                    rightSide.appendChild(connector);
                });

                clearInterval(timerInterval);
                timeLeft = 30 + (level * 5);
                updateTimer();
                timerInterval = setInterval(updateTimer, 1000);

                nextBtn.style.display = 'none';
                levelComplete.classList.remove('show');
            }

            function createConnector(color, side, index) {
                const connector = document.createElement('div');
                connector.className = `wire-connector ${side}`;
                connector.style.backgroundColor = color.bg;
                connector.style.boxShadow = `0 0 10px ${color.glow}, 0 0 5px ${color.glow} inset`;
                connector.dataset.color = color.name;
                connector.dataset.index = index;
                connector.dataset.side = side;

                if (side === 'left') {
                    connector.addEventListener('mousedown', startDrag);
                    connector.addEventListener('touchstart', startDrag, { passive: false });
                }

                return connector;
            }

            function startDrag(e) {
                e.preventDefault();
                const connector = e.target.closest('.wire-connector');
                if (!connector || connector.dataset.side !== 'left') return;

                const existingConnection = connections.find(conn => conn.leftIndex === parseInt(connector.dataset.index));
                if (existingConnection) {
                    const wireElement = document.getElementById(`wire-${existingConnection.leftIndex}-${existingConnection.rightIndex}`);
                    if (wireElement) {
                        wireElement.remove();
                    }
                    connections = connections.filter(conn => conn.leftIndex !== parseInt(connector.dataset.index));
                    if (existingConnection.correct) {
                        correctConnections--;
                    }
                }

                const rect = connector.getBoundingClientRect();
                const containerRect = wireContainer.getBoundingClientRect();
                wireStartX = rect.left + rect.width / 2 - containerRect.left;
                wireStartY = rect.top + rect.height / 2 - containerRect.top;

                const wire = document.createElement('div');
                wire.className = 'wire dragging';
                wire.id = `temp-wire`;
                wire.style.backgroundColor = connector.style.backgroundColor;
                wire.style.boxShadow = connector.style.boxShadow;
                wire.style.left = `${wireStartX}px`;
                wire.style.top = `${wireStartY}px`;
                wirePath.appendChild(wire);

                activeWire = {
                    element: wire,
                    color: connector.dataset.color,
                    leftIndex: parseInt(connector.dataset.index)
                };

                isDragging = true;

                document.addEventListener('mousemove', dragWire);
                document.addEventListener('touchmove', dragWire, { passive: false });
                document.addEventListener('mouseup', endDrag);
                document.addEventListener('touchend', endDrag);
            }

            function dragWire(e) {
                if (!isDragging || !activeWire) return;
                e.preventDefault();
                const containerRect = wireContainer.getBoundingClientRect();
                const clientX = e.clientX || (e.touches && e.touches[0].clientX);
                const clientY = e.clientY || (e.touches && e.touches[0].clientY);
                if (!clientX || !clientY) return;

                const mouseX = clientX - containerRect.left;
                const mouseY = clientY - containerRect.top;
                const dx = mouseX - wireStartX;
                const dy = mouseY - wireStartY;
                const length = Math.sqrt(dx * dx + dy * dy);
                const angle = Math.atan2(dy, dx) * 180 / Math.PI;

                activeWire.element.style.width = `${length}px`;
                activeWire.element.style.transform = `rotate(${angle}deg)`;
                const waveAmount = Math.sin(Date.now() / 300) * 2;
                activeWire.element.style.height = `${6 + waveAmount}px`;
            }

            function endDrag(e) {
                if (!isDragging || !activeWire) return;
                isDragging = false;

                document.removeEventListener('mousemove', dragWire);
                document.removeEventListener('touchmove', dragWire);
                document.removeEventListener('mouseup', endDrag);
                document.removeEventListener('touchend', endDrag);

                const rightConnectors = document.querySelectorAll('.wire-connector.right');
                const containerRect = wireContainer.getBoundingClientRect();
                const clientX = e.clientX || (e.changedTouches && e.changedTouches[0].clientX);
                const clientY = e.clientY || (e.changedTouches && e.changedTouches[0].clientY);

                if (!clientX || !clientY) {
                    activeWire.element.remove();
                    activeWire = null;
                    return;
                }

                let dropped = false;

                rightConnectors.forEach(connector => {
                    const rect = connector.getBoundingClientRect();
                    if (
                        clientX >= rect.left &&
                        clientX <= rect.right &&
                        clientY >= rect.top &&
                        clientY <= rect.bottom
                    ) {
                        dropped = true;
                        const existingRightConnection = connections.find(conn => conn.rightIndex === parseInt(connector.dataset.index));
                        if (existingRightConnection) {
                            const wireElement = document.getElementById(`wire-${existingRightConnection.leftIndex}-${existingRightConnection.rightIndex}`);
                            if (wireElement) {
                                wireElement.remove();
                            }
                            connections = connections.filter(conn => conn.rightIndex !== parseInt(connector.dataset.index));
                            if (existingRightConnection.correct) {
                                correctConnections--;
                            }
                        }

                        const endX = rect.left + rect.width / 2 - containerRect.left;
                        const endY = rect.top + rect.height / 2 - containerRect.top;
                        const dx = endX - wireStartX;
                        const dy = endY - wireStartY;
                        const length = Math.sqrt(dx * dx + dy * dy);
                        const angle = Math.atan2(dy, dx) * 180 / Math.PI;

                        activeWire.element.remove();
                        const wire = document.createElement('div');
                        wire.className = 'wire';
                        wire.id = `wire-${activeWire.leftIndex}-${connector.dataset.index}`;
                        wire.style.backgroundColor = connector.style.backgroundColor;
                        wire.style.boxShadow = connector.style.boxShadow;
                        wire.style.left = `${wireStartX}px`;
                        wire.style.top = `${wireStartY}px`;
                        wire.style.width = `${length}px`;
                        wire.style.transform = `rotate(${angle}deg)`;
                        wirePath.appendChild(wire);

                        const isCorrect = activeWire.color === connector.dataset.color;
                        connections.push({
                            leftIndex: activeWire.leftIndex,
                            rightIndex: parseInt(connector.dataset.index),
                            correct: isCorrect
                        });

                        if (isCorrect) {
                            correctConnections++;
                            wire.classList.add('connected');
                            wire.style.animation = 'success 0.5s';
                            if (correctConnections === wireCount) {
                                levelComplete.classList.add('show');
                                clearInterval(timerInterval);
                                const timeBonus = timeLeft * 10;
                                score += timeBonus + (level * 100);
                                scoreElement.textContent = score;
                                timeBonusElement.textContent = timeBonus;
                                nextBtn.style.display = 'block';
                            }
                        } else {
                            createSpark(endX, endY);
                            wireContainer.style.animation = 'shake 0.5s';
                            setTimeout(() => {
                                wireContainer.style.animation = '';
                            }, 500);
                            timeLeft = Math.max(1, timeLeft - 3);
                            updateTimer();
                        }
                    }
                });

                if (!dropped) {
                    activeWire.element.remove();
                }
                activeWire = null;
            }

            function createSpark(x, y) {
                const spark = document.createElement('div');
                spark.className = 'spark';
                spark.style.left = `${x - 20}px`;
                spark.style.top = `${y - 20}px`;
                spark.style.animation = 'sparkAnimation 0.3s forwards';
                wirePath.appendChild(spark);
                setTimeout(() => {
                    spark.remove();
                }, 300);
            }

            function updateTimer() {
                if (timeLeft <= 0) {
                    clearInterval(timerInterval);
                    timeLeft = 0;
                    resetLevel();
                    return;
                }
                const minutes = Math.floor(timeLeft / 60);
                const seconds = timeLeft % 60;
                timerElement.textContent = `${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}`;
                if (timeLeft <= 10) {
                    timerElement.style.color = 'var(--warning)';
                    timerElement.style.textShadow = '0 0 10px var(--warning)';
                } else {
                    timerElement.style.color = 'var(--success)';
                    timerElement.style.textShadow = '0 0 10px var(--success)';
                }
                timeLeft--;
            }

            function resetLevel() {
                clearInterval(timerInterval);
                initLevel();
            }

            function nextLevel() {
                level++;
                resetLevel();
            }

            function animateCircuitPattern() {
                const circuitLines = document.querySelector('.circuit-lines');
                let offset = 0;
                setInterval(() => {
                    offset = (offset + 0.5) % 50;
                    circuitLines.style.backgroundPosition = `${offset}px ${offset}px`;
                }, 100);
            }

            animateCircuitPattern();

            function handleResize() {
                const container = document.querySelector('.game-container');
                const wireContainer = document.getElementById('wire-container');
                const containerRect = wireContainer.getBoundingClientRect();
                connections.forEach(conn => {
                    const wireElement = document.getElementById(`wire-${conn.leftIndex}-${conn.rightIndex}`);
                    if (wireElement) {
                        const leftConnector = document.querySelector(`.wire-connector.left[data-index="${conn.leftIndex}"]`);
                        const rightConnector = document.querySelector(`.wire-connector.right[data-index="${conn.rightIndex}"]`);
                        if (leftConnector && rightConnector) {
                            const leftRect = leftConnector.getBoundingClientRect();
                            const rightRect = rightConnector.getBoundingClientRect();
                            const startX = leftRect.left + leftRect.width / 2 - containerRect.left;
                            const startY = leftRect.top + leftRect.height / 2 - containerRect.top;
                            const endX = rightRect.left + rightRect.width / 2 - containerRect.left;
                            const endY = rightRect.top + rightRect.height / 2 - containerRect.top;
                            const dx = endX - startX;
                            const dy = endY - startY;
                            const length = Math.sqrt(dx * dx + dy * dy);
                            const angle = Math.atan2(dy, dx) * 180 / Math.PI;
                            wireElement.style.left = `${startX}px`;
                            wireElement.style.top = `${startY}px`;
                            wireElement.style.width = `${length}px`;
                            wireElement.style.transform = `rotate(${angle}deg)`;
                        }
                    }
                });
            }

            let resizeTimeout;
            window.addEventListener('resize', () => {
                clearTimeout(resizeTimeout);
                resizeTimeout = setTimeout(handleResize, 100);
            });
            window.addEventListener('orientationchange', () => {
                clearTimeout(resizeTimeout);
                resizeTimeout = setTimeout(handleResize, 100);
            });
            handleResize();
        });
    </script>
</body>
</html>
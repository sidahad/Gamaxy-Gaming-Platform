@model List<Feedback>

<div class="section-full overlay-black-middle bg-img-fix content-inner"
     style="url('@Url.Content("~/assets/images/wallpaperflare.com_wallpaper (1).jpg")');">
    
    <div class="container">
        <div class="row">
            <div class="col-lg-12">

                <!-- Section Title -->
                <div class="sort-title text-white clearfix text-center mb-5">
                    <h4>What Gamers Say</h4>
                </div>

                <!-- Show Success/Error messages -->
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success text-center">@TempData["Success"]</div>
                }
                else if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger text-center">@TempData["Error"]</div>
                }

                <!-- Testimonials -->
                <div class="section-content mb-5">
                    <div class="testimonial-four owl-carousel owl-theme owl-none">
                        <!-- Testimonial 1 -->
                        <div class="item">
                            <div class="testimonial-4" style="background-image:linear-gradient(to right, #008dff 0%, #D400FF 50%,#008dff 100%);">
                                <div class="testimonial-text">
                                    <p>
                                        “Gamaxy changed the way I discover games. The community vibes and smooth design
                                        make it my go-to hub for gaming.”
                                    </p>
                                </div>
                                <div class="testimonial-detail">
                                    <strong class="testimonial-name">Ayesha Khan</strong>
                                    <span class="testimonial-position">Pro Gamer</span>
                                </div>
                                <div class="quote-right"></div>
                            </div>
                        </div>

                        <!-- Testimonial 2 -->
                        <div class="item">
                            <div class="testimonial-4 testimonial-bg">
                                <div class="testimonial-text">
                                    <p>
                                        “I love how easy it is to upload and share my games on Gamaxy.
                                        It feels like the future of gaming platforms.”
                                    </p>
                                </div>
                                <div class="testimonial-detail">
                                    <strong class="testimonial-name">Zain Malik</strong>
                                    <span class="testimonial-position">Indie Developer</span>
                                </div>
                                <div class="quote-right"></div>
                            </div>
                        </div>

                        <!-- Testimonial 3 -->
                        <div class="item">
                            <div class="testimonial-4 testimonial-bg">
                                <div class="testimonial-text">
                                    <p>
                                        “Gamaxy isn’t just a website — it’s a universe.
                                        The gradient style and futuristic feel make it stand out.”
                                    </p>
                                </div>
                                <div class="testimonial-detail">
                                    <strong class="testimonial-name">Sara Ahmed</strong>
                                    <span class="testimonial-position">Student & Gamer</span>
                                </div>
                                <div class="quote-right"></div>
                            </div>
                        </div>
                        @foreach (var item in Model)
                        {
                            <div class="item">
                                <div class="testimonial-4 testimonial-bg p-4 rounded shadow-lg text-white">

                                    <!-- Star Rating -->
                                    <div class="mb-2">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            if (i <= item.Rating)
                                            {
                                                <i class="fa-solid fa-star text-warning"></i>
                                            }
                                            else
                                            {
                                                <i class="fa-regular fa-star text-warning"></i>
                                            }
                                        }
                                    </div>

                                    <!-- Comment -->
                                    <div class="testimonial-text mb-3">
                                        <p>"@item.Comment"</p>
                                    </div>

                                    <!-- Details -->
                                    <div class="testimonial-detail">
                                        <strong class="testimonial-name">@item.Name</strong>
                                        <span class="testimonial-position">(@item.Email)</span>
                                    </div>

                                    <div class="text-muted small mt-1">
                                        @item.DateSubmitted.ToString("MMM dd, yyyy hh:mm tt")
                                    </div>

                                    <div class="quote-right"></div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
                <!-- End Testimonials -->
            </div>
        </div>
    </div>
</div>
@model Registration
@{
    ViewBag.Title = "Login";
}

<div class="container-fluid d-flex justify-content-center align-items-center" style="padding-top:100px; padding-bottom:100px; background-image: linear-gradient(to right, #008dff 0%, #D400FF 50%,#008dff 100%);">
    <div class="cardrr p-4 shadow-lg rounded border-0 body" style="max-width: 400px; width: 100%; background-color:black">
        <div class="col-lg-12">
            <form method="post" asp-action="Login" class="lform">
                <h1 class="ltitle text-center"style="color:white;">Login</h1>
                <p class="lmessage" style="color:white;">Enter your credentials to access your account.</p>

                @if (!ViewData.ModelState.IsValid)
                {
                    foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <p class="text-danger">@error.ErrorMessage</p>
                    }
                }

                <div class="mb-3">
                    <label class="form-label fw-bold" style="color:white;">Email</label>
                    <input asp-for="Email" type="email" required class="form-control form-controlrr shadow-sm" />
                    @* <input name="email" required type="email" class="form-control form-controlrr shadow-sm" /> *@
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold" style="color:white;">Password</label>
                    <input asp-for="Password" type="password" required class="form-control form-controlrr shadow-sm" />
                    @* <input name="Password" required type="password" class="form-control form-controlrr shadow-sm" /> *@
                </div>

                <button type="submit" class="site-button outline white outline-2 btnhover11">Login</button>

                <p class="lsignin"><a asp-action="ForgetPassword" style="color:white;">Forgot Password?</a></p>

                <p class="lsignin" style="color:white;">Don't have an account? <a asp-action="Registration">Register</a></p>
            </form>
        </div>
    </div>
</div>

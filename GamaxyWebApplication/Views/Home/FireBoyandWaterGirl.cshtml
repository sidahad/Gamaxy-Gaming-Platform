@model GamaxyWebApplication.Models.GameRatingViewModel
@{
    ViewData["Title"] = "Game Page";
    Layout = "_layout3";
}
<script type="text/javascript">
    var gk_isXlsx = false;
    var gk_xlsxFileLookup = {};
    var gk_fileData = {};
    function filledCell(cell) {
      return cell !== '' && cell != null;
    }
    function loadFileData(filename) {
    if (gk_isXlsx && gk_xlsxFileLookup[filename]) {
        try {
            var workbook = XLSX.read(gk_fileData[filename], { type: 'base64' });
            var firstSheetName = workbook.SheetNames[0];
            var worksheet = workbook.Sheets[firstSheetName];
            var jsonData = XLSX.utils.sheet_to_json(worksheet, { header: 1, blankrows: false, defval: '' });
            var filteredData = jsonData.filter(row => row.some(filledCell));
            var headerRowIndex = filteredData.findIndex((row, index) =>
              row.filter(filledCell).length >= filteredData[index + 1]?.filter(filledCell).length
            );
            if (headerRowIndex === -1 || headerRowIndex > 25) {
              headerRowIndex = 0;
            }
            var csv = XLSX.utils.aoa_to_sheet(filteredData.slice(headerRowIndex));
            csv = XLSX.utils.sheet_to_csv(csv, { header: 1 });
            return csv;
        } catch (e) {
            console.error(e);
            return "";
        }
    }
    return gk_fileData[filename] || "";
    }
</script>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Fire Boy & Water Girl: Crystal Temple Adventure</title>
    <link rel="stylesheet" href="~/css/FireBoyandWaterGirl.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700&display=swap" rel="stylesheet">
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
</head>
<body>
    <div class="game-page">
        <header class="game-header">
            <h1 class="game-title">@Model.GameName</h1>
        </header>
        <div class="game-container-wrapper">
            <div class="game-container">
                <!-- Loading Screen -->
                <div class="loading-screen" id="loadingScreen">
                    <div class="game-logo">🔥💧 Fire Boy & Water Girl 💧🔥</div>
                    <h2 style="color: #ecf0f1; margin-bottom: 30px;">Crystal Temple Adventure</h2>
                    <button class="start-btn" onclick="startGame()">Start Adventure</button>
                </div>
                <!-- Game Canvas -->
                <canvas id="gameCanvas" class="hidden"></canvas>
                <!-- Game UI -->
                <div class="game-ui hidden" id="gameUI">
                    <!-- HUD -->
                    <div class="hud">
                        <div class="hud-item">
                            <div class="player-status">
                                <div class="player-icon fire-icon">🔥</div>
                                <span>Fire Boy</span>
                            </div>
                            <span id="fireScore">0</span>
                        </div>
                        <div class="hud-item">
                            <div class="player-status">
                                <div class="player-icon water-icon">💧</div>
                                <span>Water Girl</span>
                            </div>
                            <span id="waterScore">0</span>
                        </div>
                        <div class="hud-item">
                            <span>Gems Collected:</span>
                            <span id="totalGems">0/10</span>
                        </div>
                        <div class="hud-item">
                            <span>Lives:</span>
                            <span id="lives">❤️❤️❤️</span>
                        </div>
                    </div>
                    <!-- Level Info -->
                    <div class="level-info">
                        <div class="level-title">LEVEL 1</div>
                        <div class="level-objective">Collect all gems and reach the exit doors!</div>
                        <div class="timer" id="timer">05:00</div>
                    </div>
                    <!-- Controls Button -->
                    <button class="controls-btn hidden" id="controlsBtn" onclick="toggleControls()">Controls</button>
                    <!-- Controls Panel -->
                    <div class="controls hidden" id="controlsPanel">
                        <div class="control-section">
                            <div class="control-title">🔥 Fire Boy</div>
                            <button class="control-btn">WASD Keys</button>
                            <button class="control-btn">W: Jump</button>
                        </div>
                        <div class="control-section">
                            <div class="control-title">💧 Water Girl</div>
                            <button class="control-btn">Arrow Keys</button>
                            <button class="control-btn">↑: Jump</button>
                        </div>
                        <div class="control-section">
                            <div class="control-title">Game Options</div>
                            <button class="control-btn game-option-btn" onclick="startNewGame()">Start New Game</button>
                            <button class="control-btn game-option-btn" onclick="restartGame()">Restart Game</button>
                            <button class="control-btn game-option-btn" onclick="resetLevel()">🔄 Reset Level</button>
                            <button class="control-btn game-option-btn" onclick="togglePause()">⏸️ Pause</button>
                        </div>
                    </div>
                    <!-- Game Over Screen -->
                    <div class="game-over" id="gameOver">
                        <h2 id="gameOverTitle">Level Complete!</h2>
                        <p id="gameOverText">Amazing teamwork! You collected all the gems!</p>
                        <div>
                            <button class="restart-btn" onclick="nextLevel()">Next Level</button>
                            <button class="restart-btn" onclick="restartGame()">Play Again</button>
                        </div>
                    </div>
                    <!-- Notification -->
                    <div class="notification" id="notification"></div>
                </div>
            </div>
        </div>
        <div class="rating-section">
            <h3 class="rating-title">Rate This Game</h3>
            <p class="rating-text">Average Rating: @Model.AverageRating.ToString("F1")</p>
            @if (Model.UserId.HasValue)
            {
                <p class="rating-text">Your Rating: @(Model.ExistingRating > 0 ? Model.ExistingRating.ToString() : "Not rated yet")</p>
                <form id="ratingForm" method="post" asp-action="RateGame" class="flex items-center space-x-2">
                    <input type="hidden" name="gameName" value="@Model.GameName" />
                    <div class="star-rating">
                        @for (int i = 1; i <= 5; i++)
                        {
                            <span class="star" data-value="@i" style="font-size: 1.5rem; cursor: pointer;">★</span>
                        }
                        <input type="hidden" name="rating" id="ratingInput" />
                    </div>
                    <button type="submit" class="submit-btn">Submit Rating</button>
                </form>
            }
            else
            {
                <p class="rating-text">Please <a asp-action="Login" class="text-success">login</a> to rate this game.</p>
            }
        </div>
    </div>
    <script>
        $(document).ready(function () {
            $('#ratingForm').submit(function (e) {
                e.preventDefault();
                $.ajax({
                    url: '@Url.Action("RateGame", "Home")',
                    type: 'POST',
                    data: $(this).serialize(),
                    headers: {
                        'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function (response) {
                        if (response.success) {
                            alert(response.message);
                            location.reload();
                        } else {
                            alert('Error: ' + response.message);
                        }
                    },
                    error: function () {
                        alert('An error occurred while submitting the rating.');
                    }
                });
            });

            $('.star').on('click', function () {
                const rating = $(this).data('value');
                $('#ratingInput').val(rating);
                $('.star').each(function () {
                    $(this).css('color', $(this).data('value') <= rating ? 'var(--warning)' : 'var(--light)');
                });
            });

            $('.star').hover(
                function () {
                    const rating = $(this).data('value');
                    $('.star').each(function () {
                        $(this).css('color', $(this).data('value') <= rating ? 'var(--warning)' : 'var(--light)');
                    });
                },
                function () {
                    const currentRating = $('#ratingInput').val() || 0;
                    $('.star').each(function () {
                        $(this).css('color', $(this).data('value') <= currentRating ? 'var(--warning)' : 'var(--light)');
                    });
                }
            );
        });

        // Game Variables
        const canvas = document.getElementById('gameCanvas');
        const ctx = canvas.getContext('2d');
        let controlsVisible = false;

        // Set canvas size
        canvas.width = Math.min(window.innerWidth, 1000);
        canvas.height = canvas.width * 4 / 3;
        canvas.style.position = 'relative';

        // Game state
        let gameStarted = false;
        let gamePaused = false;
        let currentLevel = 1;
        let gameTime = 300;
        let lives = 3;
        let totalGems = 0;
        let gemsCollected = 0;

        // Players
        const fireBoy = {
            x: 100,
            y: 400,
            width: 30,
            height: 40,
            vx: 0,
            vy: 0,
            onGround: false,
            color: '#ff6b35',
            score: 0,
            canTouchWater: false,
            canTouchFire: true
        };

        const waterGirl = {
            x: 150,
            y: 400,
            width: 30,
            height: 40,
            vx: 0,
            vy: 0,
            onGround: false,
            color: '#4facfe',
            score: 0,
            canTouchWater: true,
            canTouchFire: false
        };

        // Input handling
        const keys = {};

        // Game objects
        let platforms = [];
        let gems = [];
        let hazards = [];
        let doors = [];
        let switches = [];
        let particles = [];

        // Physics constants
        const GRAVITY = 0.8;
        const JUMP_FORCE = -15;
        const MOVE_SPEED = 5;
        const FRICTION = 0.8;

        function startGame() {
            gameStarted = true;
            document.getElementById('loadingScreen').classList.add('hidden');
            document.getElementById('gameCanvas').classList.remove('hidden');
            document.getElementById('gameUI').classList.remove('hidden');
            setupControls();
            initLevel();
            gameLoop();
            startTimer();
            showNotification('🔥💧 Adventure begins! Work together to solve puzzles!');
        }

        function setupControls() {
            document.addEventListener('keydown', (e) => {
                keys[e.key.toLowerCase()] = true;
                if (e.key === 'Escape') {
                    toggleControls();
                    e.preventDefault();
                }
                if (['w', 'a', 's', 'd', 'arrowup', 'arrowdown', 'arrowleft', 'arrowright'].includes(e.key.toLowerCase())) {
                    e.preventDefault();
                }
            });

            document.addEventListener('keyup', (e) => {
                keys[e.key.toLowerCase()] = false;
            });
        }

        function toggleControls() {
            const controlsBtn = document.getElementById('controlsBtn');
            const controlsPanel = document.getElementById('controlsPanel');
            controlsVisible = !controlsVisible;
            if (controlsVisible) {
                controlsBtn.classList.remove('hidden');
                controlsPanel.classList.remove('hidden');
                controlsPanel.classList.add('show');
                showNotification('🎮 Controls panel opened');
            } else {
                controlsBtn.classList.add('hidden');
                controlsPanel.classList.remove('show');
                setTimeout(() => {
                    controlsPanel.classList.add('hidden');
                }, 300);
                showNotification('🎮 Controls panel closed');
            }
        }

        function startNewGame() {
            currentLevel = 1;
            gameTime = 300;
            lives = 3;
            fireBoy.score = 0;
            waterGirl.score = 0;
            gemsCollected = 0;
            document.getElementById('gameOver').classList.remove('show');
            initLevel();
            gameStarted = true;
            gamePaused = false;
            startTimer();
            toggleControls();
            showNotification('🌟 New game started!');
        }

        function initLevel() {
            fireBoy.x = 100;
            fireBoy.y = 400;
            fireBoy.vx = 0;
            fireBoy.vy = 0;
            waterGirl.x = 150;
            waterGirl.y = 400;
            waterGirl.vx = 0;
            waterGirl.vy = 0;
            createLevel1();
            gemsCollected = 0;
            updateUI();
        }

        function createLevel1() {
            platforms = [
                { x: 0, y: canvas.height - 50, width: 300, height: 50, type: 'normal' },
                { x: 400, y: canvas.height - 50, width: 300, height: 50, type: 'normal' },
                { x: canvas.width - 300, y: canvas.height - 50, width: 300, height: 50, type: 'normal' },
                { x: 200, y: canvas.height - 200, width: 150, height: 20, type: 'normal' },
                { x: 450, y: canvas.height - 300, width: 150, height: 20, type: 'normal' },
                { x: 700, y: canvas.height - 250, width: 150, height: 20, type: 'normal' },
                { x: 100, y: canvas.height - 400, width: 100, height: 20, type: 'normal' },
                { x: 600, y: canvas.height - 450, width: 100, height: 20, type: 'normal' },
                { x: 350, y: canvas.height - 150, width: 100, height: 20, type: 'fire' },
                { x: 550, y: canvas.height - 150, width: 100, height: 20, type: 'water' }
            ];
            gems = [
                { x: 250, y: canvas.height - 240, type: 'fire', collected: false },
                { x: 500, y: canvas.height - 340, type: 'water', collected: false },
                { x: 750, y: canvas.height - 290, type: 'neutral', collected: false },
                { x: 150, y: canvas.height - 440, type: 'fire', collected: false },
                { x: 650, y: canvas.height - 490, type: 'water', collected: false },
                { x: 400, y: canvas.height - 190, type: 'neutral', collected: false },
                { x: 600, y: canvas.height - 190, type: 'neutral', collected: false },
                { x: 75, y: canvas.height - 90, type: 'fire', collected: false },
                { x: canvas.width - 75, y: canvas.height - 90, type: 'water', collected: false },
                { x: canvas.width / 2, y: canvas.height - 500, type: 'neutral', collected: false }
            ];
            hazards = [
                { x: 300, y: canvas.height - 70, width: 100, height: 20, type: 'lava' },
                { x: 700, y: canvas.height - 70, width: 100, height: 20, type: 'water' },
                { x: 500, y: canvas.height - 70, width: 100, height: 20, type: 'acid' }
            ];
            doors = [
                { x: 50, y: canvas.height - 150, width: 40, height: 60, type: 'fire', open: false },
                { x: canvas.width - 90, y: canvas.height - 150, width: 40, height: 60, type: 'water', open: false }
            ];
            switches = [
                { x: 275, y: canvas.height - 220, width: 20, height: 10, pressed: false, target: 'door1' },
                { x: 575, y: canvas.height - 270, width: 20, height: 10, pressed: false, target: 'door2' }
            ];
            totalGems = gems.length;
        }

        function gameLoop() {
            if (!gameStarted || gamePaused) {
                requestAnimationFrame(gameLoop);
                return;
            }
            update();
            render();
            requestAnimationFrame(gameLoop);
        }

        function update() {
            updatePlayer(fireBoy, 'w', 'a', 'd');
            updatePlayer(waterGirl, 'arrowup', 'arrowleft', 'arrowright');
            updateParticles();
            checkCollisions();
            checkWinCondition();
        }

        function updatePlayer(player, jumpKey, leftKey, rightKey) {
            if (keys[leftKey]) {
                player.vx = -MOVE_SPEED;
            } else if (keys[rightKey]) {
                player.vx = MOVE_SPEED;
            } else {
                player.vx *= FRICTION;
            }
            if (keys[jumpKey] && player.onGround) {
                player.vy = JUMP_FORCE;
                player.onGround = false;
                createJumpParticles(player);
            }
            player.vy += GRAVITY;
            player.x += player.vx;
            player.y += player.vy;
            player.onGround = false;
            platforms.forEach(platform => {
                if (checkPlatformCollision(player, platform)) {
                    if (platform.type === 'fire' && !player.canTouchFire) {
                        takeDamage();
                        return;
                    }
                    if (platform.type === 'water' && !player.canTouchWater) {
                        takeDamage();
                        return;
                    }
                    if (player.vy > 0) {
                        player.y = platform.y - player.height;
                        player.vy = 0;
                        player.onGround = true;
                    }
                }
            });
            if (player.x < 0) player.x = 0;
            if (player.x + player.width > canvas.width) player.x = canvas.width - player.width;
            if (player.y > canvas.height) {
                takeDamage();
            }
        }

        function checkPlatformCollision(player, platform) {
            return player.x < platform.x + platform.width &&
                   player.x + player.width > platform.x &&
                   player.y < platform.y + platform.height &&
                   player.y + player.height > platform.y;
        }

        function checkCollisions() {
            gems.forEach((gem, index) => {
                if (!gem.collected) {
                    if (checkCollision(fireBoy, gem) && (gem.type === 'fire' || gem.type === 'neutral')) {
                        collectGem(gem, fireBoy, index);
                    }
                    if (checkCollision(waterGirl, gem) && (gem.type === 'water' || gem.type === 'neutral')) {
                        collectGem(gem, waterGirl, index);
                    }
                }
            });
            hazards.forEach(hazard => {
                if (checkCollision(fireBoy, hazard) && hazard.type !== 'lava') {
                    takeDamage();
                }
                if (checkCollision(waterGirl, hazard) && hazard.type !== 'water') {
                    takeDamage();
                }
            });
            switches.forEach(switchObj => {
                const wasPressed = switchObj.pressed;
                switchObj.pressed = checkCollision(fireBoy, switchObj) || checkCollision(waterGirl, switchObj);
                if (switchObj.pressed && !wasPressed) {
                    activateSwitch(switchObj);
                }
            });
        }

        function checkCollision(obj1, obj2) {
            return obj1.x < obj2.x + (obj2.width || 20) &&
                   obj1.x + obj1.width > obj2.x &&
                   obj1.y < obj2.y + (obj2.height || 20) &&
                   obj1.y + obj1.height > obj2.y;
        }

        function collectGem(gem, player, index) {
            gem.collected = true;
            gemsCollected++;
            player.score += 100;
            createGemParticles(gem);
            showNotification(`💎 Gem collected! ${gemsCollected}/${totalGems}`);
            updateUI();
        }

        function activateSwitch(switchObj) {
            doors.forEach(door => {
                if (door.type === switchObj.target.includes('1') ? 'fire' : 'water') {
                    door.open = true;
                }
            });
            showNotification('🔓 Door unlocked!');
        }

        function takeDamage() {
            lives--;
            updateUI();
            if (lives <= 0) {
                gameOver(false);
            } else {
                showNotification('💔 Life lost! Be careful!');
                fireBoy.x = 100;
                fireBoy.y = 400;
                waterGirl.x = 150;
                waterGirl.y = 400;
            }
        }

        function checkWinCondition() {
            if (gemsCollected >= totalGems) {
                const fireAtDoor = doors.some(door => door.type === 'fire' && door.open && checkCollision(fireBoy, door));
                const waterAtDoor = doors.some(door => door.type === 'water' && door.open && checkCollision(waterGirl, door));
                if (fireAtDoor && waterAtDoor) {
                    gameOver(true);
                }
            }
        }

        function render() {
            const skyGradient = ctx.createLinearGradient(0, 0, 0, canvas.height);
            skyGradient.addColorStop(0, '#87ceeb');
            skyGradient.addColorStop(0.3, '#4682b4');
            skyGradient.addColorStop(0.7, '#2f4f4f');
            skyGradient.addColorStop(1, '#1e3a5f');
            ctx.fillStyle = skyGradient;
            ctx.fillRect(0, 0, canvas.width, canvas.height);
            drawAtmosphericEffects();
            platforms.forEach(platform => drawRealisticPlatform(platform));
            hazards.forEach(hazard => drawRealisticHazard(hazard));
            gems.forEach(gem => { if (!gem.collected) drawRealisticGem(gem); });
            switches.forEach(switchObj => drawRealisticSwitch(switchObj));
            doors.forEach(door => drawRealisticDoor(door));
            drawPlayer(fireBoy);
            drawPlayer(waterGirl);
            particles.forEach(particle => {
                ctx.fillStyle = particle.color;
                ctx.globalAlpha = particle.alpha;
                ctx.fillRect(particle.x, particle.y, particle.size, particle.size);
                ctx.globalAlpha = 1;
            });
        }

        function drawAtmosphericEffects() {
            const time = Date.now() * 0.001;
            for (let i = 0; i < 20; i++) {
                const x = (Math.sin(time * 0.5 + i) * 50) + (i * canvas.width / 20);
                const y = (Math.cos(time * 0.3 + i) * 30) + (i * 20);
                const alpha = 0.1 + Math.sin(time + i) * 0.05;
                ctx.fillStyle = `rgba(255, 255, 255, ${alpha})`;
                ctx.beginPath();
                ctx.arc(x % canvas.width, y % canvas.height, 2, 0, Math.PI * 2);
                ctx.fill();
            }
            const mountainGradient = ctx.createLinearGradient(0, canvas.height * 0.6, 0, canvas.height * 0.8);
            mountainGradient.addColorStop(0, 'rgba(47, 79, 79, 0.3)');
            mountainGradient.addColorStop(1, 'rgba(47, 79, 79, 0.1)');
            ctx.fillStyle = mountainGradient;
            ctx.beginPath();
            for (let x = 0; x <= canvas.width; x += 50) {
                const height = Math.sin(x * 0.01) * 50 + 100;
                if (x === 0) ctx.moveTo(x, canvas.height * 0.8 - height);
                else ctx.lineTo(x, canvas.height * 0.8 - height);
            }
            ctx.lineTo(canvas.width, canvas.height);
            ctx.lineTo(0, canvas.height);
            ctx.closePath();
            ctx.fill();
        }

        function drawRealisticPlatform(platform) {
            let gradient, shadowColor, glowIntensity;
            switch(platform.type) {
                case 'fire':
                    gradient = ctx.createLinearGradient(platform.x, platform.y, platform.x, platform.y + platform.height);
                    gradient.addColorStop(0, '#ff8a50');
                    gradient.addColorStop(0.3, '#ff6b35');
                    gradient.addColorStop(0.7, '#e55100');
                    gradient.addColorStop(1, '#bf360c');
                    shadowColor = '#ff6b35';
                    glowIntensity = 20;
                    break;
                case 'water':
                    gradient = ctx.createLinearGradient(platform.x, platform.y, platform.x, platform.y + platform.height);
                    gradient.addColorStop(0, '#64b5f6');
                    gradient.addColorStop(0.3, '#4facfe');
                    gradient.addColorStop(0.7, '#2196f3');
                    gradient.addColorStop(1, '#1565c0');
                    shadowColor = '#4facfe';
                    glowIntensity = 15;
                    break;
                default:
                    gradient = ctx.createLinearGradient(platform.x, platform.y, platform.x, platform.y + platform.height);
                    gradient.addColorStop(0, '#546e7a');
                    gradient.addColorStop(0.3, '#455a64');
                    gradient.addColorStop(0.7, '#37474f');
                    gradient.addColorStop(1, '#263238');
                    shadowColor = '#455a64';
                    glowIntensity = 5;
            }
            ctx.fillStyle = 'rgba(0, 0, 0, 0.3)';
            ctx.fillRect(platform.x + 3, platform.y + 3, platform.width, platform.height);
            ctx.fillStyle = gradient;
            ctx.fillRect(platform.x, platform.y, platform.width, platform.height);
            ctx.shadowColor = shadowColor;
            ctx.shadowBlur = glowIntensity;
            ctx.fillRect(platform.x, platform.y, platform.width, platform.height);
            ctx.shadowBlur = 0;
            const highlightGradient = ctx.createLinearGradient(platform.x, platform.y, platform.x, platform.y + 5);
            highlightGradient.addColorStop(0, 'rgba(255, 255, 255, 0.4)');
            highlightGradient.addColorStop(1, 'rgba(255, 255, 255, 0)');
            ctx.fillStyle = highlightGradient;
            ctx.fillRect(platform.x, platform.y, platform.width, 5);
            if (platform.type !== 'normal') {
                drawPlatformTexture(platform);
            }
        }

        function drawPlatformTexture(platform) {
            const time = Date.now() * 0.003;
            if (platform.type === 'fire') {
                for (let x = platform.x; x < platform.x + platform.width; x += 8) {
                    for (let y = platform.y; y < platform.y + platform.height; y += 8) {
                        const flicker = Math.sin(time * 3 + x * 0.1 + y * 0.1) * 0.3 + 0.7;
                        ctx.fillStyle = `rgba(255, 193, 7, ${flicker * 0.6})`;
                        ctx.fillRect(x, y, 4, 4);
                    }
                }
            } else if (platform.type === 'water') {
                for (let x = platform.x; x < platform.x + platform.width; x += 6) {
                    const wave = Math.sin(time * 2 + x * 0.05) * 3;
                    ctx.fillStyle = 'rgba(255, 255, 255, 0.3)';
                    ctx.fillRect(x, platform.y + wave, 2, platform.height - wave);
                }
            }
        }

        function drawRealisticHazard(hazard) {
            const time = Date.now() * 0.002;
            let gradient, particleColor, glowColor;
            switch(hazard.type) {
                case 'lava':
                    gradient = ctx.createRadialGradient(
                        hazard.x + hazard.width/2, hazard.y + hazard.height/2, 0,
                        hazard.x + hazard.width/2, hazard.y + hazard.height/2, hazard.width/2
                    );
                    gradient.addColorStop(0, '#ffeb3b');
                    gradient.addColorStop(0.3, '#ff9800');
                    gradient.addColorStop(0.6, '#f44336');
                    gradient.addColorStop(1, '#b71c1c');
                    particleColor = '#ff5722';
                    glowColor = '#ff6b35';
                    break;
                case 'water':
                    gradient = ctx.createRadialGradient(
                        hazard.x + hazard.width/2, hazard.y + hazard.height/2, 0,
                        hazard.x + hazard.width/2, hazard.y + hazard.height/2, hazard.width/2
                    );
                    gradient.addColorStop(0, '#e1f5fe');
                    gradient.addColorStop(0.3, '#4fc3f7');
                    gradient.addColorStop(0.6, '#2196f3');
                    gradient.addColorStop(1, '#0d47a1');
                    particleColor = '#2196f3';
                    glowColor = '#4facfe';
                    break;
                case 'acid':
                    gradient = ctx.createRadialGradient(
                        hazard.x + hazard.width/2, hazard.y + hazard.height/2, 0,
                        hazard.x + hazard.width/2, hazard.y + hazard.height/2, hazard.width/2
                    );
                    gradient.addColorStop(0, '#c8e6c9');
                    gradient.addColorStop(0.3, '#66bb6a');
                    gradient.addColorStop(0.6, '#4caf50');
                    gradient.addColorStop(1, '#1b5e20');
                    particleColor = '#4caf50';
                    glowColor = '#66bb6a';
                    break;
            }
            ctx.fillStyle = gradient;
            ctx.fillRect(hazard.x, hazard.y, hazard.width, hazard.height);
            const glowIntensity = 15 + Math.sin(time * 2) * 5;
            ctx.shadowColor = glowColor;
            ctx.shadowBlur = glowIntensity;
            ctx.fillRect(hazard.x, hazard.y, hazard.width, hazard.height);
            ctx.shadowBlur = 0;
            for (let i = 0; i < 5; i++) {
                const bubbleX = hazard.x + Math.random() * hazard.width;
                const bubbleY = hazard.y + Math.sin(time * 3 + i) * 5 + 5;
                const bubbleSize = 2 + Math.sin(time * 4 + i) * 2;
                ctx.fillStyle = `rgba(255, 255, 255, ${0.3 + Math.sin(time * 2 + i) * 0.2})`;
                ctx.beginPath();
                ctx.arc(bubbleX, bubbleY, bubbleSize, 0, Math.PI * 2);
                ctx.fill();
            }
        }

        function drawRealisticGem(gem) {
            const time = Date.now() * 0.003;
            const offset = Math.sin(time + gem.x * 0.01) * 4;
            const rotation = time * 2 + gem.x * 0.01;
            const centerX = gem.x + 10;
            const centerY = gem.y + 10 + offset;
            ctx.save();
            ctx.translate(centerX, centerY);
            ctx.rotate(rotation);
            let gradient;
            switch(gem.type) {
                case 'fire':
                    gradient = ctx.createRadialGradient(0, 0, 0, 0, 0, 12);
                    gradient.addColorStop(0, '#ffeb3b');
                    gradient.addColorStop(0.3, '#ff9800');
                    gradient.addColorStop(0.6, '#ff6b35');
                    gradient.addColorStop(1, '#e65100');
                    break;
                case 'water':
                    gradient = ctx.createRadialGradient(0, 0, 0, 0, 0, 12);
                    gradient.addColorStop(0, '#e3f2fd');
                    gradient.addColorStop(0.3, '#81d4fa');
                    gradient.addColorStop(0.6, '#4facfe');
                    gradient.addColorStop(1, '#0277bd');
                    break;
                default:
                    gradient = ctx.createRadialGradient(0, 0, 0, 0, 0, 12);
                    gradient.addColorStop(0, '#fff9c4');
                    gradient.addColorStop(0.3, '#fff176');
                    gradient.addColorStop(0.6, '#f39c12');
                    gradient.addColorStop(1, '#e65100');
            }
            ctx.fillStyle = gradient;
            ctx.beginPath();
            ctx.moveTo(0, -12);
            ctx.lineTo(8, -4);
            ctx.lineTo(0, 12);
            ctx.lineTo(-8, -4);
            ctx.closePath();
            ctx.fill();
            const sparkleIntensity = 20 + Math.sin(time * 4) * 10;
            ctx.shadowColor = gem.type === 'fire' ? '#ff6b35' : gem.type === 'water' ? '#4facfe' : '#f39c12';
            ctx.shadowBlur = sparkleIntensity;
            ctx.fill();
            ctx.shadowBlur = 0;
            ctx.fillStyle = 'rgba(255, 255, 255, 0.8)';
            ctx.beginPath();
            ctx.moveTo(-2, -8);
            ctx.lineTo(2, -8);
            ctx.lineTo(0, -4);
            ctx.closePath();
            ctx.fill();
            ctx.restore();
            for (let i = 0; i < 3; i++) {
                const sparkleX = centerX + Math.sin(time * 3 + i * 2) * 15;
                const sparkleY = centerY + Math.cos(time * 2 + i * 2) * 15;
                const sparkleAlpha = 0.3 + Math.sin(time * 4 + i) * 0.3;
                ctx.fillStyle = `rgba(255, 255, 255, ${sparkleAlpha})`;
                ctx.beginPath();
                ctx.arc(sparkleX, sparkleY, 1, 0, Math.PI * 2);
                ctx.fill();
            }
        }

        function drawPlayer(player) {
            const time = Date.now() * 0.002;
            let bodyGradient = ctx.createRadialGradient(
                player.x + player.width/2, player.y + player.height/2, 0,
                player.x + player.width/2, player.y + player.height/2, player.width/2
            );
            if (player === fireBoy) {
                bodyGradient.addColorStop(0, '#ff8a50');
                bodyGradient.addColorStop(0.5, '#ff6b35');
                bodyGradient.addColorStop(1, '#e55100');
            } else {
                bodyGradient.addColorStop(0, '#64b5f6');
                bodyGradient.addColorStop(0.5, '#4facfe');
                bodyGradient.addColorStop(1, '#1565c0');
            }
            ctx.fillStyle = 'rgba(0, 0, 0, 0.3)';
            ctx.fillRect(player.x + 2, player.y + player.height - 2, player.width, 4);
            ctx.fillStyle = bodyGradient;
            ctx.fillRect(player.x, player.y, player.width, player.height);
            const glowIntensity = 15 + Math.sin(time * 3) * 5;
            ctx.shadowColor = player.color;
            ctx.shadowBlur = glowIntensity;
            ctx.fillRect(player.x, player.y, player.width, player.height);
            ctx.shadowBlur = 0;
            const highlightGradient = ctx.createLinearGradient(
                player.x, player.y, player.x + player.width/3, player.y + player.height/3
            );
            highlightGradient.addColorStop(0, 'rgba(255, 255, 255, 0.4)');
            highlightGradient.addColorStop(1, 'rgba(255, 255, 255, 0)');
            ctx.fillStyle = highlightGradient;
            ctx.fillRect(player.x, player.y, player.width/2, player.height/2);
            const eyeGlow = Math.sin(time * 4) * 0.2 + 0.8;
            ctx.fillStyle = `rgba(255, 255, 255, ${eyeGlow})`;
            ctx.fillRect(player.x + 6, player.y + 8, 6, 6);
            ctx.fillRect(player.x + 18, player.y + 8, 6, 6);
            ctx.fillStyle = 'rgba(0, 0, 0, 0.8)';
            ctx.fillRect(player.x + 8, player.y + 10, 2, 2);
            ctx.fillRect(player.x + 20, player.y + 10, 2, 2);
            ctx.strokeStyle = 'rgba(255, 255, 255, 0.9)';
            ctx.lineWidth = 2;
            ctx.beginPath();
            ctx.arc(player.x + player.width/2, player.y + 22, 6, 0, Math.PI);
            ctx.stroke();
        }

        function drawRealisticSwitch(switchObj) {
            const time = Date.now() * 0.003;
            const baseGradient = ctx.createLinearGradient(switchObj.x, switchObj.y, switchObj.x, switchObj.y + switchObj.height);
            baseGradient.addColorStop(0, '#455a64');
            baseGradient.addColorStop(1, '#263238');
            ctx.fillStyle = baseGradient;
            ctx.fillRect(switchObj.x - 5, switchObj.y - 2, switchObj.width + 10, switchObj.height + 4);
            let buttonGradient;
            if (switchObj.pressed) {
                buttonGradient = ctx.createRadialGradient(
                    switchObj.x + switchObj.width/2, switchObj.y + switchObj.height/2, 0,
                    switchObj.x + switchObj.width/2, switchObj.y + switchObj.height/2, switchObj.width/2
                );
                buttonGradient.addColorStop(0, '#66bb6a');
                buttonGradient.addColorStop(0.5, '#4caf50');
                buttonGradient.addColorStop(1, '#2e7d32');
                const glowIntensity = 15 + Math.sin(time * 4) * 5;
                ctx.shadowColor = '#4caf50';
                ctx.shadowBlur = glowIntensity;
            } else {
                buttonGradient = ctx.createRadialGradient(
                    switchObj.x + switchObj.width/2, switchObj.y + switchObj.height/2, 0,
                    switchObj.x + switchObj.width/2, switchObj.y + switchObj.height/2, switchObj.width/2
                );
                buttonGradient.addColorStop(0, '#ef5350');
                buttonGradient.addColorStop(0.5, '#f44336');
                buttonGradient.addColorStop(1, '#c62828');
            }
            ctx.fillStyle = buttonGradient;
            ctx.fillRect(switchObj.x, switchObj.y, switchObj.width, switchObj.height);
            ctx.shadowBlur = 0;
            ctx.fillStyle = 'rgba(255, 255, 255, 0.3)';
            ctx.fillRect(switchObj.x + 2, switchObj.y + 1, switchObj.width - 4, 2);
        }

        function drawRealisticDoor(door) {
            const time = Date.now() * 0.002;
            const frameGradient = ctx.createLinearGradient(door.x - 5, door.y, door.x - 5, door.y + door.height);
            frameGradient.addColorStop(0, '#546e7a');
            frameGradient.addColorStop(1, '#37474f');
            ctx.fillStyle = frameGradient;
            ctx.fillRect(door.x - 5, door.y, door.width + 10, door.height);
            let doorGradient;
            if (door.open) {
                if (door.type === 'fire') {
                    doorGradient = ctx.createLinearGradient(door.x, door.y, door.x, door.y + door.height);
                    doorGradient.addColorStop(0, '#ff8a50');
                    doorGradient.addColorStop(0.5, '#ff6b35');
                    doorGradient.addColorStop(1, '#e55100');
                    const glowIntensity = 20 + Math.sin(time * 3) * 8;
                    ctx.shadowColor = '#ff6b35';
                    ctx.shadowBlur = glowIntensity;
                } else {
                    doorGradient = ctx.createLinearGradient(door.x, door.y, door.x, door.y + door.height);
                    doorGradient.addColorStop(0, '#64b5f6');
                    doorGradient.addColorStop(0.5, '#4facfe');
                    doorGradient.addColorStop(1, '#1565c0');
                    const glowIntensity = 20 + Math.sin(time * 3) * 8;
                    ctx.shadowColor = '#4facfe';
                    ctx.shadowBlur = glowIntensity;
                }
            } else {
                doorGradient = ctx.createLinearGradient(door.x, door.y, door.x, door.y + door.height);
                doorGradient.addColorStop(0, '#90a4ae');
                doorGradient.addColorStop(1, '#607d8b');
            }
            ctx.fillStyle = doorGradient;
            ctx.fillRect(door.x, door.y, door.width, door.height);
            ctx.shadowBlur = 0;
            if (door.open) {
                for (let i = 0; i < 8; i++) {
                    const particleX = door.x + Math.random() * door.width;
                    const particleY = door.y + (time * 50 + i * 20) % door.height;
                    const alpha = 0.3 + Math.sin(time * 4 + i) * 0.2;
                    ctx.fillStyle = door.type === 'fire' ?
                        `rgba(255, 193, 7, ${alpha})` :
                        `rgba(129, 212, 250, ${alpha})`;
                    ctx.beginPath();
                    ctx.arc(particleX, particleY, 2, 0, Math.PI * 2);
                    ctx.fill();
                }
                ctx.fillStyle = 'rgba(255, 255, 255, 0.4)';
                ctx.fillRect(door.x + 2, door.y + 2, door.width - 4, door.height/4);
            } else {
                ctx.fillStyle = '#37474f';
                ctx.fillRect(door.x + door.width/2 - 3, door.y + door.height/2 - 5, 6, 8);
                ctx.strokeStyle = '#37474f';
                ctx.lineWidth = 2;
                ctx.beginPath();
                ctx.arc(door.x + door.width/2, door.y + door.height/2 - 3, 4, Math.PI, 0);
                ctx.stroke();
            }
        }

        function createJumpParticles(player) {
            for (let i = 0; i < 8; i++) {
                particles.push({
                    x: player.x + Math.random() * player.width,
                    y: player.y + player.height,
                    vx: (Math.random() - 0.5) * 6,
                    vy: Math.random() * -4 - 2,
                    color: player.color,
                    alpha: 1,
                    size: Math.random() * 5 + 2,
                    life: 40
                });
            }
        }

        function createGemParticles(gem) {
            for (let i = 0; i < 10; i++) {
                particles.push({
                    x: gem.x + 10,
                    y: gem.y + 10,
                    vx: (Math.random() - 0.5) * 6,
                    vy: (Math.random() - 0.5) * 6,
                    color: '#f39c12',
                    alpha: 1,
                    size: Math.random() * 3 + 1,
                    life: 40
                });
            }
        }

        function updateParticles() {
            particles = particles.filter(particle => {
                particle.x += particle.vx;
                particle.y += particle.vy;
                particle.vy += 0.2;
                particle.alpha -= 1 / particle.life;
                particle.life--;
                return particle.life > 0 && particle.alpha > 0;
            });
        }

        function startTimer() {
            const timerInterval = setInterval(() => {
                if (!gameStarted || gamePaused) return;
                gameTime--;
                updateTimer();
                if (gameTime <= 0) {
                    clearInterval(timerInterval);
                    gameOver(false);
                }
            }, 1000);
        }

        function updateTimer() {
            const minutes = Math.floor(gameTime / 60);
            const seconds = gameTime % 60;
            document.getElementById('timer').textContent =
                `${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}`;
        }

        function updateUI() {
            document.getElementById('fireScore').textContent = fireBoy.score;
            document.getElementById('waterScore').textContent = waterGirl.score;
            document.getElementById('totalGems').textContent = `${gemsCollected}/${totalGems}`;
            document.getElementById('lives').textContent = '❤️'.repeat(lives);
        }

        function gameOver(won) {
            gameStarted = false;
            const gameOverDiv = document.getElementById('gameOver');
            const title = document.getElementById('gameOverTitle');
            const text = document.getElementById('gameOverText');
            if (won) {
                title.textContent = '🎉 Level Complete! 🎉';
                text.textContent = `Amazing teamwork! You collected all ${totalGems} gems in ${Math.floor((300 - gameTime) / 60)}:${((300 - gameTime) % 60).toString().padStart(2, '0')}!`;
            } else {
                title.textContent = '💔 Game Over 💔';
                text.textContent = lives <= 0 ? 'You ran out of lives! Try again!' : 'Time\'s up! Work faster next time!';
            }
            gameOverDiv.classList.add('show');
        }

        function nextLevel() {
            currentLevel++;
            document.getElementById('gameOver').classList.remove('show');
            gameTime = 300;
            lives = 3;
            initLevel();
            gameStarted = true;
            startTimer();
            showNotification(`🎮 Level ${currentLevel} - New challenges await!`);
        }

        function restartGame() {
            currentLevel = 1;
            document.getElementById('gameOver').classList.remove('show');
            gameTime = 300;
            lives = 3;
            fireBoy.score = 0;
            waterGirl.score = 0;
            initLevel();
            gameStarted = true;
            startTimer();
            showNotification('🔄 Game restarted! Good luck!');
        }

        function resetLevel() {
            initLevel();
            showNotification('🔄 Level reset!');
        }

        function togglePause() {
            gamePaused = !gamePaused;
            showNotification(gamePaused ? '⏸️ Game paused' : '▶️ Game resumed');
        }

        function showNotification(message) {
            const notification = document.getElementById('notification');
            notification.textContent = message;
            notification.classList.add('show');
            setTimeout(() => {
                notification.classList.remove('show');
            }, 3000);
        }

        window.addEventListener('resize', () => {
            canvas.width = Math.min(window.innerWidth, 1000);
            canvas.height = canvas.width * 4 / 3;
            initLevel();
        });

        console.log('🔥💧 Fire Boy & Water Girl: Crystal Temple Adventure');
        console.log('🎮 Controls:');
        console.log('🔥 Fire Boy: WASD (W to jump)');
        console.log('💧 Water Girl: Arrow Keys (↑ to jump)');
        console.log('🤝 Work together to solve puzzles and collect all gems!');
    </script>
</body>
</html>
                },
                lettuce: {
                    name: 'Lettuce',
                    height: 15,
                    image: "data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 160 40'%3E%3Cpath d='M30,30 Q40,25 50,30 Q60,25 70,30 Q80,25 90,30 Q100,25 110,30 Q120,25 130,30 L130,25 Q120,20 110,25 Q100,20 90,25 Q80,20 70,25 Q60,20 50,25 Q40,20 30,25 Z' fill='%2327AE60'/%3E%3Cpath d='M30,30 Q40,25 50,30 Q60,25 70,30 Q80,25 90,30 Q100,25 110,30 Q120,25 130,30 L130,32 Q120,27 110,32 Q100,27 90,32 Q80,27 70,32 Q60,27 50,32 Q40,27 30,32 Z' fill='%232ECC71'/%3E%3C/svg%3E"

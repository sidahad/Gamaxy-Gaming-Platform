@model IEnumerable<PremiumGameRating>
@{
    ViewData["Title"] = "My Premium Game Reviews and Ratings Page";
    Layout = "_layout";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Premium Game Reviews and Ratings Page</title>
    <link href="~/css/MyPremiumGameReviewsandRatings.css" rel="stylesheet" />
    <!-- Font Awesome -->
    <script src="https://kit.fontawesome.com/a076d05399.js" crossorigin="anonymous"></script>

    <!-- Bootstrap 5.3 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
   <style>
        .page-wraper {
            background: transparent;
            color: white;
        }
   </style>
</head>
<body>
<!-- Loading Overlay -->
<div class="loading-overlay" id="loadingOverlay">
    <div class="loading-spinner"></div>
</div>
 <div style="height:100px;"></div>
<!-- Animated Background Particles -->
<div class="particles" id="particles"></div>

<div class="container my-5 text-white" >
    <h1 class="mb-4">My Premium Game Reviews and Ratings</h1>

    @if (Model.Any())
    {
        <table class="table table-dark table-striped">
            <thead>
                <tr>
                    <th>Game Name</th>
                    <th>Rating</th>
                    <th>Date</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var rating in Model)
                {
                    <tr>
                        <td>@rating.GameName</td>
                        <td>
                            @for (int i = 1; i <= 5; i++)
                            {
                                if (i <= rating.Rating)
                                {
                                    <i class="fas fa-star text-warning"></i>
                                }
                                else
                                {
                                    <i class="far fa-star text-warning"></i>
                                }
                            }
                            <span class="ms-2">(@rating.Rating)</span>
                        </td>
                        <td>@rating.RatingDate.ToString("MMM dd, yyyy HH:mm")</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p class="text-muted">You haven't rated any premium games yet.</p>
    }

    <a asp-controller="Launcher" asp-action="Index" class="btn btn-primary mt-3">
        <i class="fas fa-arrow-left me-2"></i>Back to Games
    </a>
</div>

    <script src="~/js/MyPremiumGameReviewsandRatings.js"></script>

</body>
</html>
@model GamaxyWebApplication.Models.GameRatingViewModel
@{
    ViewData["Title"] = "Game Page";
    Layout = "_layout3";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Fishing Adventure</title>
    <link rel="stylesheet" href="~/css/fish.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700&display=swap" rel="stylesheet">
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
</head>
<body>
    <div class="game-page">
        <header class="game-header">
            <h1 class="game-title">@Model.GameName</h1>
        </header>
        <div class="game-container-wrapper">
            <div class="game-container">
                <div class="sky"></div>
                <div class="sun"></div>
                <div class="water"></div>
                <div class="dock"></div>
                <div class="fishing-rod" id="fishing-rod"></div>
                <div class="fishing-line" id="fishing-line"></div>

                <div class="controls">
                    <button id="cast-btn">Cast Line</button>
                    <button id="reel-btn" disabled>Reel In</button>
                    <button id="shop-btn">Shop</button>
                    <button id="collection-btn">Collection</button>
                </div>

                <div class="scoreboard">
                    <h2>Fishing Stats</h2>
                    <p>Score: <span id="score">0</span></p>
                    <p>Coins: <span id="coins">50</span></p>
                    <p>Fish Caught: <span id="fish-count">0</span></p>
                </div>

                <div class="fishing-zones">
                    <h3>Fishing Zones</h3>
                    <div class="zone-option active" data-zone="shore">Shore</div>
                    <div class="zone-option" data-zone="lake">Lake</div>
                    <div class="zone-option" data-zone="deep">Deep Sea</div>
                </div>

                <div class="bait-selector">
                    <h3>Bait</h3>
                    <div class="bait-options">
                        <div class="bait-option selected" data-bait="worm" style="background-color: #8B4513;">
                            <span class="bait-count">∞</span>
                        </div>
                        <div class="bait-option" data-bait="corn" style="background-color: #FFD700;">
                            <span class="bait-count" id="corn-count">0</span>
                        </div>
                        <div class="bait-option" data-bait="lure" style="background-color: #FF4500;">
                            <span class="bait-count" id="lure-count">0</span>
                        </div>
                    </div>
                </div>

                <div class="catch-message" id="catch-message">
                    <h2>Nice Catch!</h2>
                    <p>You caught a <span id="fish-type">Small Fish</span></p>
                    <p>+<span id="points">10</span> points</p>
                    <p>+<span id="coins-earned">5</span> coins</p>
                    <button id="continue-btn">Continue Fishing</button>
                </div>

                <div class="shop-panel" id="shop-panel">
                    <button class="close-btn" id="close-shop-btn">×</button>
                    <h2>Fishing Shop</h2>
                    <div class="shop-item">
                        <div class="shop-item-info">
                            <div class="shop-item-name">Better Rod</div>
                            <div class="shop-item-desc">Longer rod for deeper fishing</div>
                        </div>
                        <div class="shop-item-price">100 coins</div>
                        <button class="shop-buy-btn" data-item="rod" data-price="100">Buy</button>
                    </div>
                    <div class="shop-item">
                        <div class="shop-item-info">
                            <div class="shop-item-name">Corn Bait (5)</div>
                            <div class="shop-item-desc">Attracts medium fish</div>
                        </div>
                        <div class="shop-item-price">20 coins</div>
                        <button class="shop-buy-btn" data-item="corn" data-price="20">Buy</button>
                    </div>
                    <div class="shop-item">
                        <div class="shop-item-info">
                            <div class="shop-item-name">Lure Bait (3)</div>
                            <div class="shop-item-desc">Attracts rare fish</div>
                        </div>
                        <div class="shop-item-price">50 coins</div>
                        <button class="shop-buy-btn" data-item="lure" data-price="50">Buy</button>
                    </div>
                </div>

                <div class="collection-panel" id="collection-panel">
                    <button class="close-btn" id="close-collection-btn">×</button>
                    <h2>Fish Collection</h2>
                    <div class="fish-collection" id="fish-collection-container">
                        <!-- Fish collection items will be added here -->
                    </div>
                </div>

                <div class="splash" id="splash"></div>
                <div class="fish-indicator" id="fish-indicator"></div>
                <div class="game-message" id="game-message"></div>
            </div>
        </div>
        <div class="rating-section">
            <h3 class="rating-title">Rate This Game</h3>
            <p class="rating-text">Average Rating: @Model.AverageRating.ToString("F1")</p>
            @if (Model.UserId.HasValue)
            {
                <p class="rating-text">Your Rating: @(Model.ExistingRating > 0 ? Model.ExistingRating.ToString() : "Not rated yet")</p>
                <form id="ratingForm" method="post" asp-action="RateGame" class="flex items-center space-x-2">
                    <input type="hidden" name="gameName" value="@Model.GameName" />
                    <div class="star-rating">
                        @for (int i = 1; i <= 5; i++)
                        {
                            <span class="star" data-value="@i" style="font-size: 1.5rem; cursor: pointer;">★</span>
                        }
                        <input type="hidden" name="rating" id="ratingInput" />
                    </div>
                    <button type="submit" class="submit-btn">Submit Rating</button>
                </form>
            }
            else
            {
                <p class="rating-text">Please <a asp-action="Login" class="text-success">login</a> to rate this game.</p>
            }
        </div>
    </div>
    <script>
        $(document).ready(function () {
            $('#ratingForm').submit(function (e) {
                e.preventDefault();
                $.ajax({
                    url: '@Url.Action("RateGame", "Home")',
                    type: 'POST',
                    data: $(this).serialize(),
                    headers: {
                        'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function (response) {
                        if (response.success) {
                            alert(response.message);
                            location.reload();
                        } else {
                            alert('Error: ' + response.message);
                        }
                    },
                    error: function () {
                        alert('An error occurred while submitting the rating.');
                    }
                });
            });

            $('.star').on('click', function () {
                const rating = $(this).data('value');
                $('#ratingInput').val(rating);
                $('.star').each(function () {
                    $(this).css('color', $(this).data('value') <= rating ? 'var(--warning)' : 'var(--light)');
                });
            });

            $('.star').hover(
                function () {
                    const rating = $(this).data('value');
                    $('.star').each(function () {
                        $(this).css('color', $(this).data('value') <= rating ? 'var(--warning)' : 'var(--light)');
                    });
                },
                function () {
                    const currentRating = $('#ratingInput').val() || 0;
                    $('.star').each(function () {
                        $(this).css('color', $(this).data('value') <= currentRating ? 'var(--warning)' : 'var(--light)');
                    });
                }
            );
        });

        document.addEventListener('DOMContentLoaded', function() {
            // Game elements
            const gameContainer = document.querySelector('.game-container');
            const fishingLine = document.getElementById('fishing-line');
            const fishingRod = document.getElementById('fishing-rod');
            const castBtn = document.getElementById('cast-btn');
            const reelBtn = document.getElementById('reel-btn');
            const scoreElement = document.getElementById('score');
            const coinsElement = document.getElementById('coins');
            const fishCountElement = document.getElementById('fish-count');
            const splashElement = document.getElementById('splash');
            const catchMessage = document.getElementById('catch-message');
            const fishTypeElement = document.getElementById('fish-type');
            const pointsElement = document.getElementById('points');
            const coinsEarnedElement = document.getElementById('coins-earned');
            const continueBtn = document.getElementById('continue-btn');
            const shopBtn = document.getElementById('shop-btn');
            const shopPanel = document.getElementById('shop-panel');
            const closeShopBtn = document.getElementById('close-shop-btn');
            const collectionBtn = document.getElementById('collection-btn');
            const collectionPanel = document.getElementById('collection-panel');
            const closeCollectionBtn = document.getElementById('close-collection-btn');
            const fishCollectionContainer = document.getElementById('fish-collection-container');
            const zoneOptions = document.querySelectorAll('.zone-option');
            const baitOptions = document.querySelectorAll('.bait-option');
            const cornCountElement = document.getElementById('corn-count');
            const lureCountElement = document.getElementById('lure-count');
            const fishIndicator = document.getElementById('fish-indicator');
            const gameMessage = document.getElementById('game-message');

            // Game state
            let score = 0;
            let coins = 50;
            let fishCaught = 0;
            let isLineInWater = false;
            let hookPosition = { x: 0, y: 0 };
            let fishes = [];
            let gameInterval;
            let hookElement = null;
            let baitElement = null;
            let baitAttractionElement = null;
            let waterHeight;
            let waterTop;
            let gameWidth;
            let gameHeight;
            let currentZone = 'shore';
            let currentBait = 'worm';
            let baitInventory = {
                worm: Infinity,
                corn: 0,
                lure: 0
            };
            let upgrades = {
                rod: 1
            };
            let fishCollection = {};
            let canCatchFish = false;
            let fishBitingTimeout = null;

            // Fish types with their properties
            const allFishTypes = [
                // Shore fish
                { id: "small_fish", name: "Small Fish", points: 10, coins: 5, color: "#FF9800", speed: 0.7, size: { width: 40, height: 20 }, probability: 0.5, zone: "shore", bait: ["worm", "corn", "lure"] },
                { id: "bluegill", name: "Bluegill", points: 15, coins: 8, color: "#2196F3", speed: 0.8, size: { width: 45, height: 22 }, probability: 0.3, zone: "shore", bait: ["worm", "corn"] },
                { id: "perch", name: "Perch", points: 20, coins: 10, color: "#FFC107", speed: 0.6, size: { width: 48, height: 24 }, probability: 0.15, zone: "shore", bait: ["worm", "corn"] },

                // Lake fish
                { id: "bass", name: "Bass", points: 25, coins: 12, color: "#4CAF50", speed: 0.5, size: { width: 50, height: 25 }, probability: 0.4, zone: "lake", bait: ["worm", "corn", "lure"] },
                { id: "trout", name: "Trout", points: 35, coins: 18, color: "#E91E63", speed: 0.9, size: { width: 55, height: 22 }, probability: 0.3, zone: "lake", bait: ["corn", "lure"] },
                { id: "pike", name: "Pike", points: 45, coins: 22, color: "#9E9E9E", speed: 0.7, size: { width: 65, height: 20 }, probability: 0.2, zone: "lake", bait: ["lure"] },

                // Deep sea fish
                { id: "tuna", name: "Tuna", points: 50, coins: 25, color: "#3F51B5", speed: 0.8, size: { width: 70, height: 35 }, probability: 0.4, zone: "deep", bait: ["lure"] },
                { id: "swordfish", name: "Swordfish", points: 70, coins: 35, color: "#673AB7", speed: 1, size: { width: 80, height: 25 }, probability: 0.25, zone: "deep", bait: ["lure"] },
                { id: "shark", name: "Shark", points: 100, coins: 50, color: "#607D8B", speed: 0.6, size: { width: 90, height: 40 }, probability: 0.1, zone: "deep", bait: ["lure"] }
            ];

            // Initialize the game
            function initGame() {
                updateGameDimensions();
                createBubbles();
                initFishCollection();
                updateBaitDisplay();
                createClouds();

                window.addEventListener('resize', updateGameDimensions);

                castBtn.addEventListener('click', castLine);
                reelBtn.addEventListener('click', reelIn);
                continueBtn.addEventListener('click', () => {
                    catchMessage.style.display = 'none';
                    castBtn.disabled = false;
                });

                shopBtn.addEventListener('click', () => {
                    shopPanel.style.display = 'block';
                });

                closeShopBtn.addEventListener('click', () => {
                    shopPanel.style.display = 'none';
                });

                collectionBtn.addEventListener('click', () => {
                    updateCollectionDisplay();
                    collectionPanel.style.display = 'block';
                });

                closeCollectionBtn.addEventListener('click', () => {
                    collectionPanel.style.display = 'none';
                });

                // Shop buy buttons
                document.querySelectorAll('.shop-buy-btn').forEach(btn => {
                    btn.addEventListener('click', () => {
                        const item = btn.getAttribute('data-item');
                        const price = parseInt(btn.getAttribute('data-price'));

                        if (coins >= price) {
                            coins -= price;
                            coinsElement.textContent = coins;

                            if (item === 'rod') {
                                upgrades.rod++;
                                fishingRod.style.height = `${10 + (upgrades.rod - 1) * 2}vmin`;
                                showGameMessage('Rod upgraded! You can now fish deeper.');
                            } else if (item === 'corn') {
                                baitInventory.corn += 5;
                                updateBaitDisplay();
                                showGameMessage('Purchased 5 corn bait!');
                            } else if (item === 'lure') {
                                baitInventory.lure += 3;
                                updateBaitDisplay();
                                showGameMessage('Purchased 3 lure bait!');
                            }
                        } else {
                            showGameMessage('Not enough coins!');
                        }
                    });
                });

                // Zone selection
                zoneOptions.forEach(option => {
                    option.addEventListener('click', () => {
                        const zone = option.getAttribute('data-zone');
                        currentZone = zone;

                        // Update active class
                        zoneOptions.forEach(opt => opt.classList.remove('active'));
                        option.classList.add('active');
                    });
                });

                // Bait selection
                baitOptions.forEach(option => {
                    option.addEventListener('click', () => {
                        const bait = option.getAttribute('data-bait');

                        // Check if we have this bait
                        if (bait !== 'worm' && baitInventory[bait] <= 0) {
                            showGameMessage(`You don't have any ${bait} bait left! Buy some in the shop.`);
                            return;
                        }

                        currentBait = bait;

                        // Update selected class
                        baitOptions.forEach(opt => opt.classList.remove('selected'));
                        option.classList.add('selected');
                    });
                });

                // Start spawning fish
                gameInterval = setInterval(gameLoop, 50);

                // Give player some starting bait
                baitInventory.corn = 3;
                baitInventory.lure = 1;
                updateBaitDisplay();

                // Show welcome message
                showGameMessage('Welcome to Fishing Adventure! Cast your line to start fishing.');
            }

            function createClouds() {
                for (let i = 0; i < 5; i++) {
                    const cloud = document.createElement('div');
                    cloud.className = 'cloud';

                    const size = Math.random() * 10 + 5;
                    const left = Math.random() * 100;
                    const top = Math.random() * 20 + 5;
                    const opacity = Math.random() * 0.5 + 0.3;

                    cloud.style.width = `${size}vmin`;
                    cloud.style.height = `${size/2}vmin`;
                    cloud.style.left = `${left}%`;
                    cloud.style.top = `${top}%`;
                    cloud.style.opacity = opacity;

                    // Animation
                    const duration = Math.random() * 30 + 30;
                    cloud.style.animation = `moveCloud ${duration}s linear infinite`;

                    document.querySelector('.sky').appendChild(cloud);
                }
            }

            function showGameMessage(message) {
                gameMessage.textContent = message;
                gameMessage.style.opacity = 1;

                setTimeout(() => {
                    gameMessage.style.opacity = 0;
                }, 3000);
            }

            function updateGameDimensions() {
                gameWidth = Math.min(window.innerWidth, 1000);
                gameHeight = gameWidth * (3/4);
                waterHeight = gameHeight * 0.6;
                waterTop = gameHeight * 0.4;

                // Update game container size
                gameContainer.style.width = `${gameWidth}px`;
                gameContainer.style.height = `${gameHeight}px`;

                // Update hook position if line is in water
                if (isLineInWater && hookElement) {
                    updateHookPosition();
                }
            }

            function createBubbles() {
                for (let i = 0; i < 10; i++) {
                    setTimeout(() => {
                        createBubble();
                    }, Math.random() * 5000);
                }
            }

            function createBubble() {
                const bubble = document.createElement('div');
                bubble.className = 'bubble';

                const size = Math.random() * 1 + 0.5;
                const left = Math.random() * 100;
                const bottom = Math.random() * 30;

                bubble.style.width = `${size}vmin`;
                bubble.style.height = `${size}vmin`;
                bubble.style.left = `${left}%`;
                bubble.style.bottom = `${bottom}%`;

                document.querySelector('.water').appendChild(bubble);

                // Remove bubble after animation completes
                setTimeout(() => {
                    if (bubble.parentNode) {
                        bubble.parentNode.removeChild(bubble);
                    }
                    createBubble();
                }, 4000);
            }

            function initFishCollection() {
                allFishTypes.forEach(fish => {
                    fishCollection[fish.id] = {
                        caught: false,
                        count: 0,
                        fish: fish
                    };
                });
            }

            function updateCollectionDisplay() {
                fishCollectionContainer.innerHTML = '';

                Object.values(fishCollection).forEach(item => {
                    const collectionItem = document.createElement('div');
                    collectionItem.className = `collection-item ${!item.caught ? 'not-caught' : ''}`;

                    const itemImage = document.createElement('div');
                    itemImage.className = 'collection-item-image';

                    if (item.caught) {
                        itemImage.innerHTML = `
                            <svg viewBox="0 0 40 20" xmlns="http://www.w3.org/2000/svg">
                                <path d="M5,10 C5,5 15,0 25,5 L35,10 L25,15 C15,20 5,15 5,10 Z" fill="${item.fish.color}" />
                                <circle cx="30" cy="7" r="2" fill="black" />
                                <path d="M5,10 L0,5 L0,15 Z" fill="${item.fish.color}" />
                            </svg>
                        `;
                    } else {
                        itemImage.innerHTML = '?';
                        itemImage.style.fontSize = '2.4vmin';
                        itemImage.style.color = '#999';
                    }

                    const itemName = document.createElement('div');
                    itemName.className = 'collection-item-name';
                    itemName.textContent = item.caught ? item.fish.name : '???';

                    const itemCount = document.createElement('div');
                    itemCount.className = 'collection-item-count';
                    itemCount.textContent = item.caught ? `Caught: ${item.count}` : 'Not caught yet';

                    collectionItem.appendChild(itemImage);
                    collectionItem.appendChild(itemName);
                    collectionItem.appendChild(itemCount);

                    fishCollectionContainer.appendChild(collectionItem);
                });
            }

            function updateBaitDisplay() {
                cornCountElement.textContent = baitInventory.corn;
                lureCountElement.textContent = baitInventory.lure;
            }

            function castLine() {
                if (isLineInWater) return;

                // Check if we have the selected bait
                if (currentBait !== 'worm' && baitInventory[currentBait] <= 0) {
                    showGameMessage(`You don't have any ${currentBait} bait left! Select another bait or buy some in the shop.`);
                    return;
                }

                // Use up bait
                if (currentBait !== 'worm') {
                    baitInventory[currentBait]--;
                    updateBaitDisplay();
                }

                isLineInWater = true;
                castBtn.disabled = true;
                reelBtn.disabled = false;
                canCatchFish = false;

                // Show fishing line
                fishingLine.style.display = 'block';

                // Calculate line length based on rod upgrade and zone
                let maxDepth;
                switch (currentZone) {
                    case 'shore':
                        maxDepth = 0.3;
                        break;
                    case 'lake':
                        maxDepth = 0.6;
                        break;
                    case 'deep':
                        maxDepth = 1;
                        break;
                    default:
                        maxDepth = 0.5;
                }

                // Adjust depth based on rod level
                maxDepth = Math.min(maxDepth * upgrades.rod, 1);

                const lineHeight = waterHeight * maxDepth;
                fishingLine.style.height = `${lineHeight}px`;

                // Create hook at the end of the line
                hookElement = document.createElement('div');
                hookElement.className = 'hook';
                gameContainer.appendChild(hookElement);

                // Create bait
                baitElement = document.createElement('div');
                baitElement.className = 'bait';

                // Set bait color based on type
                switch (currentBait) {
                    case 'worm':
                        baitElement.style.backgroundColor = '#8B4513';
                        break;
                    case 'corn':
                        baitElement.style.backgroundColor = '#FFD700';
                        break;
                    case 'lure':
                        baitElement.style.backgroundColor = '#FF4500';
                        break;
                }

                gameContainer.appendChild(baitElement);

                // Create bait attraction zone
                baitAttractionElement = document.createElement('div');
                baitAttractionElement.className = 'bait-attraction';

                // Set attraction radius based on bait type
                let attractionRadius;
                switch (currentBait) {
                    case 'worm':
                        attractionRadius = 100;
                        break;
                    case 'corn':
                        attractionRadius = 150;
                        break;
                    case 'lure':
                        attractionRadius = 200;
                        break;
                    default:
                        attractionRadius = 100;
                }

                baitAttractionElement.style.width = `${attractionRadius * 2}px`;
                baitAttractionElement.style.height = `${attractionRadius * 2}px`;
                gameContainer.appendChild(baitAttractionElement);

                // Set hook position
                hookPosition.x = gameWidth / 2;
                hookPosition.y = waterTop + lineHeight;
                updateHookPosition();

                // Create splash effect
                createSplashEffect(gameWidth / 2, waterTop);

                // Allow catching fish after a short delay
                setTimeout(() => {
                    canCatchFish = true;
                    showGameMessage('Your bait is in the water. Wait for fish to bite!');
                }, 1000);
            }

            function updateHookPosition() {
                if (hookElement) {
                    hookElement.style.left = `${hookPosition.x}px`;
                    hookElement.style.top = `${hookPosition.y}px`;
                }

                if (baitElement) {
                    baitElement.style.left = `${hookPosition.x}px`;
                    baitElement.style.top = `${hookPosition.y + 10}px`;
                }

                if (baitAttractionElement) {
                    baitAttractionElement.style.left = `${hookPosition.x - parseInt(baitAttractionElement.style.width) / 2}px`;
                    baitAttractionElement.style.top = `${hookPosition.y - parseInt(baitAttractionElement.style.height) / 2}px`;
                }
            }

            function reelIn() {
                if (!isLineInWater) return;

                // Clear any pending fish biting timeout
                if (fishBitingTimeout) {
                    clearTimeout(fishBitingTimeout);
                    fishBitingTimeout = null;
                }

                // Hide fish indicator
                fishIndicator.style.display = 'none';

                // Check if a fish is caught
                const caughtFish = checkForCatch();

                if (caughtFish) {
                    // Show caught fish animation
                    showCaughtFish(caughtFish);

                    // Update score and coins
                    score += caughtFish.points;
                    coins += caughtFish.coins;
                    fishCaught++;

                    scoreElement.textContent = score;
                    coinsElement.textContent = coins;
                    fishCountElement.textContent = fishCaught;

                    // Update fish collection
                    if (fishCollection[caughtFish.id]) {
                        const collectionItem = fishCollection[caughtFish.id];
                        collectionItem.caught = true;
                        collectionItem.count++;
                    }

                    // Show catch message
                    fishTypeElement.textContent = caughtFish.name;
                    pointsElement.textContent = caughtFish.points;
                    coinsEarnedElement.textContent = caughtFish.coins;
                    catchMessage.style.display = 'block';

                    // Remove the fish from the array
                    const index = fishes.indexOf(caughtFish);
                    if (index > -1) {
                        fishes.splice(index, 1);
                    }

                    // Remove fish element
                    if (caughtFish.element && caughtFish.element.parentNode) {
                        caughtFish.element.parentNode.removeChild(caughtFish.element);
                    }
                } else {
                    // No fish caught, enable cast button again
                    castBtn.disabled = false;
                    showGameMessage('No fish caught. Try again!');
                }

                // Hide fishing line, hook and bait
                fishingLine.style.display = 'none';

                if (hookElement && hookElement.parentNode) {
                    hookElement.parentNode.removeChild(hookElement);
                    hookElement = null;
                }

                if (baitElement && baitElement.parentNode) {
                    baitElement.parentNode.removeChild(baitElement);
                    baitElement = null;
                }

                if (baitAttractionElement && baitAttractionElement.parentNode) {
                    baitAttractionElement.parentNode.removeChild(baitAttractionElement);
                    baitAttractionElement = null;
                }

                isLineInWater = false;
                canCatchFish = false;
                reelBtn.disabled = true;
            }

            function checkForCatch() {
                if (!canCatchFish) return null;

                // Check if any fish is near the hook
                for (const fish of fishes) {
                    // Skip fish that aren't interested
                    if (!fish.interested) continue;

                    // Calculate distance between hook and fish center
                    const fishCenterX = fish.x + fish.size.width / 2;
                    const fishCenterY = fish.y + fish.size.height / 2;

                    const distance = Math.sqrt(
                        Math.pow(hookPosition.x - fishCenterX, 2) +
                        Math.pow(hookPosition.y - fishCenterY, 2)
                    );

                    // If fish is close enough to the hook, it's caught
                    if (distance < fish.size.width / 2 + 25) {
                        return fish;
                    }
                }

                return null;
            }

            function showCaughtFish(fish) {
                const caughtFishElement = document.createElement('div');
                caughtFishElement.className = 'caught-fish';

                // Copy the fish SVG
                caughtFishElement.innerHTML = fish.element.innerHTML;

                // Position at the hook
                caughtFishElement.style.left = `${hookPosition.x - fish.size.width / 2}px`;
                caughtFishElement.style.top = `${hookPosition.y - fish.size.height / 2}px`;

                gameContainer.appendChild(caughtFishElement);

                // Animate fish being reeled in
                setTimeout(() => {
                    caughtFishElement.style.top = `${waterTop - 50}px`;
                    caughtFishElement.style.transform = 'rotate(90deg)';

                    setTimeout(() => {
                        if (caughtFishElement.parentNode) {
                            caughtFishElement.parentNode.removeChild(caughtFishElement);
                        }
                    }, 500);
                }, 100);
            }

            function createSplashEffect(x, y) {
                splashElement.style.left = `${x - 25}px`;
                splashElement.style.top = `${y - 25}px`;
                splashElement.style.display = 'block';

                // Reset animation
                splashElement.style.animation = 'none';
                splashElement.offsetHeight; // Trigger reflow
                splashElement.style.animation = 'splash 0.5s forwards';

                setTimeout(() => {
                    splashElement.style.display = 'none';
                }, 500);

                // Create ripple effect
                const ripple = document.createElement('div');
                ripple.className = 'ripple';
                ripple.style.left = `${x - 50}px`;
                ripple.style.top = `${y - 50}px`;
                gameContainer.appendChild(ripple);

                setTimeout(() => {
                    if (ripple.parentNode) {
                        ripple.parentNode.removeChild(ripple);
                    }
                }, 2000);
            }

            function showFishIndicator() {
                if (!isLineInWater || !canCatchFish) return;

                // Check if any fish is interested in the bait
                let interestedFish = fishes.find(fish => fish.interested);

                if (interestedFish) {
                    // Show indicator near the hook
                    fishIndicator.style.display = 'block';
                    fishIndicator.style.left = `${hookPosition.x - 15}px`;
                    fishIndicator.style.top = `${hookPosition.y - 15}px`;

                    // Show message
                    showGameMessage('A fish is biting! Reel in now!');
                } else {
                    fishIndicator.style.display = 'none';
                }
            }

            function spawnFish() {
                // Limit the number of fish on screen
                if (fishes.length >= 10) return;

                // Filter fish types based on current zone
                const availableFish = allFishTypes.filter(fish => fish.zone === currentZone);

                if (availableFish.length === 0) return;

                // Determine which fish to spawn based on probability
                const rand = Math.random();
                let cumulativeProbability = 0;
                let selectedFishType;

                // Normalize probabilities
                const totalProbability = availableFish.reduce((sum, fish) => sum + fish.probability, 0);

                for (const fishType of availableFish) {
                    cumulativeProbability += fishType.probability / totalProbability;
                    if (rand < cumulativeProbability) {
                        selectedFishType = fishType;
                        break;
                    }
                }

                if (!selectedFishType) {
                    selectedFishType = availableFish[0]; // Default to first available fish
                }

                // Create fish element
                const fishElement = document.createElement('div');
                fishElement.className = 'fish';

                // Random position in water based on zone
                let minDepth, maxDepth;
                switch (currentZone) {
                    case 'shore':
                        minDepth = 0;
                        maxDepth = 0.3;
                        break;
                    case 'lake':
                        minDepth = 0.2;
                        maxDepth = 0.6;
                        break;
                    case 'deep':
                        minDepth = 0.5;
                        maxDepth = 1;
                        break;
                    default:
                        minDepth = 0;
                        maxDepth = 0.5;
                }

                const fishY = waterTop + (waterHeight * minDepth) + Math.random() * (waterHeight * (maxDepth - minDepth));

                // Determine direction (left to right or right to left)
                const direction = Math.random() > 0.5 ? 1 : -1;
                const fishX = direction > 0 ? -selectedFishType.size.width : gameWidth;

                fishElement.style.top = `${fishY}px`;
                fishElement.style.left = `${fishX}px`;
                fishElement.style.width = `${selectedFishType.size.width}px`;
                fishElement.style.height = `${selectedFishType.size.height}px`;

                // Create fish SVG
                const fishColor = selectedFishType.color;
                fishElement.innerHTML = `
                    <svg viewBox="0 0 40 20" xmlns="http://www.w3.org/2000/svg">
                        <path d="${direction > 0 ?
                            'M5,10 C5,5 15,0 25,5 L35,10 L25,15 C15,20 5,15 5,10 Z' :
                            'M35,10 C35,5 25,0 15,5 L5,10 L15,15 C25,20 35,15 35,10 Z'}"
                            fill="${fishColor}" />
                        <circle cx="${direction > 0 ? '30' : '10'}" cy="7" r="2" fill="black" />
                        <path d="${direction > 0 ?
                            'M5,10 L0,5 L0,15 Z' :
                            'M35,10 L40,5 L40,15 Z'}"
                            fill="${fishColor}" />
                    </svg>
                `;

                gameContainer.appendChild(fishElement);

                // Create fish object
                const fish = {
                    id: selectedFishType.id,
                    element: fishElement,
                    x: fishX,
                    y: fishY,
                    direction: direction,
                    speed: selectedFishType.speed,
                    size: selectedFishType.size,
                    name: selectedFishType.name,
                    points: selectedFishType.points,
                    coins: selectedFishType.coins,
                    bait: selectedFishType.bait,
                    interested: false,
                    targetX: null,
                    targetY: null
                };

                fishes.push(fish);
            }

            function updateFishes() {
                const fishesToRemove = [];
                let anyFishInterested = false;

                for (const fish of fishes) {
                    // Check if fish is interested in the bait
                    if (isLineInWater && canCatchFish && fish.bait.includes(currentBait)) {
                        // Calculate distance between hook and fish
                        const fishCenterX = fish.x + fish.size.width / 2;
                        const fishCenterY = fish.y + fish.size.height / 2;

                        const distance = Math.sqrt(
                            Math.pow(hookPosition.x - fishCenterX, 2) +
                            Math.pow(hookPosition.y - fishCenterY, 2)
                        );

                        // Get attraction radius based on bait type
                        let attractionRadius;
                        switch (currentBait) {
                            case 'worm':
                                attractionRadius = 100;
                                break;
                            case 'corn':
                                attractionRadius = 150;
                                break;
                            case 'lure':
                                attractionRadius = 200;
                                break;
                            default:
                                attractionRadius = 100;
                        }

                        // If fish is within attraction radius, it becomes interested
                        if (distance < attractionRadius) {
                            fish.interested = true;
                            fish.targetX = hookPosition.x - fish.size.width / 2;
                            fish.targetY = hookPosition.y - fish.size.height / 2;
                            fish.element.classList.add('interested');
                            anyFishInterested = true;
                        } else {
                            fish.interested = false;
                            fish.targetX = null;
                            fish.targetY = null;
                            fish.element.classList.remove('interested');
                        }
                    } else {
                        fish.interested = false;
                        fish.targetX = null;
                        fish.targetY = null;
                        fish.element.classList.remove('interested');
                    }

                    // Move fish
                    if (fish.interested && fish.targetX !== null && fish.targetY !== null) {
                        // Move towards the hook
                        const fishCenterX = fish.x + fish.size.width / 2;
                        const fishCenterY = fish.y + fish.size.height / 2;

                        const targetCenterX = fish.targetX + fish.size.width / 2;
                        const targetCenterY = fish.targetY + fish.size.height / 2;

                        const dx = targetCenterX - fishCenterX;
                        const dy = targetCenterY - fishCenterY;
                        const distance = Math.sqrt(dx * dx + dy * dy);

                        if (distance > 5) {
                            fish.x += (dx / distance) * fish.speed * 1.5;
                            fish.y += (dy / distance) * fish.speed * 1.5;

                            // Update fish direction based on movement
                            if (dx > 0) {
                                fish.direction = 1;
                                fish.element.innerHTML = `
                                    <svg viewBox="0 0 40 20" xmlns="http://www.w3.org/2000/svg">
                                        <path d="M5,10 C5,5 15,0 25,5 L35,10 L25,15 C15,20 5,15 5,10 Z" fill="${fish.element.querySelector('path').getAttribute('fill')}" />
                                        <circle cx="30" cy="7" r="2" fill="black" />
                                        <path d="M5,10 L0,5 L0,15 Z" fill="${fish.element.querySelector('path').getAttribute('fill')}" />
                                    </svg>
                                `;
                            } else {
                                fish.direction = -1;
                                fish.element.innerHTML = `
                                    <svg viewBox="0 0 40 20" xmlns="http://www.w3.org/2000/svg">
                                        <path d="M35,10 C35,5 25,0 15,5 L5,10 L15,15 C25,20 35,15 35,10 Z" fill="${fish.element.querySelector('path').getAttribute('fill')}" />
                                        <circle cx="10" cy="7" r="2" fill="black" />
                                        <path d="M35,10 L40,5 L40,15 Z" fill="${fish.element.querySelector('path').getAttribute('fill')}" />
                                    </svg>
                                `;
                            }
                        }
                    } else {
                        // Normal movement
                        fish.x += fish.direction * fish.speed;
                    }

                    // Update fish position
                    fish.element.style.left = `${fish.x}px`;
                    fish.element.style.top = `${fish.y}px`;

                    // Remove fish if it's out of bounds
                    if ((fish.direction > 0 && fish.x > gameWidth) ||
                        (fish.direction < 0 && fish.x < -fish.size.width)) {
                        fishesToRemove.push(fish);
                    }
                }

                // Show fish indicator if any fish is interested
                if (anyFishInterested) {
                    if (!fishBitingTimeout) {
                        fishBitingTimeout = setTimeout(() => {
                            showFishIndicator();
                        }, 1000);
                    }
                } else {
                    if (fishBitingTimeout) {
                        clearTimeout(fishBitingTimeout);
                        fishBitingTimeout = null;
                    }
                    fishIndicator.style.display = 'none';
                }

                // Remove fishes that are out of bounds
                for (const fish of fishesToRemove) {
                    const index = fishes.indexOf(fish);
                    if (index > -1) {
                        fishes.splice(index, 1);
                    }

                    if (fish.element && fish.element.parentNode) {
                        fish.element.parentNode.removeChild(fish.element);
                    }
                }
            }

            function gameLoop() {
                // Randomly spawn fish
                if (Math.random() < 0.02) {
                    spawnFish();
                }

                // Update fish positions
                updateFishes();
            }

            // Start the game
            initGame();
        });
    </script>
</body>
</html>
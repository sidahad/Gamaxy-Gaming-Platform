@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <title>Gamaxy Admin</title>
    <meta content="width=device-width, initial-scale=1.0" name="viewport">

    <!-- Favicon -->
    <link href="~/img/favicon.ico" rel="icon">

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;600&family=Roboto:wght@500;700&display=swap" rel="stylesheet">

    <!-- Icons and CSS -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.10.0/css/all.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.4.1/font/bootstrap-icons.css" rel="stylesheet">
    <link href="~/gamer/lib/owlcarousel/assets/owl.carousel.min.css" rel="stylesheet">
    <link href="~/gamer/lib/tempusdominus/css/tempusdominus-bootstrap-4.min.css" rel="stylesheet" />
    <link href="~/gamer/css/bootstrap.min.css" rel="stylesheet">
    <link href="~/gamer/css/style.css" rel="stylesheet">
</head>

<body>
    @{
        var user = HttpContextAccessor.HttpContext?.User;
        var sessionValue = HttpContextAccessor.HttpContext?.Session.GetString("mysession");
    }

    <div class="container-fluid position-relative d-flex p-0">
       
        <!-- Spinner End -->
        <!-- Sidebar Start -->
        <div class="sidebar pe-4 pb-3">
            <nav class="navbar bg-secondary navbar-dark">
                <a asp-action="Index" asp-controller="Admin" class="navbar-brand mx-4 mb-3">
                    <h3 class="text-primary"><i class="fa fa-user-edit me-2"></i>Gamaxy</h3>
                </a>

                @if (ViewBag.Username != null)
                {
                    <div class="d-flex align-items-center ms-4 mb-4">
                        <div class="position-relative">
                            <img class="rounded-circle" src="@ViewBag.UserImage" alt="User Image" style="width: 40px; height: 40px;">
                            <div class="bg-success rounded-circle border border-2 border-white position-absolute end-0 bottom-0 p-1"></div>
                        </div>
                        <div class="ms-3">
                            <h6 class="mb-0">@ViewBag.Username</h6>
                            <span>Admin</span>
                        </div>
                    </div>
                }

                <div class="navbar-nav w-100">
                    <a asp-action="Index" asp-controller="Admin" class="nav-item nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
                        <i class="fa fa-tachometer-alt me-2"></i>Dashboard
                    </a>
                    <a asp-action="AddGame" asp-controller="Admin" class="nav-item nav-link">
                        <i class="fa fa-th me-2"></i>Upload Game
                    </a>
                    <a asp-action="Contactinfo" asp-controller="Admin" class="nav-item nav-link">
                        <i class="fa fa-keyboard me-2"></i>Contact Data
                    </a>
                    <a asp-action="AddCategory" asp-controller="Admin" class="nav-item nav-link">
                        <i class="fa fa-table me-2"></i>Add Category
                    </a>
                    <a asp-action="ViewCategories" asp-controller="Admin" class="nav-item nav-link">
                        <i class="fa fa-table me-2"></i>View Categories
                    </a>
                    <a asp-action="Games" asp-controller="Admin" class="nav-item nav-link">
                        <i class="fa fa-gamepad me-2"></i>Games
                    </a>
                    <a asp-action="UsersList" asp-controller="Admin" class="nav-item nav-link">
                        <i class="fa fa-user me-2"></i>Users
                    </a>
                    <a asp-action="GamerList" asp-controller="Admin" class="nav-item nav-link">
                        <i class="fa fa-gamepad me-2"></i>Gamers
                    </a>
                    <a asp-action="LeaderboardForm" asp-controller="Admin" class="nav-item nav-link">
                        <i class="fa fa-gamepad me-2"></i>LB Add
                    </a>
                    <a asp-action="LeaderboardView" asp-controller="Admin" class="nav-item nav-link">
                        <i class="fa fa-home me-2"></i>LB View
                    </a>
                    <a asp-action="Index" asp-controller="Home" class="nav-item nav-link">
                        <i class="fa fa-home me-2"></i>Website Home
                    </a>
                    <a asp-action="Logout" asp-controller="Admin" class="nav-item nav-link">
                        <i class="fa fa-sign-out-alt me-2"></i>Logout
                    </a>
                </div>
            </nav>
        </div>
        <!-- Sidebar End -->
        <!-- Content Start -->
        <div class="content">
            <!-- Navbar Start -->
            <nav class="navbar navbar-expand bg-secondary navbar-dark sticky-top px-4 py-0">
                <a asp-action="Index" asp-controller="Admin" class="navbar-brand d-flex d-lg-none me-4">
                    <h2 class="text-primary mb-0"><i class="fa fa-user-edit"></i></h2>
                </a>
                <a class="sidebar-toggler flex-shrink-0">
                    <i class="fa fa-bars"></i>
                </a>

                <form class="d-none d-md-flex ms-4">
                    <input class="form-control bg-dark border-0" type="search" placeholder="Search">
                </form>

                <div class="navbar-nav align-items-center ms-auto">
                    <!-- Notifications and Messages -->
                    <!-- (Same as your original dropdown code) -->
                    <!-- User Profile Dropdown -->
                    <div class="nav-item dropdown">
                        @if (ViewBag.Username != null)
                        {
                            <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown">
                                <img class="rounded-circle me-lg-2" src="@ViewBag.UserImage" alt="User Image" style="width: 40px; height: 40px;">
                                <span class="d-none d-lg-inline-flex">@ViewBag.Username</span>
                            </a>
                            <div class="dropdown-menu dropdown-menu-end bg-secondary border-0 rounded-0 rounded-bottom m-0">
                                <a asp-action="Error" asp-controller="Admin" class="dropdown-item">My Profile</a>
                                <a asp-action="Error" asp-controller="Admin" class="dropdown-item">Settings</a>
                                <a asp-action="Logout" asp-controller="Admin" class="dropdown-item">Log Out</a>
                            </div>
                        }
                    </div>
                </div>
            </nav>
            <!-- Navbar End -->
            <!-- Render Main Page Body -->
            @RenderBody()

            <!-- Footer -->
            <div class="container-fluid pt-4 px-4">
                <div class="bg-secondary rounded-top p-4">
                    <div class="row">
                        <div class="col-12 col-sm-6 text-center text-sm-start">
                            &copy; <a>Gamaxy</a>, All Rights Reserved.
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!-- Content End -->
        <!-- Back to Top -->
        <a class="btn btn-lg btn-primary btn-lg-square back-to-top"><i class="bi bi-arrow-up"></i></a>
    </div>

    <!-- Scripts -->
    <script src="https://code.jquery.com/jquery-3.4.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/gamer/lib/chart/chart.min.js"></script>
    <script src="~/gamer/lib/easing/easing.min.js"></script>
    <script src="~/gamer/lib/waypoints/waypoints.min.js"></script>
    <script src="~/gamer/lib/owlcarousel/owl.carousel.min.js"></script>
    <script src="~/gamer/lib/tempusdominus/js/moment.min.js"></script>
    <script src="~/gamer/lib/tempusdominus/js/moment-timezone.min.js"></script>
    <script src="~/gamer/lib/tempusdominus/js/tempusdominus-bootstrap-4.min.js"></script>
    <script src="~/gamer/js/main.js"></script>
</body>
</html>

        <script src="https://cdn.jsdelivr.net/npm/swiper@10/swiper-bundle.min.js"></script>

        <script>
                    $(document).ready(function () {
                $('.add-to-favorite').click(function () {
                    var button = $(this);
                    var gameName = button.data('game-name');
                    var gameAction = button.data('game-action');

                    $.ajax({
                        url: '/Home/AddToFavorites',
                        type: 'POST',
                        data: {
                            gameName: gameName,
                            gameAction: gameAction
                        },
                        success: function (response) {
                            if (response.success) {
                                alert(gameName + ' has been added to your favorites!');
                                button.text('Added').prop('disabled', true).removeClass('btn-primary').addClass('btn-success');
                            } else if (response.message === 'Already favorited') {
                                alert(gameName + ' is already in your favorites.');
                            } else {
                                alert('Error: ' + response.message);
                            }
                        },
                        error: function () {
                            alert('An error occurred while adding to favorites. Please try again.');
                        }
                    });
                });
            });

                    // Swiper Init
            const swiper = new Swiper('.category-slider', {
                slidesPerView: 5,
                spaceBetween: 10,
                grabCursor: true,
                breakpoints: {
                    0: { slidesPerView: 2 },
                    768: { slidesPerView: 4 },
                    992: { slidesPerView: 5 }
                }
            });

                    document.addEventListener("DOMContentLoaded", function () {
                    const categorySlides = document.querySelectorAll(".swiper-slide");
                    const gameCards = document.querySelectorAll("#masonry8 .col-lg-3"); // ✅ updated selector

                    categorySlides.forEach(slide => {
                        slide.addEventListener("click", () => {
                            const filterValue = slide.getAttribute("data-filter");

                            // Update active class
                            categorySlides.forEach(s => s.classList.remove("active"));
                            slide.classList.add("active");

                            // Show/hide cards
                            gameCards.forEach(card => {
                                if (!filterValue || card.classList.contains(filterValue)) {
                                    card.style.display = "block";
                                } else {
                                    card.style.display = "none";
                                }
                            });
                        });
                    });
                });


        </script>

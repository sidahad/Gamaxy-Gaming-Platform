@model GameUploadViewModel
@{
    ViewData["Title"] = "Upload Game";
    Layout = "Admin_layout";
}
<style>
    body {
        background: black;
    }

    .body {
        background-image: linear-gradient(to right, #008dff 0%, #D400FF 50%,#008dff 100%);
    }
</style>

<div class="container-fluid d-flex justify-content-center align-items-center" style=" padding-bottom:100px;  background:black;">
    <div class="cardrr p-4 shadow-lg rounded border-0 body" style="margin-top:80px; max-width: 900px; width: 100%;">
        <!-- Upload Method Selection -->
        <section class="p-4" style=" background:black;">
            <div class="mb-3">
                <h2 class="mb-4" style="color:white;">
                    Choose Upload Method
                </h2><br />
                <div class="form-check form-check-inline">
                    <input class="form-check-input" type="radio" name="uploadType" id="chatbotOption" value="chatbot">
                    <label class="form-check-label" for="chatbotOption" style="color:white;">Use Chatbot Idea</label>
                </div>
                <div class="form-check form-check-inline">
                    <input class="form-check-input" type="radio" name="uploadType" id="manualOption" value="manual" checked>
                    <label class="form-check-label" for="manualOption" style="color:white;">Manual Upload</label>
                </div>
            </div>

            <!-- Chatbot Instructions -->
            <div id="chatbot-instruction" class="alert alert-info d-none">
                <strong>Step 1:</strong> Chat with Gamaxy Bot to get a sample game.<br />
                <strong>Step 2:</strong> Download the .zip or .html file.<br />
                <strong>Step 3:</strong> Upload it below to launch the game!
                <br /><br />
                <a asp-controller="Chatbot" asp-action="Index" class="btn btn-sm btn-primary mt-2">Go to Chatbot</a>
            </div>
        </section>
        <!-- JS: Upload Method Sync -->
        <script>
            document.querySelectorAll('input[name="uploadType"]').forEach(input => {
                input.addEventListener('change', function () {
                    const chatbotSection = document.getElementById('chatbot-instruction');
                    document.getElementById('uploadMethodInput').value = this.value;

                    chatbotSection.classList.toggle('d-none', this.value !== 'chatbot');
                });
            });

            // Initialize hidden field on load
            document.addEventListener("DOMContentLoaded", () => {
                const checked = document.querySelector('input[name="uploadType"]:checked');
                if (checked) {
                    document.getElementById('uploadMethodInput').value = checked.value;
                }
            });
        </script>

        <!-- Game Upload Form -->
        <section class="p-4" style=" background:black;">
            <div class="clearfix"></div>
            <div class="content-wrapper">
                <div class="container-fluid pt-4 px-4">
                    <div class="row g-4">
                        <div class="col-sm-12 col-xl-12 p-4" style="color:white; background:black;">
                            <h2 class="mb-4" style="color:white;">Add Game</h2>

                            <form asp-controller="Admin" asp-action="AddGame" method="post" enctype="multipart/form-data" class="p-4  border rounded">


                                <!-- Hidden field for upload method -->
                                <input type="hidden" asp-for="UploadMethod" id="uploadMethodInput" />

                                <div class="mb-3">
                                    <label asp-for="Title" class="form-label" style="color:white;">Game Title</label>
                                    <input asp-for="Title" class="form-control" required />
                                </div>

                                <div class="mb-3">
                                    <select asp-for="CatId" asp-items="@ViewBag.CategoriesSl"
                                            class="form-control form-controlrr shadow-sm">
                                        <option class="text-white" value="">Category</option>
                                    </select>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="ShortDescription" class="form-label" style="color:white;">Short Description</label>
                                    <input asp-for="ShortDescription" class="form-control" required />
                                </div>

                                <div class="mb-3">
                                    <label asp-for="LongDescription" class="form-label" style="color:white;">Long Description</label>
                                    <textarea asp-for="LongDescription" class="form-control" rows="4" required></textarea>
                                </div>
                                <div class="mb-3">
                                    <label asp-for="HowToPlay" class="form-label" style="color:white;">How to Play Instructions</label>
                                    <textarea asp-for="HowToPlay" class="form-control" rows="4" placeholder="Explain how users should play your game..."></textarea>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="Price" class="form-label" style="color:white;">Price (optional)</label>
                                    <input asp-for="Price" class="form-control" type="number" step="0.01" />
                                </div>

                                <div class="mb-3">
                                    <label asp-for="GameFile" class="form-label" style="color:white;">Upload Game File</label>
                                    <input asp-for="GameFile" type="file" class="form-control" required />
                                </div>

                                <div class="mb-3">
                                    <label asp-for="ThumbnailImage" class="form-label" style="color:white;">Upload Game Thumbnail</label>
                                    <input asp-for="ThumbnailImage" type="file" accept="image/*" class="form-control" required />
                                </div>

                                <button type="submit" class="site-button outline white outline-2 btnhover11">Add Game</button>
                            </form>

                        </div>
                    </div>
                </div>
            </div>
        </section>
    </div>
</div>

<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">

<style>
    .text-gradient {
        background: linear-gradient(90deg, #008dff, #D400FF);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .bg-dark {
        background-color: #008dff !important;
    }

    .bg-info {
        background-color: #D400FF !important;
    }

    .bg-warning {
        background-color: #008dff !important;
    }

    .bg-danger {
        background-color: #D400FF !important;
    }


    h1 {
        margin-bottom: 20px;
        background: linear-gradient(to right, #008dff, #D400FF);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        font-weight: 800;
        letter-spacing: 1px;
    }

</style>
<section class="section-full content-inner py-5 " style="background: black; color: #fff;">
    <div class="container">
        <!-- Header -->
        <div class="section-head text-center mb-5 mt-4">
            <h1 class="title fw-bold" style="font-size: 2.5rem;">Terms & Conditions</h1>
            <div class="dlab-separator bg-primary mx-auto" style="width: 80px; height: 4px;"></div>
            <p class="mt-3 text-muted small">By using Gamaxy, you agree to the following terms and conditions.</p>
        </div>

        <!-- Section 1 -->
        <div class="mb-5">
            <h5 class="text-uppercase" style="color:white;">Account Usage</h5>
            <p>
                Your Gamaxy account is your gateway to the world of online games. You are responsible for maintaining the confidentiality of your login credentials and for all activities under your account.
            </p>
            <div class="dlab-divider divider-2px bg-primary icon-left">
                <i class="fa fa-user-shield bg-primary text-white"></i>
            </div>
        </div>

        <!-- Section 2 -->
        <div class="mb-5">
            <h5 class="text-uppercase" style="color:white;">User-Generated Content</h5>
            <p>
                You may upload games, comments, or media as part of your experience. By doing so, you grant Gamaxy the right to display this content. However, any illegal or offensive material will be removed and may result in account suspension.
            </p>
            <div class="dlab-divider divider-2px icon-right" style="background:#008dff;">
                <i class="fa fa-comment-dots bg-dark text-white" ></i>
            </div>
        </div>

        <!-- Section 3 -->
        <div class="mb-5">
            <h5 class="text-uppercase" style="color:white;">Purchases and Refunds</h5>
            <p>
                All purchases on Gamaxy are final unless otherwise stated. In case of technical issues, please contact our support team. We reserve the right to issue refunds at our discretion.
            </p>
            <div class="dlab-divider divider-2px icon-center" style="background:#D400FF;">
                <i class="fa fa-credit-card bg-danger text-white"></i>
            </div>
        </div>

        <!-- Section 4 -->
        <div class="mb-5">
            <h5 class="text-uppercase" style="color:white;">Code of Conduct</h5>
            <p>
                We expect all Gamaxy users to behave respectfully toward others. Harassment, cheating, or using exploits will result in bans or restrictions. Let's keep Gamaxy fair and fun!
            </p>
            <div class="dlab-divider divider-2px icon-left" style="background:#008dff;">
                <i class="fa fa-gavel bg-warning text-white"></i>
            </div>
        </div>

        <!-- Section 5 -->
        <div class="mb-5">
            <h5 class="text-uppercase" style="color:white;">Changes to Terms</h5>
            <p>
                These terms may be updated periodically. We will notify you of significant changes. Continued use of Gamaxy after updates means you accept the revised terms.
            </p>
            <div class="dlab-divider divider-2px icon-right" style="background:#D400FF;">
                <i class="fa fa-sync bg-info text-white"></i>
            </div>
        </div>

        <!-- CTA -->
        <div class="text-center mt-5">
            <a asp-controller="Home" asp-action="Ppolicy" class="site-button btnhover14 px-4 py-2"
               style="background: linear-gradient(45deg, #008dff, #D400FF); border: none; color: white; border-radius: 30px;">
                Read Our Privacy Policy
            </a>
        </div>
    </div>
</section>

@model GamaxyWebApplication.Models.GameRatingViewModel
@{
    ViewData["Title"] = "Lexicon Master";
    Layout = "_layout3";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>LEXICON MASTER - Professional Animated Hangman</title>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;600;700;900&family=Arial+Rounded+MT+Bold&display=swap" rel="stylesheet">
    <link href="~/css/Hangmen.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
</head>
<body style="background-color:  #0a0a1e;">
    <div class="container py-4">
        <div class="game-page">
            <div class="header-section">
                <h1 class="game-title">LEXICON MASTER</h1>
                <div class="game-subtitle">The Ultimate Animated Hangman Experience</div>
            </div>

            <div class="game-container-wrapper">
                <div class="game-container">
                    <div class="controls-panel">
                        <div class="control-group">
                            <span class="control-label">Theme:</span>
                            <div class="select-wrapper">
                                <select id="themeSelect">
                                    <option value="dark">Dark</option>
                                    <option value="light">Light</option>
                                    <option value="neon">Neon</option>
                                    <option value="retro">Retro</option>
                                </select>
                            </div>
                        </div>
                        <div class="control-group">
                            <span class="control-label">Category:</span>
                            <div class="select-wrapper">
                                <select id="categorySelect">
                                    <option value="Animals">Animals</option>
                                    <option value="Countries">Countries</option>
                                    <option value="Tech">Technology</option>
                                    <option value="Sports">Sports</option>
                                    <option value="Science">Science</option>
                                    <option value="Movies">Movies</option>
                                    <option value="Food">Food & Cuisine</option>
                                </select>
                            </div>
                        </div>
                        <div class="control-group">
                            <span class="control-label">Difficulty:</span>
                            <div class="select-wrapper">
                                <select id="difficultySelect">
                                    <option value="easy">Easy</option>
                                    <option value="medium">Medium</option>
                                    <option value="hard">Hard</option>
                                </select>
                            </div>
                        </div>
                        <button class="btn" id="restartBtn">
                            <svg class="icon button-icon" viewBox="0 0 24 24">
                                <path d="M17.65 6.35C16.2 4.9 14.21 4 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08c-.82 2.33-3.04 4-5.65 4-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z" />
                            </svg>
                            Restart
                        </button>
                    </div>

                    <div class="game-content">
                        <section class="hangman-section">
                            <div class="canvas-container">
                                <div class="difficulty-indicator" id="difficultyIndicator">
                                    <div class="difficulty-dot"></div>
                                    <div class="difficulty-dot"></div>
                                    <div class="difficulty-dot"></div>
                                </div>
                                <canvas id="hangman" width="400" height="500"></canvas>
                                <div class="streak-badge" id="streakBadge">0</div>
                            </div>
                        </section>

                        <section class="game-info-section">
                            <div class="stats-panel">
                                <div class="stat-card">
                                    <div class="stat-label">Score</div>
                                    <div class="stat-value" id="score">0</div>
                                </div>
                                <div class="stat-card">
                                    <div class="stat-label">High Score</div>
                                    <div class="stat-value" id="highScore">0</div>
                                </div>
                                <div class="stat-card">
                                    <div class="stat-label">Streak</div>
                                    <div class="stat-value" id="streak">0</div>
                                </div>
                                <div class="stat-card">
                                    <div class="stat-label">Time</div>
                                    <div class="stat-value" id="timer">60</div>
                                    <div class="timer-container">
                                        <div class="timer-bar" id="timerBar"></div>
                                    </div>
                                </div>
                            </div>

                            <div class="word-display" id="wordDisplay"></div>

                            <div class="info-card">
                                <div class="info-card-header">
                                    <div class="info-card-title">
                                        <svg class="icon" viewBox="0 0 24 24" width="18" height="18">
                                            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z" />
                                        </svg>
                                        Guessed Letters
                                    </div>
                                </div>
                                <div class="guessed-letters" id="guessedLetters"></div>
                            </div>

                            <div class="message-display" id="message"></div>

                            <div class="keyboard" id="keyboard"></div>

                            <div class="hint-section">
                                <button class="btn hint-button" id="hintBtn">
                                    <svg class="icon" viewBox="0 0 24 24" width="18" height="18">
                                        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm-1-4h2v2h-2zm0-10h2v8h-2z" />
                                    </svg>
                                    Get Hint (-50 points)
                                </button>
                                <div class="hint-text" id="hintText"></div>
                            </div>

                            <div class="definition-section" id="definitionSection">
                                <div class="definition-title">
                                    <svg class="icon" viewBox="0 0 24 24" width="18" height="18">
                                        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z" />
                                    </svg>
                                    Word Definition
                                </div>
                                <div class="definition-text" id="definitionText"></div>
                            </div>
                        </section>
                    </div>
                </div>
            </div>

            <div class="controls">
                <p>Click letters or type to guess • Solve the word before time runs out</p>
            </div>

            <div class="rating-section">
                <h2 class="rating-title">@Model.GameName</h2>
                <p class="rating-average">Average Rating: @Model.AverageRating.ToString("F1")</p>
                @if (Model.UserId.HasValue)
                {
                    <p class="rating-user">Your Rating: @(Model.ExistingRating > 0 ? Model.ExistingRating.ToString() : "Not rated yet")</p>
                    <form id="ratingForm" method="post" asp-action="RateGame">
                        <input type="hidden" name="gameName" value="@Model.GameName" />
                        <div class="star-rating">
                            <input type="radio" id="star5" name="rating" value="5" /><label for="star5">★</label>
                            <input type="radio" id="star4" name="rating" value="4" /><label for="star4">★</label>
                            <input type="radio" id="star3" name="rating" value="3" /><label for="star3">★</label>
                            <input type="radio" id="star2" name="rating" value="2" /><label for="star2">★</label>
                            <input type="radio" id="star1" name="rating" value="1" /><label for="star1">★</label>
                        </div>
                        <button type="submit" class="btn btn-rate">Submit Rating</button>
                    </form>
                }
                else
                {
                    <p class="rating-login">Please <a asp-action="Login">login</a> to rate this game.</p>
                }
            </div>

            <div class="modal-overlay" id="gameOverModal">
                <div class="modal">
                    <div class="modal-header">
                        <h2 class="modal-title" id="modalTitle">Game Over</h2>
                    </div>
                    <div class="modal-body">
                        <p class="modal-message" id="modalMessage">Your score: 0</p>
                    </div>
                    <div class="modal-footer">
                        <button class="btn modal-button primary" id="playAgainBtn">Play Again</button>
                        <button class="btn modal-button secondary" id="viewStatsBtn">View Stats</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        $(document).ready(function () {
            $('#ratingForm').submit(function (e) {
                e.preventDefault();
                $.ajax({
                    url: '@Url.Action("RateGame", "Home")',
                    type: 'POST',
                    data: $(this).serialize(),
                    headers: {
                        'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function (response) {
                        if (response.success) {
                            alert(response.message);
                            location.reload();
                        } else {
                            alert('Error: ' + response.message);
                        }
                    },
                    error: function () {
                        alert('An error occurred while submitting the rating.');
                    }
                });
            });
        });

        // DOM Elements
        const canvas = document.getElementById("hangman");
        const ctx = canvas.getContext("2d");
        const wordDisplay = document.getElementById("wordDisplay");
        const guessedLettersEl = document.getElementById("guessedLetters");
        const messageEl = document.getElementById("message");
        const keyboardEl = document.getElementById("keyboard");
        const scoreEl = document.getElementById("score");
        const highScoreEl = document.getElementById("highScore");
        const timerEl = document.getElementById("timer");
        const timerBar = document.getElementById("timerBar");
        const themeSelect = document.getElementById("themeSelect");
        const categorySelect = document.getElementById("categorySelect");
        const difficultySelect = document.getElementById("difficultySelect");
        const restartBtn = document.getElementById("restartBtn");
        const hintBtn = document.getElementById("hintBtn");
        const hintText = document.getElementById("hintText");
        const definitionSection = document.getElementById("definitionSection");
        const definitionText = document.getElementById("definitionText");
        const gameOverModal = document.getElementById("gameOverModal");
        const modalTitle = document.getElementById("modalTitle");
        const modalMessage = document.getElementById("modalMessage");
        const playAgainBtn = document.getElementById("playAgainBtn");
        const viewStatsBtn = document.getElementById("viewStatsBtn");
        const streakEl = document.getElementById("streak");
        const streakBadge = document.getElementById("streakBadge");
        const difficultyIndicator = document.getElementById("difficultyIndicator");

        // Word Bank (unchanged from original)
        const wordBank = {
            Animals: [
                { word: "ELEPHANT", hint: "Largest land mammal with a trunk", definition: "A very large plant-eating mammal with a prehensile trunk, long curved ivory tusks, and large ears, native to Africa and southern Asia." },
                { word: "TIGER", hint: "Large cat with orange fur and black stripes", definition: "A large carnivorous feline mammal with a tawny coat striped with black, native to Asia." },
                { word: "GIRAFFE", hint: "Tallest living animal with a long neck", definition: "A large African mammal with a very long neck and forelegs, having a coat patterned with brown patches separated by lighter lines." },
                { word: "DOLPHIN", hint: "Intelligent marine mammal known for its playfulness", definition: "A small toothed whale that typically has a beaklike snout and a curved dorsal fin. Dolphins are known for their intelligence and playful behavior." },
                { word: "KANGAROO", hint: "Australian marsupial that hops", definition: "A large plant-eating marsupial with a long powerful tail and strongly developed hind limbs that enable it to travel by leaping, native to Australia." },
                { word: "PENGUIN", hint: "Flightless bird that swims and lives in cold regions", definition: "A flightless seabird of the southern hemisphere, with black upper parts and white underparts and wings developed into flippers for swimming underwater." },
                { word: "OCTOPUS", hint: "Sea creature with eight arms", definition: "A cephalopod mollusk with eight sucker-bearing arms, a soft body, strong beaklike jaws, and no internal shell." },
                { word: "CHEETAH", hint: "Fastest land animal", definition: "A large slender spotted cat found in Africa and parts of Asia, the fastest land animal in the world." },
                { word: "RHINOCEROS", hint: "Large mammal with one or two horns on its snout", definition: "A large, heavily built plant-eating mammal with one or two horns on the nose and thick folded skin, native to Africa and southern Asia." }
            ],
            Countries: [
                { word: "PAKISTAN", hint: "South Asian country with Islamabad as capital", definition: "A country in South Asia, bordered by India, Afghanistan, Iran, and China, with Islamabad as its capital city." },
                { word: "BRAZIL", hint: "Largest country in South America", definition: "The largest country in South America and the fifth largest in the world, known for the Amazon rainforest, carnival celebrations, and football." },
                { word: "GERMANY", hint: "European country known for engineering and beer", definition: "A country in central Europe, known for its rich history, engineering achievements, beer culture, and as a leading economy in the European Union." },
                { word: "CANADA", hint: "Second largest country by land area", definition: "A country in North America, the second largest country in the world by total area, known for its vast wilderness, multiculturalism, and ice hockey." },
                { word: "NEPAL", hint: "Himalayan country with Mount Everest", definition: "A landlocked country in South Asia, located in the Himalayas, home to Mount Everest (the world's highest mountain) and known for its ancient culture and religious diversity." },
                { word: "AUSTRALIA", hint: "Country that is also a continent", definition: "A country and continent surrounded by the Indian and Pacific oceans, known for its unique wildlife, natural wonders, and vibrant cities." },
                { word: "MOROCCO", hint: "North African country with Casablanca", definition: "A country in North Africa with coastlines on the Atlantic Ocean and Mediterranean Sea, known for its diverse culture, ancient cities, and distinctive cuisine." },
                { word: "SWITZERLAND", hint: "European country known for mountains and chocolate", definition: "A mountainous Central European country known for its neutrality, banking system, chocolate, cheese, and watches." },
                { word: "SINGAPORE", hint: "Small island city-state in Southeast Asia", definition: "A sovereign island city-state in Southeast Asia, known for its modern architecture, multicultural population, and being a global financial center." }
            ],
            Tech: [
                { word: "PYTHON", hint: "Programming language named after a snake", definition: "A high-level, interpreted programming language known for its readability and versatility, named after the British comedy group Monty Python." },
                { word: "ROBOT", hint: "Mechanical device that can be programmed", definition: "A machine capable of carrying out a complex series of actions automatically, especially one programmable by a computer." },
                { word: "INTERNET", hint: "Global network connecting computers", definition: "A global computer network providing a variety of information and communication facilities, consisting of interconnected networks using standardized communication protocols." },
                { word: "COMPUTER", hint: "Electronic device that processes data", definition: "An electronic device for storing and processing data, typically in binary form, according to instructions given to it in a variable program." },
                { word: "JAVASCRIPT", hint: "Programming language for web development", definition: "A high-level, interpreted programming language that conforms to the ECMAScript specification, commonly used to create interactive effects within web browsers." },
                { word: "BLOCKCHAIN", hint: "Technology behind cryptocurrencies", definition: "A system in which a record of transactions made in bitcoin or another cryptocurrency is maintained across several computers that are linked in a peer-to-peer network." },

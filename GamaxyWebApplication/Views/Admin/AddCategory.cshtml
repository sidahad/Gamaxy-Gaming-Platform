@model Category

@{
    ViewData["Title"] = "Add Category";
    Layout = "Admin_layout";
}

<div class="content-wrapper">
    <div class="container-fluid pt-4 px-4">
        <div class="row g-4">
            <div class="col-sm-12 col-xl-12">
                <div class="rounded h-100 p-4">
                    <h1>Add Category</h1>

                    <form asp-action="AddCategory" asp-controller="Admin" method="post">

                        <div class="mb-3">
                            <label asp-for="CategoryName" class="form-label"></label>
                            <input asp-for="CategoryName" class="form-control" />
                            <span asp-validation-for="CategoryName" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="IconClass" class="form-label">Font Awesome Icon Class</label>
                            <input asp-for="IconClass" class="form-control" placeholder="e.g., fa-solid fa-gamepad" />
                            <span asp-validation-for="IconClass" class="text-danger"></span>
                        </div>

                        <input type="submit" value="Add Category" class="btn btn-dark" />
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>

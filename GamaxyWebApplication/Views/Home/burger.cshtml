                miss: "data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Ccircle cx='50' cy='50' r='40' fill='none' stroke='%23E74C3C' stroke-width='5' stroke-dasharray='10 5'/%3E%3Cpath d='M30,30 L70,70 M30,70 L70,30' stroke='%23E74C3C' stroke-width='8' stroke-linecap='round'/%3E%3C/svg%3E",
                perfect: "data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Ccircle cx='50' cy='50' r='40' fill='none' stroke='%23F1C40F' stroke-width='5' stroke-dasharray='10 5'/%3E%3Cpath d='M25,50 L40,65 L75,30' stroke='%23F1C40F' stroke-width='8' stroke-linecap='round' stroke-linejoin='round' fill='none'/%3E%3C/svg%3E",
                powerup: "data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Ccircle cx='50' cy='50' r='40' fill='none' stroke='%233498DB' stroke-width='5' stroke-dasharray='10 5'/%3E%3Ccircle cx='50' cy='50' r='20' fill='%233498DB' opacity='0.5'/%3E%3Cpath d='M30,50 L70,50 M50,30 L50,70' stroke='%233498DB' stroke-width='8' stroke-linecap='round'/%3E%3C/svg%3E"
            };

            // Level configurations
            const levels = [
                {
                    name: "Classic Burger",
                    order: ["bottomBun", "lettuce", "tomato", "cheese", "patty", "topBun"],
                    fallingSpeed: 2,
                    specialFrequency: 0.05,
                    obstacleFrequency: 0,
                    powerupFrequency: 0.02,
                    timeLimit: 60,
                    tiltMode: false
                },
                {
                    name: "Breakfast Stack",
                    order: ["bottomBun", "lettuce", "tomato", "egg", "bacon", "cheese", "topBun"],
                    fallingSpeed: 2.5,
                    specialFrequency: 0.1,
                    obstacleFrequency: 0.05,
                    powerupFrequency: 0.03,
                    timeLimit: 75,
                    tiltMode: false
                },
                {
                    name: "Monster Tower",
                    order: ["bottomBun", "patty", "cheese", "patty", "lettuce", "tomato", "onion", "pickle", "sauce", "topBun"],
                    fallingSpeed: 3,
                    specialFrequency: 0.15,
                    obstacleFrequency: 0.1,
                    powerupFrequency: 0.04,
                    timeLimit: 90,
                    tiltMode: false
                },
                {
                    name: "Tilt Challenge",
                    order: ["bottomBun", "patty", "cheese", "lettuce", "tomato", "onion", "topBun"],
                    fallingSpeed: 2.5,
                    specialFrequency: 0.1,
                    obstacleFrequency: 0.1,
                    powerupFrequency: 0.05,
                    timeLimit: 75,
                    tiltMode: true
                },
                {
                    name: "Speed Round",
                    order: ["bottomBun", "patty", "cheese", "lettuce", "sauce", "topBun"],
                    fallingSpeed: 4,
                    specialFrequency: 0.2,
                    obstacleFrequency: 0.15,
                    powerupFrequency: 0.06,
                    timeLimit: 45,
                    tiltMode: false
                },
                {
                    name: "Ultimate Burger",
                    order: ["bottomBun", "sauce", "patty", "cheese", "bacon", "egg", "lettuce", "tomato", "onion", "pickle", "sauce", "topBun"],
                    fallingSpeed: 3.5,
                    specialFrequency: 0.15,
                    obstacleFrequency: 0.12,
                    powerupFrequency: 0.08,
                    timeLimit: 120,
                    tiltMode: true
                }
            ];

            // Initialize game
            function init() {
                gameWidth = gameContainer.clientWidth;
                gameHeight = gameContainer.clientHeight;
                platePosition.x = gameWidth / 2;
                updatePlatePosition();
                loadGameData();
                updateLevelButtons();
                window.addEventListener('resize', handleResize);
                document.addEventListener('keydown', handleKeyDown);
                gameContainer.addEventListener('touchstart', handleTouchStart);
                gameContainer.addEventListener('touchmove', handleTouchMove);
                restartBtn.addEventListener('click', restartGame);
                restartBtnPause.addEventListener('click', restartGame);
                startBtn.addEventListener('click', startGame);
                nextLevelBtn.addEventListener('click', nextLevel);
                menuBtn.addEventListener('click', showMenu);
                menuBtnGameover.addEventListener('click', showMenu);
                menuBtnPause.addEventListener('click', showMenu);
                pauseBtn.addEventListener('click', togglePause);
                resumeBtn.addEventListener('click', resumeGame);
                tutorialNext.addEventListener('click', nextTutorialStep);
                levelBtns.forEach(btn => {
                    btn.addEventListener('click', function() {
                        const level = parseInt(this.dataset.level);
                        if (level <= unlockedLevels) {
                            currentLevel = level;
                            startGame();
                        }
                    });
                });
                requestAnimationFrame(gameLoop);
            }

            // Game loop
            function gameLoop(timestamp) {
                if (!lastFrameTime) {
                    lastFrameTime = timestamp;
                    lastFpsUpdate = timestamp;
                }
                const deltaTime = timestamp - lastFrameTime;
                lastFrameTime = timestamp;
                frameCount++;
                if (timestamp - lastFpsUpdate > 1000) {
                    fps = Math.round(frameCount * 1000 / (timestamp - lastFpsUpdate));
                    fpsCounter.textContent = `FPS: ${fps}`;
                    frameCount = 0;
                    lastFpsUpdate = timestamp;
                }
                if (gameActive && !gamePaused) {
                    if (fallingIngredient) {
                        updateFallingIngredient(deltaTime);
                    }
                    activePowerups.forEach(powerup => {
                        if (powerupTypes[powerup.type].effect) {
                            powerupTypes[powerup.type].effect();
                        }
                    });
                    if (tiltMode) {
                        updateTilt(deltaTime);
                    }
                }
                requestAnimationFrame(gameLoop);
            }

            // Start game
            function startGame() {
                startScreen.style.display = 'none';
                gameOver.style.display = 'none';
                levelComplete.style.display = 'none';
                pauseScreen.style.display = 'none';
                gameActive = true;
                gamePaused = false;
                score = 0;
                lives = 3;
                combo = 1;
                maxCombo = 1;
                perfectStackCount = 0;
                stack = [];
                activePowerups = [];
                const level = levels[currentLevel - 1];
                levelContainer.textContent = `Level: ${currentLevel} - ${level.name}`;
                timeRemaining = level.timeLimit;
                tiltMode = level.tiltMode;
                tiltValue = 0;
                stackTilt = 0;
                tiltIndicator.style.display = tiltMode ? 'block' : 'none';
                generateOrder(level.order);
                updateScore();
                updateCombo();
                updateLives();
                updateTimeDisplay();
                const ingredients = document.querySelectorAll('.ingredient, .falling-ingredient, .powerup, .splash');
                ingredients.forEach(ingredient => ingredient.remove());
                powerupIndicator.innerHTML = '';
                if (timeInterval) clearInterval(timeInterval);
                timeInterval = setInterval(updateTime, 1000);
                if (showTutorial && currentLevel === 1) {
                    tutorialStep = 0;
                    tutorialOverlay.style.display = 'flex';
                } else {
                    dropIngredient();
                }
                if (powerupInterval) clearInterval(powerupInterval);
                powerupInterval = setInterval(() => {
                    if (gameActive && !gamePaused && Math.random() < level.powerupFrequency) {
                        spawnPowerup();
                    }
                }, 10000);
            }

            // Generate order
            function generateOrder(orderItems) {
                currentOrder = [...orderItems];
                const orderContainer = document.getElementById('order-items');
                orderContainer.innerHTML = '';
                currentOrder.forEach(item => {
                    const orderItem = document.createElement('div');
                    orderItem.className = 'order-item';
                    const img = document.createElement('img');
                    img.src = ingredientTypes[item].image;
                    orderItem.appendChild(img);
                    orderContainer.appendChild(orderItem);
                });
            }

            // Restart game
            function restartGame() {
                gameOver.style.display = 'none';
                pauseScreen.style.display = 'none';
                const ingredients = document.querySelectorAll('.ingredient, .falling-ingredient, .powerup, .splash');
                ingredients.forEach(ingredient => ingredient.remove());
                startGame();
            }

            // Next level
            function nextLevel() {
                if (currentLevel < levels.length) {
                    currentLevel++;
                    startGame();
                } else {
                    showMenu();
                }
            }

            // Show menu
            function showMenu() {
                gameActive = false;
                gamePaused = false;
                if (timeInterval) clearInterval(timeInterval);
                if (powerupInterval) clearInterval(powerupInterval);
                gameOver.style.display = 'none';
                levelComplete.style.display = 'none';
                pauseScreen.style.display = 'none';
                startScreen.style.display = 'flex';
                updateLevelButtons();
            }

            // Update level buttons
            function updateLevelButtons() {
                levelBtns.forEach(btn => {
                    const level = parseInt(btn.dataset.level);
                    if (level <= unlockedLevels) {
                        btn.classList.remove('locked');
                    } else {
                        btn.classList.add('locked');
                    }
                });
            }

            // Toggle pause
            function togglePause() {
                if (!gameActive) return;
                if (gamePaused) {
                    resumeGame();
                } else {
                    pauseGame();
                }
            }

            // Pause game
            function pauseGame() {
                gamePaused = true;
                pauseScreen.style.display = 'flex';
            }

            // Resume game
            function resumeGame() {
                gamePaused = false;
                pauseScreen.style.display = 'none';
            }

            // Handle window resize
            function handleResize() {
                gameWidth = gameContainer.clientWidth;
                gameHeight = gameContainer.clientHeight;
                if (platePosition.x > gameWidth) {
                    platePosition.x = gameWidth / 2;
                }
                updatePlatePosition();
            }

            // Handle keyboard input
            function handleKeyDown(e) {
                if (!gameActive || gamePaused) return;
                if (e.key === 'ArrowLeft') {
                    movePlate(-20);
                } else if (e.key === 'ArrowRight') {
                    movePlate(20);
                } else if (e.key === 'p' || e.key === 'P') {
                    togglePause();
                }
            }

            // Handle touch input
            function handleTouchStart(e) {
                if (!gameActive || gamePaused) return;
                touchStartX = e.touches[0].clientX;
            }

            function handleTouchMove(e) {
                if (!gameActive || gamePaused) return;
                e.preventDefault();
                const touchX = e.touches[0].clientX;
                const diff = touchX - touchStartX;
                if (Math.abs(diff) > 5) {
                    movePlate(diff);
                    touchStartX = touchX;
                }
            }

            // Move the plate
            function movePlate(dx) {
                platePosition.x += dx;
                const halfPlateWidth = plateWidth / 2;
                if (platePosition.x < halfPlateWidth) {
                    platePosition.x = halfPlateWidth;
                } else if (platePosition.x > gameWidth - halfPlateWidth) {
                    platePosition.x = gameWidth - halfPlateWidth;
                }
                updatePlatePosition();
            }

            // Update plate position
            function updatePlatePosition() {
                plate.style.left = platePosition.x + 'px';
                stack.forEach((item, index) => {
                    item.x = platePosition.x;
                    if (tiltMode && index > 0) {
                        const tiltOffset = stackTilt * (index + 1) * 2;
                        item.element.style.left = (item.x + tiltOffset) + 'px';
                        const rotation = stackTilt * 10;
                        item.element.style.transform = `translateX(-50%) rotate(${rotation}deg)`;
                    } else {
                        item.element.style.left = item.x + 'px';
                        item.element.style.transform = 'translateX(-50%)';
                    }
                });
            }

            // Update tilt
            function updateTilt(deltaTime) {
                if (stack.length <= 1) return;
                const tiltFactor = 0.0001 * deltaTime;
                const randomTilt = (Math.random() - 0.5) * 0.0002 * deltaTime;
                stackTilt += randomTilt;
                const plateMovementCorrection = (0 - stackTilt) * 0.01 * deltaTime;
                stackTilt += plateMovementCorrection;
                const maxTilt = 0.5;
                if (stackTilt > maxTilt) stackTilt = maxTilt;
                if (stackTilt < -maxTilt) stackTilt = -maxTilt;
                tiltMarker.style.left = `${(stackTilt + 0.5) * 100}%`;
                if (Math.abs(stackTilt) > 0.4 && stack.length > 3) {
                    if (Math.random() < 0.01 * deltaTime * (Math.abs(stackTilt) - 0.4) * 10) {
                        collapseStack();
                    }
                }
                updatePlatePosition();
            }

            // Collapse stack
            function collapseStack() {
                if (!gameActive) return;
                stack.forEach(item => {
                    item.element.classList.add('fall');
                });
                createSplashEffect(platePosition.x, gameHeight - 150, 'miss');
                lives--;
                updateLives();
                combo = 1;
                updateCombo();
                if (lives <= 0) {
                    endGame();
                } else {
                    setTimeout(() => {
                        if (!gameActive) return;
                        stack.forEach(item => item.element.remove());
                        stack = [];
                        stackTilt = 0;
                        setTimeout(() => {
                            if (gameActive && !fallingIngredient) dropIngredient();
                        }, 500);
                    }, 1000);
                }
            }

            // Drop a new ingredient
            function dropIngredient() {
                if (!gameActive || gamePaused) return;
                let type;
                if (stack.length < currentOrder.length) {
                    const nextOrderItem = currentOrder[stack.length];
                    if (Math.random() < 0.3 && nextOrderItem !== 'bottomBun') {
                        const ingredientKeys = Object.keys(ingredientTypes).filter(key =>
                            !ingredientTypes[key].special &&
                            !ingredientTypes[key].obstacle &&
                            key !== 'topBun' &&
                            key !== 'bottomBun'
                        );
                        const randomIndex = Math.floor(Math.random() * ingredientKeys.length);
                        type = ingredientKeys[randomIndex];
                    } else {
                        type = nextOrderItem;
                    }
                    const level = levels[currentLevel - 1];
                    if (Math.random() < level.specialFrequency && type !== 'bottomBun' && type !== 'topBun') {
                        type = 'goldenPatty';
                    }
                } else {
                    type = 'topBun';
                }
                const ingredientType = ingredientTypes[type];
                const element = document.createElement('div');
                element.className = 'falling-ingredient';
                const img = document.createElement('img');
                img.src = ingredientType.image;
                img.style.width = '100%';
                img.style.height = '100%';
                element.appendChild(img);
                const x = Math.random() * (gameWidth - ingredientWidth) + ingredientWidth / 2;
                const y = -50;
                element.style.left = x + 'px';
                element.style.top = y + 'px';
                gameArea.appendChild(element);
                fallingIngredient = {
                    type: type,
                    element: element,
                    x: x,
                    y: y,
                    width: ingredientWidth,
                    height: 40,
                    speed: levels[currentLevel - 1].fallingSpeed * (1 + Math.random() * 0.5)
                };
            }

            // Update falling ingredient position
            function updateFallingIngredient(deltaTime) {
                if (!gameActive || gamePaused || !fallingIngredient) return;
                const speedFactor = deltaTime / 16.67;
                fallingIngredient.y += fallingIngredient.speed * speedFactor;
                fallingIngredient.element.style.top = fallingIngredient.y + 'px';
                const plateTop = gameHeight - 100;
                const stackHeight = getStackHeight();
                const catchY = plateTop - stackHeight;
                if (fallingIngredient.y >= catchY - 10) {
                    const plateLeft = platePosition.x - plateWidth / 2;
                    const plateRight = platePosition.x + plateWidth / 2;
                    if (fallingIngredient.x >= plateLeft && fallingIngredient.x <= plateRight) {
                        catchIngredient();
                    } else if (fallingIngredient.y > gameHeight) {
                        missIngredient();
                    }
                }
            }

            // Calculate current stack height
            function getStackHeight() {
                let height = 0;
                stack.forEach(item => {
                    height += ingredientTypes[item.type].height;
                });
                return height;
            }

            // Handle caught ingredient
            function catchIngredient() {
                if (!fallingIngredient) return;
                fallingIngredient.element.remove();
                const element = document.createElement('div');
                element.className = 'ingredient';
                const img = document.createElement('img');
                img.src = ingredientTypes[fallingIngredient.type].image;
                img.style.width = '100%';
                img.style.height = '100%';
                element.appendChild(img);
                const stackHeight = getStackHeight();
                const y = gameHeight - 100 - stackHeight;
                element.style.left = platePosition.x + 'px';
                element.style.top = y + 'px';
                gameArea.appendChild(element);
                stack.push({
                    type: fallingIngredient.type,
                    element: element,
                    x: platePosition.x,
                    y: y
                });
                element.classList.add('wobble');
                createSplashEffect(platePosition.x, y + 20, 'sauce');
                let points = 10;
                if (ingredientTypes[fallingIngredient.type].special) {
                    points = ingredientTypes[fallingIngredient.type].points || 100;
                    showFloatingText(platePosition.x, y, `+${points}!`);
                }
                points *= combo;
                if (hasPowerup('doublePoints')) {
                    points *= 2;
                }
                score += points;
                updateScore();
                combo++;
                maxCombo = Math.max(maxCombo, combo);
                updateCombo();
                checkPerfectStack();
                if (fallingIngredient.type === 'topBun') {
                    const burgerBonus = stack.length * 20;
                    score += burgerBonus;
                    updateScore();
                    showFloatingText(platePosition.x, y - 30, `Burger Complete! +${burgerBonus}`);
                    setTimeout(() => {
                        if (!gameActive) return;
                        stack.forEach(item => item.element.remove());
                        stack = [];
                        stackTilt = 0;
                    }, 1000);
                }
                fallingIngredient = null;
                setTimeout(() => {
                    if (gameActive && !gamePaused) dropIngredient();
                }, 800);
            }

            // Check for perfect stack
            function checkPerfectStack() {
                if (stack.length >= 3) {
                    const lastThree = stack.slice(-3);
                    if (
                        (lastThree[0].type === 'patty' &&
                         lastThree[1].type === 'cheese' &&
                         lastThree[2].type === 'topBun') ||
                        (lastThree[0].type === 'lettuce' &&
                         lastThree[1].type === 'tomato' &&
                         lastThree[2].type === 'topBun') ||
                        (lastThree[0].type === 'bacon' &&
                         lastThree[1].type === 'egg' &&
                         lastThree[2].type === 'topBun')
                    ) {
                        const perfectBonus = 50 * combo;
                        score += perfectBonus;
                        updateScore();
                        perfectStack.style.opacity = '1';
                        setTimeout(() => {
                            perfectStack.style.opacity = '0';
                        }, 1500);
                        const lastItem = stack[stack.length - 1];
                        createSplashEffect(lastItem.x, lastItem.y, 'perfect');
                        showFloatingText(lastItem.x, lastItem.y - 30, `Perfect Stack! +${perfectBonus}`);
                        perfectStackCount++;
                        if (perfectStackCount >= 5 && !achievements.fivePerfectStacks) {
                            achievements.fivePerfectStacks = true;
                            showAchievement('Stack Master', '🏆');
                            saveGameData();
                        }
                    }
                    let followingOrder = true;
                    for (let i = 0; i < stack.length; i++) {
                        if (i >= currentOrder.length || stack[i].type !== currentOrder[i]) {
                            followingOrder = false;
                            break;
                        }
                    }
                    if (followingOrder && stack.length >= 4) {
                        const orderBonus = 30 * stack.length;
                        score += orderBonus;
                        updateScore();
                        const lastItem = stack[stack.length - 1];
                        showFloatingText(lastItem.x, lastItem.y - 50, `Following Order! +${orderBonus}`);
                    }
                }
            }

            // Handle missed ingredient
            function missIngredient() {
                if (!fallingIngredient) return;
                createSplashEffect(fallingIngredient.x, gameHeight - 50, 'miss');
                fallingIngredient.element.remove();
                fallingIngredient = null;
                combo = 1;
                updateCombo();
                if (!hasPowerup('shield')) {
                    lives--;
                    updateLives();
                    gameContainer.classList.add('shake');
                    setTimeout(() => {
                        gameContainer.classList.remove('shake');
                    }, 500);
                    if (lives <= 0) {
                        endGame();
                        return;
                    }
                } else {
                    showFloatingText(fallingIngredient.x, gameHeight - 150, "Shield Protected!");
                }
                setTimeout(() => {
                    if (gameActive && !gamePaused) dropIngredient();
                }, 1000);
            }

            // Create splash effect
            function createSplashEffect(x, y, type) {
                const splash = document.createElement('div');
                splash.className = 'splash';
                splash.style.left = (x - 50) + 'px';
                splash.style.top = (y - 50) + 'px';
                const img = document.createElement('img');
                img.src = splashEffects[type];
                img.style.width = '100%';
                img.style.height = '100%';
                splash.appendChild(img);
                gameArea.appendChild(splash);
                setTimeout(() => {
                    splash.remove();
                }, 500);
            }

            // Show floating text
            function showFloatingText(x, y, text) {
                const floatingText = document.createElement('div');
                floatingText.className = 'floating-text';
                floatingText.textContent = text;
                floatingText.style.left = x + 'px';
                floatingText.style.top = y + 'px';
                floatingText.style.fontSize = '24px';
                gameArea.appendChild(floatingText);
                setTimeout(() => {
                    floatingText.remove();
                }, 1000);
            }

            // Spawn powerup
            function spawnPowerup() {
                if (!gameActive || gamePaused) return;
                const powerupKeys = Object.keys(powerupTypes);
                const randomIndex = Math.floor(Math.random() * powerupKeys.length);
                const type = powerupKeys[randomIndex];
                const element = document.createElement('div');
                element.className = 'powerup';
                const img = document.createElement('img');
                img.src = powerupTypes[type].image;
                img.className = 'powerup-icon';
                element.appendChild(img);
                const x = Math.random() * (gameWidth - 40) + 20;
                const y = Math.random() * (gameHeight - 300) + 100;
                element.style.left = x + 'px';
                element.style.top = y + 'px';
                gameArea.appendChild(element);
                element.addEventListener('click', () => collectPowerup(type, element));
                element.addEventListener('touchstart', (e) => {
                    e.preventDefault();
                    collectPowerup(type, element);
                });
                setTimeout(() => {
                    if (element.parentNode) {
                        element.remove();
                    }
                }, 5000);
            }

            // Collect powerup
            function collectPowerup(type, element) {
                if (!gameActive || gamePaused) return;
                element.remove();
                const rect = element.getBoundingClientRect();
                const x = rect.left + rect.width / 2;
                const y = rect.top + rect.height / 2;
                createSplashEffect(x, y, 'powerup');
                showFloatingText(x, y - 30, powerupTypes[type].name + ' Activated!');
                if (powerupTypes[type].duration === 0) {
                    if (powerupTypes[type].effect) {
                        powerupTypes[type].effect();
                    }
                    return;
                }
                activePowerups.push({
                    type: type,
                    timeRemaining: powerupTypes[type].duration
                });
                updatePowerupIndicator();
                const powerupTimer = setInterval(() => {
                    if (gamePaused) return;
                    const index = activePowerups.findIndex(p => p.type === type);
                    if (index === -1) {
                        clearInterval(powerupTimer);
                        return;
                    }
                    activePowerups[index].timeRemaining--;
                    updatePowerupIndicator();
                    if (activePowerups[index].timeRemaining <= 0) {
                        activePowerups.splice(index, 1);
                        updatePowerupIndicator();
                        clearInterval(powerupTimer);
                    }
                }, 1000);
            }

            // Update powerup indicator
            function updatePowerupIndicator() {
                powerupIndicator.innerHTML = '';
                activePowerups.forEach(powerup => {
                    const container = document.createElement('div');
                    container.className = 'active-powerup';
                    const img = document.createElement('img');
                    img.src = powerupTypes[powerup.type].image;
                    container.appendChild(img);
                    const timer = document.createElement('div');
                    timer.className = 'powerup-timer';
                    container.appendChild(timer);
                    powerupIndicator.appendChild(container);
                    const duration = powerupTypes[powerup.type].duration;
                    const progress = powerup.timeRemaining / duration;
                    const degrees = 360 * (1 - progress);
                    if (degrees <= 180) {
                        timer.classList.remove('active');
                        timer.style.transform = `rotate(${degrees}deg)`;
                    } else {
                        timer.classList.add('active');
                        timer.style.transform = `rotate(${degrees - 180}deg)`;
                    }
                });
            }

            // Check if a powerup is active
            function hasPowerup(type) {
                return activePowerups.some(p => p.type === type);
            }

            // Update score display
            function updateScore() {
                scoreValue.textContent = score;
            }

            // Update combo display
            function updateCombo() {
                comboText.textContent = `x${combo}`;
                comboFill.style.width = `${Math.min(100, (combo - 1) * 10)}%`;
            }

            // Update lives display
            function updateLives() {
                livesContainer.innerHTML = '';
                for (let i = 0; i < lives; i++) {
                    const lifeIcon = document.createElement('div');
                    lifeIcon.className = 'life-icon';
                    livesContainer.appendChild(lifeIcon);
                }
            }

            // Update time
            function updateTime() {
                if (!gameActive || gamePaused) return;
                timeRemaining--;
                updateTimeDisplay();
                if (timeRemaining <= 0) {
                    completeLevel();
                }
            }

            // Update time display
            function updateTimeDisplay() {
                timeValue.textContent = timeRemaining;
                if (timeRemaining <= 10) {
                    timeContainer.style.color = '#FF5722';
                } else {
                    timeContainer.style.color = 'white';
                }
            }

            // Complete level
            function completeLevel() {
                gameActive = false;
                if (timeInterval) clearInterval(timeInterval);
                if (powerupInterval) clearInterval(powerupInterval);
                let stars = 1;
                if (score >= levels[currentLevel - 1].scoreThreshold2) {
                    stars = 3;
                } else if (score >= levels[currentLevel - 1].scoreThreshold1) {
                    stars = 2;
                }
                levelScore.textContent = score;
                levelPerfectStacks.textContent = perfectStackCount;
                levelStars.textContent = '★'.repeat(stars) + '☆'.repeat(3 - stars);
                if (currentLevel === unlockedLevels && currentLevel < levels.length) {
                    unlockedLevels++;
                    saveGameData();
                }
                levelComplete.style.display = 'flex';
                nextLevelBtn.style.display = currentLevel < levels.length ? 'block' : 'none';
            }

            // End game
            function endGame() {
                gameActive = false;
                if (timeInterval) clearInterval(timeInterval);
                if (powerupInterval) clearInterval(powerupInterval);
                finalScore.textContent = score;
                perfectStacks.textContent = perfectStackCount;
                gameOver.style.display = 'flex';
                if (score > (achievements.highScore || 0)) {
                    achievements.highScore = score;
                    saveGameData();
                }
            }

            // Show achievement
            function showAchievement(text, icon) {
                const achievementIcon = achievement.querySelector('.achievement-icon');
                const achievementText = achievement.querySelector('.achievement-text');
                achievementIcon.textContent = icon;
                achievementText.textContent = text;
                achievement.style.opacity = '1';
                setTimeout(() => {
                    achievement.style.opacity = '0';
                }, 3000);
            }

            // Tutorial steps
            function nextTutorialStep() {
                tutorialStep++;
                if (tutorialStep === 1) {
                    const tutorialMessage = tutorialOverlay.querySelector('.tutorial-message');
                    tutorialMessage.textContent = 'Follow the order shown at the top to build the perfect burger!';
                } else {
                    tutorialOverlay.style.display = 'none';
                    dropIngredient();
                }
            }

            // Save game data
            function saveGameData() {
                const gameData = {
                    unlockedLevels: unlockedLevels,
                    achievements: achievements,
                    showTutorial: showTutorial
                };
                try {
                    localStorage.setItem('burgerStackData', JSON.stringify(gameData));
                } catch (e) {
                    console.log('Could not save game data');
                }
            }

            // Load game data
            function loadGameData() {
                try {
                    const gameData = localStorage.getItem('burgerStackData');
                    if (gameData) {
                        const data = JSON.parse(gameData);
                        unlockedLevels = data.unlockedLevels || 1;
                        achievements = data.achievements || {};
                        showTutorial = data.showTutorial !== undefined ? data.showTutorial : true;
                    }
                } catch (e) {
                    console.log('Could not load game data');
                }
            }

            // Initialize the game
            init();
        });
    </script>

@{
    ViewData["Title"] = "Privacy Policy";
}
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">

<style>
    .text-gradient {
        background: linear-gradient(90deg, #008dff, #D400FF);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

</style>


<section class="section-full content-inner-1 frame-sr-list-area py-5" style="background: black; color: #ffffff;">
    <div class="container">
        <!-- Header -->
        <div class="section-head text-center mb-5 mt-4 pt-4">
            <h2 class="title fw-bold text-gradient" style="font-size: 2.5rem;">
                Privacy Policy
            </h2>
            <div class="dlab-separator bg-primary mx-auto" style="width: 80px; height: 4px;"></div>
            <p class="mt-3 text-muted small">
                Learn how Gamaxy protects your data and ensures your privacy while you enjoy gaming.
            </p>
        </div>


        <!-- Content Grid -->
        <div class="row align-items-start">
            <!-- Left Column -->
            <div class="col-lg-6 mb-4 wow fadeInUp" data-wow-duration="2s" data-wow-delay="0.3s">
                <ul class="list-unstyled px-3">
                    <li class="mb-3"><i class="fa fa-shield-alt me-2 text-primary"></i>  We collect basic information like email and username to personalize your experience.</li>
                    <li class="mb-3"><i class="fa fa-lock me-2 text-primary"></i>  Your data is encrypted and securely stored. We never sell or share it with third parties.</li>
                    <li class="mb-3"><i class="fa fa-user-secret me-2 text-primary"></i>  Only you have control over what you share on your Gamaxy profile.</li>
                    <li class="mb-3"><i class="fa fa-globe me-2 text-primary"></i>  Cookies are used only to enhance performance and save your preferences.</li>
                    <li class="mb-3"><i class="fa fa-gamepad me-2 text-primary"></i> Gameplay data is stored to help track your achievements and progress.</li>
                </ul>
            </div>

            <!-- Right Column -->
            <div class="col-lg-6 mb-4 wow fadeInUp" data-wow-duration="2s" data-wow-delay="0.6s">
                <ul class="list-unstyled px-3">
                    <li class="mb-3"><i class="fa fa-bell me-2 text-primary"></i>  We only send you notifications you subscribe to <br />
                        — no spam.</li>
                    <li class="mb-3"><i class="fa fa-cogs me-2 text-primary"></i> You can modify your privacy settings anytime from <br /> your account.</li>
                    <li class="mb-3"><i class="fa fa-database me-2 text-primary"></i>  We retain data only as long as necessary for  <br />game-related services.</li>
                    <li class="mb-3"><i class="fa fa-flag me-2 text-primary"></i>  You can request data deletion or export at any time.</li>
                    <li class="mb-3"><i class="fa fa-code me-2 text-primary"></i>  Gamaxy follows strict security practices including regular <br /> audits.</li>
                </ul>
            </div>
        </div>

        <!-- Call to Action -->
        <div class="text-center mt-5">
            <a href="/Home/Contact" class="site-button btnhover14 px-4 py-2"
               style="background: linear-gradient(45deg, #008dff, #D400FF); border: none; color: white; border-radius: 30px;">
                Contact Us for More Info
            </a>
        </div>
    </div>
</section>


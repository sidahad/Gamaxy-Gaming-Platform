@model GamaxyWebApplication.Models.PaymentViewModel
@{
    ViewData["Title"] = "Process Payment";
}

<style>
    body {
        background: black;
    }

    .payment-card {
        background-image: linear-gradient(to right, #008dff 0%, #D400FF 50%, #008dff 100%);
        color: white;
        max-width: 600px;
        margin: 100px auto;
        padding: 20px;
        border-radius: 10px;
        box-shadow: 0 0 10px rgba(0,0,0,0.5);
    }
</style>

<div class="container-fluid">
    <div class="payment-card">
        <h2>Payment for @Model.GameTitle</h2>
        <p>Amount: $@Model.Amount</p>

        <form asp-action="ProcessPayment" asp-controller="Payment" method="post">
            <input type="hidden" asp-for="GameId" />
            <input type="hidden" asp-for="GameTitle" />
            <input type="hidden" asp-for="Amount" />
            <input type="hidden" asp-for="UserId" />
            <input type="hidden" asp-for="Role" />

            <div class="mb-3">
                <label asp-for="CardNumber" class="form-label">Card Number</label>
                <input asp-for="CardNumber" class="form-control" placeholder="1234 5678 9012 3456" />
                <span asp-validation-for="CardNumber" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ExpiryDate" class="form-label">Expiry Date (MM/YY)</label>
                <input asp-for="ExpiryDate" class="form-control" placeholder="MM/YY" />
                <span asp-validation-for="ExpiryDate" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="CVV" class="form-label">CVV</label>
                <input asp-for="CVV" class="form-control" placeholder="123" />
                <span asp-validation-for="CVV" class="text-danger"></span>
            </div>

            <button type="submit" class="site-button outline white outline-2 btnhover11">Pay Now</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
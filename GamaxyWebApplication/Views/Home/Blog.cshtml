@{
    Layout = "_Layout";
}
<style>
    @@import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Exo+2:wght@300;400;500;600;700;800;900&family=Rajdhani:wght@300;400;500;600;700&display=swap');

    /** {
        scroll-behavior: smooth;
    }*/

    body {
        overflow-x: hidden;
    }

    .gv-ultimate-bg-x9z {
        background: radial-gradient(ellipse at top left, #1a0033 0%, #000000 40%), radial-gradient(ellipse at top right, #001133 0%, #000000 40%), radial-gradient(ellipse at bottom, D400FF 0%, #000000 50%), linear-gradient(135deg, #000000 0%, #1a0033 25%, #001133 50%, #2d1b69 75%, #000000 100%);
        background-attachment: fixed;
        background-size: 100% 100%, 100% 100%, 100% 100%, 100% 100%;
    }

    .gv-ultimate-gradient-k7m {
        background: linear-gradient(135deg, #008dff 0%, #008dff 25%, #D400FF 50%, #D400FF 75%, #008dff 100%);
        background-size: 400% 400%;
        animation: gv-ultimate-flow-a3n 8s ease infinite;
    }

    @@keyframes gv-ultimate-flow-a3n {
        0%, 100%

    {
        background-position: 0% 50%;
    }

    25% {
        background-position: 100% 50%;
    }

    50% {
        background-position: 100% 100%;
    }

    75% {
        background-position: 0% 100%;
    }

    }

    .gv-ultimate-glow-p8q {
        box-shadow: 0 0 30px rgba(139, 92, 246, 0.8), 0 0 60px rgba(59, 130, 246, 0.6), 0 0 90px #D400FF, 0 0 120px rgba(139, 92, 246, 0.2), inset 0 0 30px rgba(99, 102, 241, 0.1);
    }

    .gv-ultimate-card-w5r {
        background: linear-gradient(145deg, rgba(30, 30, 30, 0.95), rgba(0, 0, 0, 0.98)), radial-gradient(circle at top right, rgba(139, 92, 246, 0.15), transparent 70%), radial-gradient(circle at bottom left, rgba(59, 130, 246, 0.12), transparent 70%), radial-gradient(circle at center, #D400FF, transparent 80%);
        border: 3px solid transparent;
        background-clip: padding-box;
        position: relative;
        transform-style: preserve-3d;
        transition: all 0.8s cubic-bezier(0.23, 1, 0.320, 1);
        backdrop-filter: blur(20px);
        box-shadow: 0 15px 50px rgba(0, 0, 0, 0.9), inset 0 1px 0 rgba(255, 255, 255, 0.1), inset 0 -1px 0 rgba(139, 92, 246, 0.2);
    }

        .gv-ultimate-card-w5r::before {
            content: '';
            position: absolute;
            inset: 0;
            padding: 3px;
            background: linear-gradient(45deg, #D400FF, #008dff, #008dff, #D400FF, #D400FF);
            background-size: 400% 400%;
            border-radius: inherit;
            mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
            mask-composite: exclude;
            animation: gv-ultimate-flow-a3n 6s ease infinite;
            z-index: -1;
        }

        .gv-ultimate-card-w5r:hover {
            transform: translateY(-20px) scale(1.08) rotateX(10deg) rotateY(5deg);
            box-shadow: 0 35px 70px rgba(0, 0, 0, 0.9), 0 0 60px rgba(139, 92, 246, 0.6), 0 0 120px rgba(59, 130, 246, 0.4), 0 0 180px #D400FF;
        }

    .gv-ultimate-text-l2s {
        background: linear-gradient(45deg, #D400FF, #008dff, #008dff, #D400FF, #D400FF);
        background-size: 400% 400%;
        animation: gv-ultimate-flame-t6u 4s ease infinite;
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        text-shadow: 0 0 40px rgba(139, 92, 246, 0.8);
    }

    @@keyframes gv-ultimate-flame-t6u {
        0%, 100%

    {
        background-position: 0% 50%;
    }

    50% {
        background-position: 100% 50%;
    }

    }

    .gv-ultimate-bg-h4v {
        background: radial-gradient(circle at 20% 80%, rgba(139, 92, 246, 0.2) 0%, transparent 50%), radial-gradient(circle at 80% 20%, rgba(59, 130, 246, 0.15) 0%, transparent 50%), radial-gradient(circle at 40% 40%, rgba(255, 107, 53, 0.12) 0%, transparent 50%), radial-gradient(circle at 60% 10%, rgba(99, 102, 241, 0.18) 0%, transparent 50%);
        animation: gv-ultimate-drift-j9x 20s ease infinite;
    }

    @@keyframes gv-ultimate-drift-j9x {
        0%, 100%

    {
        transform: rotate(0deg) scale(1);
    }

    33% {
        transform: rotate(120deg) scale(1.2);
    }

    66% {
        transform: rotate(240deg) scale(0.8);
    }

    }

    .gv-ultimate-float-n1c {
        animation: gv-ultimate-float-b8d 6s ease-in-out infinite;
    }

    @@keyframes gv-ultimate-float-b8d {
        0%, 100%

    {
        transform: translateY(0px) translateX(0px) rotate(0deg);
    }

    25% {
        transform: translateY(-40px) translateX(20px) rotate(5deg);
    }

    50% {
        transform: translateY(-20px) translateX(-20px) rotate(-5deg);
    }

    75% {
        transform: translateY(-60px) translateX(10px) rotate(3deg);
    }

    }

    .gv-ultimate-effect-m7y {
        background: linear-gradient(45deg, #D400FF, #008dff, #008dff, #D400FF);
        background-size: 400% 400%;
        animation: gv-ultimate-dance-q5z 3s ease infinite;
        border-radius: 50%;
    }

    @@keyframes gv-ultimate-dance-q5z {
        0%, 100%

    {
        background-position: 0% 50%;
    }

    50% {
        background-position: 100% 50%;
    }

    }

    .gv-ultimate-glitch-r3f {
        animation: gv-ultimate-glitch-e4g 4s infinite;
        position: relative;
    }

        .gv-ultimate-glitch-r3f::before,
        .gv-ultimate-glitch-r3f::after {
            content: attr(data-text);
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
        }

        .gv-ultimate-glitch-r3f::before {
            animation: gv-glitch-purple-i8h 3s infinite;
            color: #D400FF;
            z-index: -1;
        }

        .gv-ultimate-glitch-r3f::after {
            animation: gv-glitch-blue-o6j 3s infinite;
            color: #008dff;
            z-index: -2;
        }

    @@keyframes gv-glitch-purple-i8h {
        0%, 100%

    {
        transform: translate(0);
    }

    20% {
        transform: translate(-3px, 3px);
    }

    40% {
        transform: translate(-3px, -3px);
    }

    60% {
        transform: translate(3px, 3px);
    }

    80% {
        transform: translate(3px, -3px);
    }

    }

    @@keyframes gv-glitch-blue-o6j {
        0%, 100%

    {
        transform: translate(0);
    }

    20% {
        transform: translate(3px, -3px);
    }

    40% {
        transform: translate(3px, 3px);
    }

    60% {
        transform: translate(-3px, -3px);
    }

    80% {
        transform: translate(-3px, 3px);
    }

    }

    .gv-ultimate-pulse-s2k {
        animation: gv-ultimate-pulse-d9l 3s ease-in-out infinite;
    }

    @@keyframes gv-ultimate-pulse-d9l {
        0%, 100%

    {
        box-shadow: 0 0 30px rgba(139, 92, 246, 0.6);
        transform: scale(1);
    }

    50% {
        box-shadow: 0 0 80px rgba(59, 130, 246, 1);
        transform: scale(1.05);
    }

    }

    .gv-ultimate-particles-u7p {
        position: absolute;
        width: 100%;
        height: 100%;
        overflow: hidden;
        pointer-events: none;
    }

    .gv-ultimate-particle-v4w {
        position: absolute;
        width: 8px;
        height: 8px;
        background: radial-gradient(circle, #D400FF 0%, #008dff 30%, #008dff 60%, #D400FF 80%, transparent 100%);
        border-radius: 50%;
        box-shadow: 0 0 15px rgba(139, 92, 246, 0.9), 0 0 30px rgba(59, 130, 246, 0.7), 0 0 45px rgba(181, 53, 255, 0.5);
        animation: gv-ultimate-rise-x1a 18s linear infinite;
    }

        .gv-ultimate-particle-v4w::after {
            content: '';
            position: absolute;
            width: 100%;
            height: 100%;
            background: inherit;
            border-radius: 50%;
            animation: gv-ultimate-particle-pulse-z2w 2.5s ease-in-out infinite;
        }

    @@keyframes gv-ultimate-particle-pulse-z2w {
        0%, 100%

    {
        transform: scale(1);
        opacity: 1;
    }

    50% {
        transform: scale(2);
        opacity: 0.3;
    }

    }

    @@keyframes gv-ultimate-rise-x1a {
        0%

    {
        transform: translateY(100vh) translateX(0) scale(0);
        opacity: 0;
    }

    10% {
        opacity: 1;
        transform: scale(1);
    }

    90% {
        opacity: 1;
    }

    100% {
        transform: translateY(-100px) translateX(200px) scale(0);
        opacity: 0;
    }

    }

    .gv-ultimate-matrix-z8b {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: 1;
        opacity: 0.15;
    }

    .gv-ultimate-matrix-column-c5n {
        position: absolute;
        top: -100%;
        color: #D400FF;
        font-family: 'Orbitron', monospace;
        font-size: 16px;
        line-height: 16px;
        animation: gv-ultimate-matrix-fall-f2m 15s linear infinite;
        text-shadow: 0 0 8px #D400FF;
    }

    @@keyframes gv-ultimate-matrix-fall-f2m {
        0%

    {
        top: -100%;
        opacity: 1;
        color: #D400FF;
    }

    25% {
        color: #008dff;
    }

    50% {
        color: #008dff;
    }

    75% {
        color: #D400FF;
    }

    100% {
        top: 100%;
        opacity: 0;
        color: #D400FF;
    }

    }

    .gv-ultimate-holographic-g9t {
        background: linear-gradient(45deg, transparent 30%, rgba(139, 92, 246, 0.15) 50%, transparent 70%);
        background-size: 200% 200%;
        animation: gv-ultimate-holographic-scan-y3r 4s ease-in-out infinite;
        position: relative;
    }

        .gv-ultimate-holographic-g9t::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(59, 130, 246, 0.3), transparent);
            animation: gv-ultimate-holographic-sweep-k6e 3s ease-in-out infinite;
        }

    @@keyframes gv-ultimate-holographic-scan-y3r {
        0%, 100%

    {
        background-position: 0% 50%;
    }

    50% {
        background-position: 100% 50%;
    }

    }

    @@keyframes gv-ultimate-holographic-sweep-k6e {
        0%

    {
        left: -100%;
    }

    100% {
        left: 100%;
    }

    }

    .gv-ultimate-neon-glow-i4q {
        text-shadow: 0 0 8px currentColor, 0 0 16px currentColor, 0 0 24px currentColor, 0 0 32px #D400FF, 0 0 48px #008dff, 0 0 64px #008dff;
        animation: gv-ultimate-neon-flicker-l7s 3s ease-in-out infinite alternate;
    }

    @@keyframes gv-ultimate-neon-flicker-l7s {
        0%, 18%, 22%, 25%, 53%, 57%, 100%

    {
        text-shadow: 0 0 8px currentColor, 0 0 16px currentColor, 0 0 24px currentColor, 0 0 32px #D400FF, 0 0 48px #008dff, 0 0 64px #008dff;
    }

    20%, 24%, 55% {
        text-shadow: none;
    }

    }

    .gv-ultimate-lightning-bg-p1u {
        background: linear-gradient(45deg, rgba(139, 92, 246, 0.15) 0%, transparent 25%, rgba(59, 130, 246, 0.12) 50%, transparent 75%, #D400FF 100%), radial-gradient(ellipse at top, rgba(99, 102, 241, 0.2) 0%, transparent 60%), radial-gradient(ellipse at bottom, rgba(139, 92, 246, 0.18) 0%, transparent 60%);
        background-size: 200% 200%, 150% 150%, 150% 150%;
        animation: gv-ultimate-lightning-flash-h8v 8s ease-in-out infinite;
    }

    @@keyframes gv-ultimate-lightning-flash-h8v {
        0%, 90%, 100%

    {
        opacity: 1;
    }

    95% {
        opacity: 0.2;
    }

    }

    .gv-ultimate-cyber-grid-a9w {
        background-image: radial-gradient(3px 3px at 25px 35px, #D400FF, transparent), radial-gradient(3px 3px at 50px 80px, rgba(59, 130, 246, 0.9), transparent), radial-gradient(2px 2px at 100px 50px, #D400FF, transparent), radial-gradient(2px 2px at 150px 90px, rgba(99, 102, 241, 0.7), transparent), radial-gradient(3px 3px at 180px 40px, rgba(139, 92, 246, 0.9), transparent), linear-gradient(rgba(139, 92, 246, 0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(59, 130, 246, 0.05) 1px, transparent 1px);
        background-repeat: repeat;
        background-size: 250px 120px, 250px 120px, 250px 120px, 250px 120px, 250px 120px, 60px 60px, 60px 60px;
        animation: gv-ultimate-cyber-grid-move-n2x 40s linear infinite;
    }

    @@keyframes gv-ultimate-cyber-grid-move-n2x {
        0%

    {
        background-position: 0 0;
    }

    100% {
        background-position: 60px 60px;
    }

    }

    .gv-ultimate-energy-orb-t5y {
        position: absolute;
        width: 150px;
        height: 150px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(139, 92, 246, 0.9) 0%, rgba(59, 130, 246, 0.7) 20%, #D400FF 40%, rgba(99, 102, 241, 0.3) 60%, rgba(107, 114, 128, 0.2) 80%, transparent 100%);
        box-shadow: 0 0 40px rgba(139, 92, 246, 0.8), 0 0 80px rgba(59, 130, 246, 0.6), 0 0 120px #D400FF;
        animation: gv-ultimate-energy-pulse-r8z 5s ease-in-out infinite;
    }

    @@keyframes gv-ultimate-energy-pulse-r8z {
        0%, 100%

    {
        transform: scale(1) rotate(0deg);
        opacity: 0.8;
    }

    50% {
        transform: scale(1.8) rotate(180deg);
        opacity: 1;
    }

    }

    .gv-ultimate-quantum-shift-b3c {
        animation: gv-ultimate-quantum-shift-m6d 7s ease-in-out infinite;
    }

    @@keyframes gv-ultimate-quantum-shift-m6d {
        0%, 100%

    {
        transform: perspective(1000px) rotateX(0deg) rotateY(0deg);
        filter: hue-rotate(0deg);
    }

    25% {
        transform: perspective(1000px) rotateX(5deg) rotateY(5deg);
        filter: hue-rotate(90deg);
    }

    50% {
        transform: perspective(1000px) rotateX(0deg) rotateY(10deg);
        filter: hue-rotate(180deg);
    }

    75% {
        transform: perspective(1000px) rotateX(-5deg) rotateY(5deg);
        filter: hue-rotate(270deg);
    }

    }

    .gv-ultimate-plasma-bg-j4e {
        background: radial-gradient(ellipse at 20% 80%, rgba(139, 92, 246, 0.4) 0%, rgba(59, 130, 246, 0.15) 30%, transparent 70%), radial-gradient(ellipse at 80% 20%, rgba(181, 53, 255, 0.5);
        0%, rgba(99, 102, 241, 0.12) 40%, transparent 70%), radial-gradient(ellipse at 40% 40%, rgba(59, 130, 246, 0.25) 0%, rgba(139, 92, 246, 0.1) 35%, transparent 65%), radial-gradient(ellipse at 60% 60%, rgba(107, 114, 128, 0.2) 0%, #D400FF 45%, transparent 75%);
        background-size: 350% 350%, 450% 450%, 400% 400%, 320% 320%;
        animation: gv-ultimate-plasma-flow-q7f 25s ease infinite;
    }

    @@keyframes gv-ultimate-plasma-flow-q7f {
        0%, 100%

    {
        background-position: 0% 50%, 0% 50%, 0% 50%, 0% 50%;
    }

    25% {
        background-position: 100% 50%, 0% 100%, 100% 0%, 50% 100%;
    }

    50% {
        background-position: 100% 100%, 100% 0%, 0% 100%, 100% 50%;
    }

    75% {
        background-position: 0% 100%, 100% 100%, 50% 50%, 0% 0%;
    }

    }

    .gv-ultimate-warp-lines-s8g {
        position: absolute;
        width: 100%;
        height: 100%;
        overflow: hidden;
        pointer-events: none;
    }

    .gv-ultimate-warp-line-u1h {
        position: absolute;
        height: 3px;
        background: linear-gradient(90deg, transparent 0%, rgba(139, 92, 246, 0.9) 50%, transparent 100%);
        animation: gv-ultimate-warp-speed-v9i 4s linear infinite;
    }

    @@keyframes gv-ultimate-warp-speed-v9i {
        0%

    {
        left: -100%;
        width: 0%;
    }

    50% {
        width: 100%;
    }

    100% {
        left: 100%;
        width: 0%;
    }

    }

    .gv-ultimate-border-x2j {
        position: relative;
        border: 3px solid transparent;
        background: linear-gradient(45deg, rgba(30, 30, 30, 0.95), rgba(0, 0, 0, 0.98));
    }

        .gv-ultimate-border-x2j::before {
            content: '';
            position: absolute;
            inset: -3px;
            background: linear-gradient(45deg, #D400FF, transparent, #008dff, transparent, #008dff);
            background-size: 400% 400%;
            border-radius: inherit;
            animation: gv-ultimate-scan-y5k 4s linear infinite;
            z-index: -1;
        }

    @@keyframes gv-ultimate-scan-y5k {
        0%, 100%

    {
        background-position: 0% 50%;
    }

    50% {
        background-position: 100% 50%;
    }

    }

    .gv-ultimate-network-z6l {
        background-image: radial-gradient(circle at 25% 25%, rgba(139, 92, 246, 0.08) 0%, transparent 50%), radial-gradient(circle at 75% 75%, rgba(59, 130, 246, 0.06) 0%, transparent 50%), linear-gradient(45deg, transparent 40%, #D400FF 50%, transparent 60%);
        background-size: 140px 140px, 200px 200px, 280px 280px;
        animation: gv-ultimate-pulse-a8m 10s ease infinite;
    }

    @@keyframes gv-ultimate-pulse-a8m {
        0%, 100%

    {
        background-position: 0% 0%, 0% 0%, 0% 0%;
    }

    50% {
        background-position: 100% 100%, -100% -100%, 50% 50%;
    }

    }

    .gv-ultimate-dimension-c3n {
        transform-style: preserve-3d;
        animation: gv-ultimate-dimension-d7o 8s ease-in-out infinite;
    }

    @@keyframes gv-ultimate-dimension-d7o {
        0%, 100%

    {
        transform: perspective(1200px) rotateX(0deg) rotateY(0deg);
    }

    25% {
        transform: perspective(1200px) rotateX(4deg) rotateY(4deg);
    }

    50% {
        transform: perspective(1200px) rotateX(0deg) rotateY(8deg);
    }

    75% {
        transform: perspective(1200px) rotateX(-4deg) rotateY(4deg);
    }

    }

    .gv-ultimate-text-e4p {
        font-family: 'Exo 2', sans-serif;
        font-weight: 800;
        letter-spacing: 3px;
        text-transform: uppercase;
    }

    .gv-ultimate-counter-f9q {
        font-family: 'Orbitron', monospace;
        font-weight: 900;
        text-shadow: 0 0 30px currentColor;
    }

    .gv-ultimate-section-g1r {
        background: linear-gradient(135deg, rgba(30, 30, 30, 0.9) 0%, rgba(0, 0, 0, 0.95) 30%, rgba(26, 0, 51, 0.9) 70%, rgba(0, 0, 0, 0.95) 100%), radial-gradient(ellipse at center, rgba(139, 92, 246, 0.08) 0%, transparent 70%);
        position: relative;
    }

        .gv-ultimate-section-g1r::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: radial-gradient(circle at 25% 25%, rgba(59, 130, 246, 0.12) 0%, transparent 50%), radial-gradient(circle at 75% 75%, #D400FF 0%, transparent 50%);
            pointer-events: none;
            z-index: 0;
        }

    /* Responsive Design */
    @@media (max-width: 768px) {
        .gv-ultimate-card-w5r:hover

    {
        transform: translateY(-15px) scale(1.05);
    }

    .gv-ultimate-float-n1c {
        animation-duration: 10s;
    }

    .gv-ultimate-text-l2s {
        font-size: clamp(2rem, 8vw, 4rem);
    }

    }

    @@media (max-width: 640px) {
        .gv-ultimate-card-w5r

    {
        margin: 0 1rem;
    }

    .gv-ultimate-particle-v4w {
        width: 4px;
        height: 4px;
    }

    }
    /* ===== NAVBAR FIXES ===== */
    /* Ensure navbar is visible and on top of effects */
    .site-header {
        position: relative;
        z-index: 1000 !important; /* Override other z-index values */
    }

    .header-nav ul.navbar-nav {
        display: flex !important;
        opacity: 1 !important;
        visibility: visible !important;
    }

    /* Fix for dropdown menus */
    .sub-menu, .mega-menu {
        display: none;
        position: absolute;
        border: 2px solid #008dff;
        border-radius: 8px;
        padding: 10px;
        z-index: 1001;
    }

    .navbar-nav li:hover .sub-menu,
    .navbar-nav li:hover .mega-menu {
        display: block;
    }

    /* Mobile menu toggle fix */
    .navbar-toggler.collapsed + .header-nav {
        display: none;
    }

    .navbar-toggler:not(.collapsed) + .header-nav {
        display: block;
    }

    body {
        overflow-x: hidden;
        background: #000;
        color: #fff;
        font-family: 'Exo 2', sans-serif;
    }

    /* ===== BACKGROUND ===== */
    .gv-ultimate-bg-x9z {
        background-image: linear-gradient(to right, #008dff 0%, #D400FF 50%, #008dff 100%);
        background-attachment: fixed;
        background-size: cover;
    }

    /* Flowing Gradient */
    .gv-ultimate-gradient-k7m {
        background-image: linear-gradient(to right, #008dff 0%, #D400FF 50%, #008dff 100%);
        background-size: 400% 400%;
        animation: gv-ultimate-flow-a3n 8s ease infinite;
    }

    @@keyframes gv-ultimate-flow-a3n {
        0%, 100% {
            background-position: 0% 50%;
        }

        50% {
            background-position: 100% 50%;
        }
    }

    /* ===== NEON GLOW ===== */
    .gv-ultimate-glow-p8q {
        box-shadow: 0 0 30px rgba(0, 141, 255, 0.8), 0 0 60px rgba(212, 0, 255, 0.6), 0 0 90px rgba(0, 141, 255, 0.4), 0 0 120px rgba(212, 0, 255, 0.2), inset 0 0 30px rgba(212, 0, 255, 0.2);
    }

    /* ===== CARD ===== */
    .gv-ultimate-card-w5r {
        background: linear-gradient(145deg, rgba(30,30,30,0.95), rgba(0,0,0,0.98)), radial-gradient(circle at top right, rgba(0,141,255,0.15), transparent 70%), radial-gradient(circle at bottom left, rgba(212,0,255,0.12), transparent 70%);
        border: 3px solid transparent;
        background-clip: padding-box;

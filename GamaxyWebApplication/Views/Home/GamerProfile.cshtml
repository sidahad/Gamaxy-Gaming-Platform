@model GamaxyWebApplication.Models.Registration
@{
    Layout = "_Layout";
}

@section Styles {
    <link href="~/css/GamerProfile.css" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
}


<div class="gamer-profile-container">
    <div class="gamer-floating-particles">
        <div class="gamer-particle"></div>
        <div class="gamer-particle"></div>
        <div class="gamer-particle"></div>
        <div class="gamer-particle"></div>
        <div class="gamer-particle"></div>
    </div>

    <div class="gamer-main-content container mx-auto px-4 py-12 relative z-10">
        <div class="gamer-profile-card max-w-4xl mx-auto p-8">
            <div class="text-center mb-8">
                <div class="gamer-avatar-container">
                    <div class="gamer-avatar-ring"></div>
                    <img src="@Model.UserImage" alt="Profile Image" class="gamer-avatar" />
                </div>
                <h2 class="gamer-name">@Model.Name</h2>
                <p class="gamer-role">Elite Gamer</p>
            </div>

            <hr class="gamer-divider" />

            <div class="gamer-info-grid">
                <div class="gamer-info-item">
                    <div class="gamer-info-label">Email Address</div>
                    <div class="gamer-info-value">@Model.Email</div>
                </div>

                <div class="gamer-info-item">
                    <div class="gamer-info-label">Age</div>
                    <div class="gamer-info-value">@Model.Age years</div>
                </div>

                <div class="gamer-info-item">
                    <div class="gamer-info-label">Gender</div>
                    <div class="gamer-info-value">@Model.Gender</div>
                </div>

                <div class="gamer-info-item">
                    <div class="gamer-info-label">Phone Number</div>
                    <div class="gamer-info-value">@Model.Phone</div>
                </div>

                <div class="gamer-info-item">
                    <div class="gamer-info-label">Location</div>
                    <div class="gamer-info-value">@Model.Address</div>
                </div>

                <div class="gamer-info-item">
                    <div class="gamer-info-label">Gamer Code</div>
                    <div class="gamer-info-value gamer-code-special">@Model.GamerCode</div>
                </div>
            </div>

            <div class="text-center">
                <a asp-action="EditGamerRegistrationDetails" class="gamer-edit-btn">
                    Upgrade Profile
                </a>
            </div>
        </div>
    </div>
</div>

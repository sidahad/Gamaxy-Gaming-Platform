@model GameUploadViewModel;
@{
	ViewData["Title"] = "Games Page";
}

<style>
/* If No Games - Center Card */
.no-games-wrapper {
    display: flex;
    justify-content: center;
    align-items: center;
    height: 80vh;
    background: black;
    font-family: 'Orbitron', sans-serif;
}

.no-games-card {
    text-align: center;
    background: rgba(20,20,30,0.95);
    padding: 40px 60px;
    border-radius: 20px;
    box-shadow: 0 0 20px rgba(0,141,255,0.3), 0 0 15px rgba(212,0,255,0.2);
    animation: glow 2s infinite alternate;
}
.no-games-card i {
    font-size: 60px;
    color: #008dff;
    margin-bottom: 15px;
}
.no-games-card h3 {
    font-size: 26px;
    color: #fff;
    margin-bottom: 10px;
}
.no-games-card p {
    color: #ccc;
    font-size: 16px;
}
.no-games-card .gamaxy {
    background: linear-gradient(to right,#008dff,#D400FF);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    font-weight: 700;
}
@@keyframes glow {
    from { box-shadow: 0 0 10px rgba(0,141,255,0.4); }
    to { box-shadow: 0 0 25px rgba(212,0,255,0.6); }
}

/* --- Category Slider --- */
.category-slider {
    padding: 20px 0;
}
.game-category {
    background: rgba(30,30,40,0.9);
    padding: 15px;
    border-radius: 20px;
    color: white;
    transition: 0.3s;
    cursor: pointer;
    font-weight: 600;
    box-shadow: 0 0 10px rgba(0,141,255,0.4);
}
.game-category:hover, 
.swiper-slide.active .game-category {
    background: linear-gradient(45deg,#008dff,#D400FF);
    color: #fff;
    transform: scale(1.05);
    box-shadow: 0 0 20px rgba(0,141,255,0.6), 0 0 15px rgba(212,0,255,0.6);
}
.game-category i {
    font-size: 20px;
    margin-bottom: 5px;
    display: block;
}

/* --- Game Cards --- */
.room-item {
    background: rgba(20,20,30,0.95);
    border-radius: 12px;
    transition: 0.3s;
}
.room-item:hover {
    transform: translateY(-5px);
    box-shadow: 0 0 25px rgba(0,141,255,0.6), 0 0 15px rgba(212,0,255,0.5);
}
.room-item img {
    border-bottom: 2px solid rgba(255,255,255,0.1);
}

/* --- Star Ratings --- */
.rate-star {
    font-size: 16px;
    margin-left: 2px;
    transition: transform 0.2s;
}
.rate-star:hover {
    transform: scale(1.2);
}

/* --- Buttons --- */
.site-button {
    border-radius: 8px;
    border: 2px solid transparent;
    font-weight: 600;
    transition: 0.3s;
}
.site-button:hover {
    transform: scale(1.05);
}
.btnhover11 {
    background: linear-gradient(45deg,#008dff,#D400FF);
    border: none;
    box-shadow: 0 0 12px rgba(0,141,255,0.5);
}
.btnhover11:hover {
    background: linear-gradient(45deg,#D400FF,#008dff);
    box-shadow: 0 0 15px rgba(212,0,255,0.8);
}
</style>

<script src="https://kit.fontawesome.com/eaad2fdcac.js" crossorigin="anonymous"></script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Heebo:wght@400;500;600;700&family=Montserrat:wght@400;500;600;700&display=swap"
	  rel="stylesheet">
<script src="https://kit.fontawesome.com/eaad2fdcac.js" crossorigin="anonymous"></script>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
<link rel="stylesheet" href="https://use.fontawesome.com/releases/v5.2.0/css/all.css"
	  integrity="sha384-hWVjflwFxL6sNzntih27bfxkr27PmbbK/iSvJ+a4+0owXq79v+lsFkW54bOGbiDQ" crossorigin="anonymous">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.10.0/css/all.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.4.1/font/bootstrap-icons.css" rel="stylesheet">
<link href="~/web/mygames.css" rel="stylesheet" />
<!-- Swiper CSS -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@9/swiper-bundle.min.css" />

<!-- Swiper JS -->
<script src="https://cdn.jsdelivr.net/npm/swiper@9/swiper-bundle.min.js"></script>



@if (Model.Games == null || !Model.Games.Any())
{
	<div class="no-games-wrapper">
		<div class="no-games-card">
			<i class="fas fa-gamepad"></i>
			<h3>No Games Uploaded Yet</h3>
			<p>Upload your first game and start building your legacy on <span class="gamaxy">Gamaxy</span> </p>
		</div>
	</div>
}
else
{
	<section class="game-category-section py-5" style="background-color: rgb(0, 0, 0);">
		@{
			var radiusStyles = new[]
			{
	"border-top-left-radius:250px;border-top-right-radius:250px;",
	"border-bottom-left-radius:250px;border-bottom-right-radius:250px;"
	};
			int styleIndex = 0;
		}
		<div class="swiper category-slider" id="categorySwiper">
			<div class="swiper-wrapper">
				<!-- "All" Category -->
				<div class="swiper-slide active" data-filter="">
					<div class="game-category text-center" style="border-top-left-radius:250px;border-top-right-radius:250px;">
						<i class="fa-solid fa-shapes"></i><span>All</span>
					</div>
				</div>

				<!-- Dynamic Categories -->
				@foreach (var cat in Model.Categories)
				{
					var style = radiusStyles[styleIndex % 2];
					styleIndex++;

					var icon = !string.IsNullOrEmpty(cat.IconClass) ? cat.IconClass : "fa-solid fa-gamepad";
					var filter = cat.CategoryName?.ToLower().Replace(" ", string.Empty);

					<div class="swiper-slide" data-filter="@filter">
						<div class="game-category text-center" style="@style">
							<i class="@icon"></i><span>@cat.CategoryName</span>
						</div>
					</div>
				}
			</div>

			<!-- Navigation Arrows -->
			<div class="swiper-button-next"></div>
			<div class="swiper-button-prev"></div>

			<!-- Pagination Bullets -->
			<div class="swiper-pagination"></div>
		</div>
	</section>

	<!-- Filterable Game Cards -->
	<div class="container-xxl justify-content-center p-4"  style="padding: 0px; background:black;">
		<div class="container ms-4" style="padding: 0px; margin: 0px;">

			<div class="row g-6 ms-4 p-4 pt-0 mx-auto">
				@foreach (var game in Model.Games)
				{
					<div class="col-lg-4 col-md-6 fadeInUp mt-5"
						 data-category="@game.Category?.CategoryName?.ToLower().Replace(" ", string.Empty)">
						<div class="room-item rounded overflow-hidden"
							 style="height: 460px; border-radius: 10px; box-shadow: 0 4px 20px #008dff, 0 0 10px #D400FF, 0 0 5px #008dff;">
							<div class="position-relative card_box2">
								<img class="img-fluid"
									 src="@(string.IsNullOrEmpty(game.ImagePath) ? "/default-image.jpg" : game.ImagePath)"
									 alt="@game.Title"
									 style="height: 250px; width: 100%;">
								<small class="position-absolute text-center start-0 top-100 translate-middle-y text-white rounded py-1 px-4"
									   style="background-image: linear-gradient(to right, #008dff 0%, #D400FF 50%,#008dff 100%);margin-left: -3px;">
									<div class="d-flex">
										<small class="border-end me-3 pe-3" style="font-weight: 600;">
											<i class="@game.Category?.IconClass me-2" style="color: #ffffff;"></i>
											@game.Category?.CategoryName
										</small>
									</div>
								</small>
								<span></span>
							</div>

							<div class="p-4 mt-2">
								<div class="d-flex justify-content-between mb-3">
									<h5 class="mb-0 text-white">
										<a asp-controller="Game" asp-action="Details" asp-route-slug="@game.Slug" style="text-decoration:none; color:white;">@game.Title</a>
									</h5>
									<div class="ps-2">
										@for (int i = 1; i <= 5; i++)
										{
											if (i <= Math.Floor(game.AverageRating))
											{
												<small class="fa fa-star rate-star"
													   style="color: gold; cursor: pointer;"
													   data-gameid="@game.GameId"
													   data-stars="@i"></small>
											}
											else if (i - game.AverageRating < 1 && game.AverageRating % 1 >= 0.5)
											{
												<small class="fa fa-star-half-alt rate-star"
													   style="color: gold; cursor: pointer;"
													   data-gameid="@game.GameId"
													   data-stars="@i"></small>
											}
											else
											{
												<small class="fa fa-star rate-star"
													   style="color: lightgray; cursor: pointer;"
													   data-gameid="@game.GameId"
													   data-stars="@i"></small>
											}
										}
									</div>

								</div>

								<p class="text-white mb-1" style="height: 70px;">
									@game.ShortDescription
									<a asp-controller="Game" asp-action="Details" asp-route-slug="@game.Slug" style="text-decoration:none;">more</a>
								</p>

								<div class="d-flex justify-content-between mt-4">
									<a class="site-button outline outline-2 btnhover11 py-2 px-4 text-white"
									   data-title="@game.Title"
									   data-instruction="@game.HowToPlay"
									   data-bs-toggle="modal"
									   data-bs-target="#howToPlayModal">How to Play</a>

									<a class="site-button outline outline-2 btnhover11 py-2 px-4"
									 asp-controller="Launcher" asp-action="Details" asp-route-slug="@game.Slug" style="text-decoration:none;">Play Now </a>
								</div>
							</div>
						</div>
					</div>
				}
			</div>

			<!-- How to Play Modal -->
			<div class="modal fade" id="howToPlayModal" tabindex="-1" aria-labelledby="howToPlayLabel" aria-hidden="true">
				<div class="modal-dialog modal-dialog-scrollable modal-lg">
					<div class="modal-content">
						<div class="modal-header">
							<h5 class="modal-title" id="howToPlayLabel">How to Play</h5>
							<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
						</div>
						<div class="modal-body" id="howToPlayBody"></div>
						<div class="modal-footer">
							<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
						</div>
					</div>
				</div>
			</div>

		</div>
	</div>
}

<script>
	document.addEventListener("DOMContentLoaded", function () {
		// Init Swiper
		var swiper = new Swiper("#categorySwiper", {
			slidesPerView: "auto",
			spaceBetween: 20,
			navigation: {
				nextEl: ".swiper-button-next",
				prevEl: ".swiper-button-prev",
			},
			pagination: {
				el: ".swiper-pagination",
				clickable: true,
			},
			freeMode: true,
		});

		// Modal: Load How to Play Content
		document.querySelectorAll('[data-bs-target="#howToPlayModal"]').forEach(btn => {
			btn.addEventListener('click', function () {
				const title = this.getAttribute('data-title');
				const instruction = this.getAttribute('data-instruction');
				document.getElementById('howToPlayLabel').innerText = `How to Play - ${title}`;
				document.getElementById('howToPlayBody').innerHTML = instruction || "No instructions provided.";
			});
		});

		// Category Filter Logic
		document.querySelectorAll('#categorySwiper .swiper-slide').forEach(slide => {
			slide.addEventListener('click', function () {
				// Remove active from all
				document.querySelectorAll('#categorySwiper .swiper-slide').forEach(s => s.classList.remove('active'));
				// Add active to clicked one
				this.classList.add('active');

				const filter = this.getAttribute('data-filter');
				document.querySelectorAll('[data-category]').forEach(card => {
					if (!filter || card.getAttribute('data-category') === filter) {
						card.style.display = '';
					} else {
						card.style.display = 'none';
					}
				});

				swiper.update(); // refresh Swiper layout
			});
		});

		// Star Rating Click Handler
		document.querySelectorAll('.rate-star').forEach(star => {
			star.addEventListener('click', function () {
				let gameId = this.getAttribute('data-gameid');
				let stars = this.getAttribute('data-stars');

				fetch('/Game/RateGame', {
					method: 'POST',
					headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
					body: `gameId=${gameId}&stars=${stars}`
				}).then(() => {
					location.reload(); // Refresh to update average rating
				});
			});
		});
	});
</script>


@model GamaxyWebApplication.Models.GameRatingViewModel
@{
    ViewData["Title"] = "Sky Delivery";
    Layout = "_layout3";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sky Delivery</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="~/css/delivery.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700&display=swap" />
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
</head>
<body class="game-page">
    <div class="game-container-wrapper">
        <div id="game-container">
            <div class="sky"></div>
            <div class="stars" id="stars"></div>
            <div class="city" id="city"></div>

            <div id="drone">
                <svg viewBox="0 0 60 30" xmlns="http://www.w3.org/2000/svg">
                    <rect x="20" y="10" width="20" height="10" fill="#334155" rx="2" />
                    <rect x="25" y="5" width="10" height="5" fill="#1e293b" />
                    <circle cx="15" cy="15" r="6" fill="#f97316" stroke="#334155" stroke-width="1" />
                    <circle cx="45" cy="15" r="6" fill="#f97316" stroke="#334155" stroke-width="1" />
                    <circle cx="15" cy="15" r="2" fill="#fcd34d" />
                    <circle cx="45" cy="15" r="2" fill="#fcd34d" />
                    <rect x="22" y="20" width="16" height="3" fill="#f97316" />
                    <circle cx="30" cy="23" r="1" fill="#fcd34d" />
                </svg>
            </div>

            <div class="ui-container">
                <div class="score-container">
                    <span>📦</span>
                    <span id="score">0</span>
                </div>

                <div class="level-container">
                    <span>🏆</span>
                    Level <span id="level">1</span>
                </div>

                <div class="progress-container">
                    <div class="progress-bar">
                        <div class="progress" id="progress"></div>
                    </div>
                </div>

                <div class="timer-container">
                    <span>⏱️</span>
                    <span id="timer">00:00</span>
                </div>

                <div class="powerup-indicator" id="powerup-indicator">
                    <span id="powerup-icon">⚡</span>
                    <span id="powerup-name">Speed Boost</span>
                    <div class="powerup-timer">
                        <div class="powerup-timer-progress" id="powerup-timer-progress"></div>
                    </div>
                </div>

                <div class="notification" id="notification">
                    <span id="notification-icon">🎉</span>
                    <span id="notification-text">Achievement unlocked!</span>
                </div>

                <div class="pause-button" id="pause-button">⏸️</div>

                <div class="game-controls">
                    <button class="control-button" id="left-button">◀</button>
                    <button class="control-button drop-button" id="drop-button">📦</button>
                    <button class="control-button" id="right-button">▶</button>
                </div>
            </div>

            <div class="screen splash-screen" id="splash-screen">
                <div class="splash-content">
                    <div class="logo">🚁</div>
                    <h1>Sky Delivery</h1>
                    <div class="tagline">Deliver packages from the sky!</div>
                    <p>Control your drone and drop packages on the targets. Avoid obstacles and collect power-ups to complete your deliveries!</p>
                    <button id="start-button">START GAME</button>
                </div>
            </div>

            <div class="screen" id="game-over-screen" style="display: none;">
                <div class="screen-content">
                    <h2>Game Over!</h2>
                    <p>Your delivery shift has ended</p>
                    <div class="stats">
                        <p><span>Final Score:</span> <span id="final-score">0</span></p>
                        <p><span>Deliveries:</span> <span id="final-deliveries">0</span></p>
                        <p><span>Level Reached:</span> <span id="final-level">1</span></p>
                        <p><span>Time Played:</span> <span id="final-time">00:00</span></p>
                    </div>
                    <button id="restart-button">Play Again</button>
                </div>
            </div>

            <div class="screen" id="level-complete-screen" style="display: none;">
                <div class="screen-content">
                    <h2>Level Complete!</h2>
                    <div class="level-complete-stars">
                        <div class="level-complete-star" id="star-1">★</div>
                        <div class="level-complete-star" id="star-2">★</div>
                        <div class="level-complete-star" id="star-3">★</div>
                    </div>
                    <div class="stats">
                        <p><span>Score:</span> <span id="level-score">0</span></p>
                        <p><span>Deliveries:</span> <span id="level-deliveries">0</span></p>
                        <p><span>Time:</span> <span id="level-time">00:00</span></p>
                        <p><span>Accuracy:</span> <span id="level-accuracy">0%</span></p>
                    </div>
                    <div class="level-complete-rewards">
                        <div class="level-complete-reward">
                            <div class="level-complete-reward-icon">🪙</div>
                            <div class="level-complete-reward-value" id="level-coins">+50</div>
                        </div>
                        <div class="level-complete-reward">
                            <div class="level-complete-reward-icon">⭐</div>
                            <div class="level-complete-reward-value" id="level-xp">+100</div>
                        </div>
                    </div>
                    <div class="level-complete-buttons">
                        <button class="level-complete-button" id="level-retry">
                            <span>🔄</span> Retry
                        </button>
                        <button class="level-complete-button next" id="level-next">
                            <span>▶️</span> Next Level
                        </button>
                    </div>
                </div>
            </div>

            <div class="screen" id="pause-screen" style="display: none;">
                <div class="pause-content">
                    <h2>Paused</h2>
                    <div class="pause-buttons">
                        <button class="pause-button-large resume" id="resume-button">
                            <span>▶️</span> Resume
                        </button>
                        <button class="pause-button-large" id="quit-button">
                            <span>🚪</span> Quit Game
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="rating-section">
        <h2 class="rating-title">@Model.GameName</h2>
        <p class="rating-average">Average Rating: @Model.AverageRating.ToString("F1")</p>
        @if (Model.UserId.HasValue)
        {
            <p class="rating-user">Your Rating: @(Model.ExistingRating > 0 ? Model.ExistingRating.ToString() : "Not rated yet")</p>
            <form id="ratingForm" method="post" asp-action="RateGame">
                <input type="hidden" name="gameName" value="@Model.GameName" />
                <div class="star-rating">
                    <input type="radio" name="rating" value="5" id="star5" @(Model.ExistingRating == 5 ? "checked" : "")>
                    <label for="star5">★</label>
                    <input type="radio" name="rating" value="4" id="star4" @(Model.ExistingRating == 4 ? "checked" : "")>
                    <label for="star4">★</label>
                    <input type="radio" name="rating" value="3" id="star3" @(Model.ExistingRating == 3 ? "checked" : "")>
                    <label for="star3">★</label>
                    <input type="radio" name="rating" value="2" id="star2" @(Model.ExistingRating == 2 ? "checked" : "")>
                    <label for="star2">★</label>
                    <input type="radio" name="rating" value="1" id="star1" @(Model.ExistingRating == 1 ? "checked" : "")>
                    <label for="star1">★</label>
                </div>
                <button type="submit" class="btn-rate">Submit Rating</button>
            </form>
        }
        else
        {
            <p class="rating-login">Please <a asp-action="Login" class="login-link">login</a> to rate this game.</p>
        }
    </div>

    <script>
        $(document).ready(function () {
            $('#ratingForm').on('submit', function (e) {
                e.preventDefault();
                $.ajax({
                    url: '@Url.Action("RateGame", "Home")',
                    type: 'POST',
                    data: $(this).serialize(),
                    headers: {
                        'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function (response) {
                        if (response.success) {
                            alert(response.message);
                            location.reload();
                        } else {
                            alert('Error: ' + response.message);
                        }
                    },
                    error: function () {
                        alert('An error occurred while submitting the rating.');
                    }
                });
            });
        });

        // Existing game JavaScript (unchanged)
        document.addEventListener('DOMContentLoaded', () => {
            // Game elements
            const gameContainer = document.getElementById('game-container');
            const city = document.getElementById('city');
            const stars = document.getElementById('stars');
            const drone = document.getElementById('drone');
            const scoreElement = document.getElementById('score');
            const levelElement = document.getElementById('level');
            const progressElement = document.getElementById('progress');
            const timerElement = document.getElementById('timer');
            const powerupIndicator = document.getElementById('powerup-indicator');
            const powerupTimerProgress = document.getElementById('powerup-timer-progress');
            const powerupIcon = document.getElementById('powerup-icon');
            const powerupName = document.getElementById('powerup-name');
            const notification = document.getElementById('notification');
            const notificationIcon = document.getElementById('notification-icon');
            const notificationText = document.getElementById('notification-text');
            const dropButton = document.getElementById('drop-button');
            const leftButton = document.getElementById('left-button');
            const rightButton = document.getElementById('right-button');
            const pauseButton = document.getElementById('pause-button');

            // Screens
            const splashScreen = document.getElementById('splash-screen');
            const gameOverScreen = document.getElementById('game-over-screen');
            const levelCompleteScreen = document.getElementById('level-complete-screen');
            const pauseScreen = document.getElementById('pause-screen');

            // Screen elements
            const startButton = document.getElementById('start-button');
            const finalScoreElement = document.getElementById('final-score');
            const finalDeliveriesElement = document.getElementById('final-deliveries');
            const finalLevelElement = document.getElementById('final-level');
            const finalTimeElement = document.getElementById('final-time');
            const restartButton = document.getElementById('restart-button');
            const levelScore = document.getElementById('level-score');
            const levelDeliveries = document.getElementById('level-deliveries');
            const levelTime = document.getElementById('level-time');
            const levelAccuracy = document.getElementById('level-accuracy');
            const levelCoins = document.getElementById('level-coins');
            const levelXp = document.getElementById('level-xp');
            const levelRetry = document.getElementById('level-retry');
            const levelNext = document.getElementById('level-next');
            const star1 = document.getElementById('star-1');
            const star2 = document.getElementById('star-2');
            const star3 = document.getElementById('star-3');
            const resumeButton = document.getElementById('resume-button');
            const quitButton = document.getElementById('quit-button');

            // Game state
            let gameActive = false;
            let isPaused = false;
            let score = 0;
            let combo = 0;
            let level = 1;
            let deliveriesCompleted = 0;
            let deliveriesNeeded = 5;
            let droneSpeed = 5;
            let gameWidth = gameContainer.clientWidth;
            let gameHeight = gameContainer.clientHeight;
            let packages = [];
            let targets = [];
            let buildings = [];
            let obstacles = [];
            let powerups = [];
            let coins = [];
            let activePowerup = null;
            let powerupTimer = null;
            let gameTimer = 0;
            let gameTimerInterval = null;
            let packagesMissed = 0;
            let packagesDropped = 0;
            let levelStartTime = 0;
            let droneX = 10;
            let droneY = 80;
            let leftPressed = false;
            let rightPressed = false;

            // Initialize game
            function init() {
                // Event listeners
                startButton.addEventListener('click', startGame);
                restartButton.addEventListener('click', startGame);
                dropButton.addEventListener('click', dropPackage);
                pauseButton.addEventListener('click', togglePause);
                resumeButton.addEventListener('click', resumeGame);
                quitButton.addEventListener('click', quitGame);
                levelRetry.addEventListener('click', retryLevel);
                levelNext.addEventListener('click', nextLevel);

                // Control buttons
                leftButton.addEventListener('mousedown', () => { leftPressed = true; });
                leftButton.addEventListener('mouseup', () => { leftPressed = false; });
                leftButton.addEventListener('touchstart', () => { leftPressed = true; });
                leftButton.addEventListener('touchend', () => { leftPressed = false; });

                rightButton.addEventListener('mousedown', () => { rightPressed = true; });
                rightButton.addEventListener('mouseup', () => { rightPressed = false; });
                rightButton.addEventListener('touchstart', () => { rightPressed = true; });
                rightButton.addEventListener('touchend', () => { rightPressed = false; });

                // Keyboard controls
                document.addEventListener('keydown', (e) => {
                    if (e.key === 'ArrowLeft') leftPressed = true;
                    if (e.key === 'ArrowRight') rightPressed = true;
                    if (e.key === ' ' || e.key === 'ArrowDown') dropPackage();
                    if (e.key === 'Escape') togglePause();
                });

                document.addEventListener('keyup', (e) => {
                    if (e.key === 'ArrowLeft') leftPressed = false;
                    if (e.key === 'ArrowRight') rightPressed = false;
                });

                // Resize handler
                window.addEventListener('resize', handleResize);
                handleResize();

                // Generate stars
                generateStars();
            }

            function handleResize() {
                gameWidth = gameContainer.clientWidth;
                gameHeight = gameContainer.clientHeight;

                // Reposition elements if game is active
                if (gameActive) {
                    repositionElements();
                }
            }

            function startGame() {
                splashScreen.style.display = 'none';
                gameOverScreen.style.display = 'none';
                levelCompleteScreen.style.display = 'none';

                // Reset game state
                gameActive = true;
                isPaused = false;
                score = 0;
                combo = 0;
                level = 1;
                deliveriesCompleted = 0;
                deliveriesNeeded = 5;
                droneSpeed = 5;
                activePowerup = null;
                if (powerupTimer) clearTimeout(powerupTimer);
                powerupIndicator.style.opacity = '0';

                // Reset drone position
                droneX = gameWidth / 2 - 30;
                droneY = 80;
                drone.style.left = `${droneX}px`;
                drone.style.top = `${droneY}px`;

                // Reset timer
                gameTimer = 0;
                clearInterval(gameTimerInterval);
                gameTimerInterval = setInterval(updateGameTimer, 1000);
                updateTimerDisplay();

                // Clear existing elements
                packages = [];
                targets = [];
                buildings = [];
                obstacles = [];
                powerups = [];
                coins = [];

                // Reset tracking variables
                packagesMissed = 0;
                packagesDropped = 0;
                levelStartTime = Date.now();

                // Remove all game elements
                document.querySelectorAll('.package, .target, .obstacle, .building, .window, .powerup, .coin, .explosion, .combo-indicator, .coin-indicator, .cloud').forEach(el => {
                    el.remove();
                });

                // Update UI
                scoreElement.textContent = score;
                levelElement.textContent = level;
                progressElement.style.width = '0%';

                // Create buildings
                createBuildings();

                // Create target
                createTarget();

                // Create clouds
                createClouds();

                // Start game loop
                requestAnimationFrame(gameLoop);
            }

            function createBuildings() {
                // Clear existing buildings
                city.innerHTML = '';
                buildings = [];

                const buildingCount = Math.floor(gameWidth / 100);
                const buildingWidth = gameWidth / buildingCount;

                for (let i = 0; i < buildingCount; i++) {
                    const height = Math.random() * 0.2 * gameHeight + 0.1 * gameHeight;
                    const building = document.createElement('div');
                    building.className = 'building';
                    building.style.left = `${i * buildingWidth}px`;
                    building.style.width = `${buildingWidth}px`;
                    building.style.height = `${height}px`;

                    // Add windows
                    const windowSize = Math.min(20, buildingWidth * 0.2);
                    const windowsPerRow = Math.floor(buildingWidth / (windowSize * 1.5));
                    const windowsPerColumn = Math.floor(height / (windowSize * 1.5));

                    for (let row = 0; row < windowsPerColumn; row++) {
                        for (let col = 0; col < windowsPerRow; col++) {
                            if (Math.random() > 0.3) {
                                const windowEl = document.createElement('div');
                                windowEl.className = 'window';
                                windowEl.style.width = `${windowSize}px`;
                                windowEl.style.height = `${windowSize}px`;
                                windowEl.style.left = `${col * windowSize * 1.5 + windowSize * 0.25}px`;
                                windowEl.style.top = `${row * windowSize * 1.5 + windowSize * 0.25}px`;
                                building.appendChild(windowEl);
                            }
                        }
                    }

                    city.appendChild(building);
                    buildings.push({
                        element: building,
                        x: i * buildingWidth,
                        y: gameHeight - height,
                        width: buildingWidth,
                        height: height
                    });
                }
            }

            function createTarget() {
                document.querySelectorAll('.target').forEach(el => el.remove());
                targets = [];

                const suitableBuildings = buildings.filter(b => b.width >= 40);
                if (suitableBuildings.length === 0) return;

                const building = suitableBuildings[Math.floor(Math.random() * suitableBuildings.length)];

                const target = document.createElement('div');
                target.className = 'target';

                const targetX = building.x + Math.random() * (building.width - 40);
                const targetY = building.y - 20;

                target.style.left = `${targetX}px`;
                target.style.top = `${targetY}px`;

                gameContainer.appendChild(target);

                targets.push({
                    element: target,
                    x: targetX,
                    y: targetY,
                    width: 40,
                    height: 40
                });

                createObstacles();

                if (Math.random() < 0.3) {
                    createPowerup();
                }

                createCoins();
            }

            function createObstacles() {
                document.querySelectorAll('.obstacle').forEach(el => el.remove());
                obstacles = [];

                const obstacleCount = Math.min(level, 5);

                for (let i = 0; i < obstacleCount; i++) {
                    const obstacle = document.createElement('div');
                    obstacle.className = 'obstacle';
                    obstacle.textContent = '🐦';

                    const obstacleX = Math.random() * (gameWidth - 30);
                    const obstacleY = Math.random() * (gameHeight * 0.6) + 50;

                    obstacle.style.left = `${obstacleX}px`;
                    obstacle.style.top = `${obstacleY}px`;

                    obstacle.style.animationDelay = `${Math.random() * 5}s`;

                    gameContainer.appendChild(obstacle);

                    obstacles.push({
                        element: obstacle,
                        x: obstacleX,
                        y: obstacleY,
                        width: 30,
                        height: 30
                    });
                }
            }

            function createPowerup() {
                document.querySelectorAll('.powerup').forEach(el => el.remove());
                powerups = [];

                const powerupTypes = [
                    { icon: '⏱️', name: 'Time Slow', color: '#38bdf8' },
                    { icon: '🪂', name: 'Parachute', color: '#fb923c' },
                    { icon: '⚡', name: 'Speed Boost', color: '#facc15' },
                    { icon: '🎯', name: 'Auto Aim', color: '#4ade80' }
                ];

                const powerupType = powerupTypes[Math.floor(Math.random() * powerupTypes.length)];

                const powerup = document.createElement('div');
                powerup.className = 'powerup';
                powerup.textContent = powerupType.icon;
                powerup.style.backgroundColor = powerupType.color;

                const powerupX = Math.random() * (gameWidth - 30);
                const powerupY = Math.random() * (gameHeight * 0.4) + 50;

                powerup.style.left = `${powerupX}px`;
                powerup.style.top = `${powerupY}px`;

                gameContainer.appendChild(powerup);

                powerups.push({
                    element: powerup,
                    x: powerupX,
                    y: powerupY,
                    width: 30,
                    height: 30,
                    type: powerupType.name,
                    icon: powerupType.icon
                });
            }

            function createCoins() {
                document.querySelectorAll('.coin').forEach(el => el.remove());
                coins = [];

                const coinCount = Math.floor(Math.random() * 3) + 1;

                for (let i = 0; i < coinCount; i++) {
                    const coin = document.createElement('div');
                    coin.className = 'coin';
                    coin.textContent = '₵';

                    const coinX = Math.random() * (gameWidth - 20);
                    const coinY = Math.random() * (gameHeight * 0.4) + 50;

                    coin.style.left = `${coinX}px`;
                    coin.style.top = `${coinY}px`;

                    gameContainer.appendChild(coin);

                    coins.push({
                        element: coin,
                        x: coinX,
                        y: coinY,
                        width: 20,
                        height: 20
                    });
                }
            }

            function createClouds() {
                const cloudCount = Math.floor(Math.random() * 5) + 3;

                for (let i = 0; i < cloudCount; i++) {
                    const cloud = document.createElement('div');
                    cloud.className = 'cloud';

                    const cloudSize = Math.random() * 50 + 50;
                    cloud.style.width = `${cloudSize}px`;
                    cloud.style.height = `${cloudSize * 0.6}px`;

                    const cloudX = Math.random() * gameWidth;
                    const cloudY = Math.random() * (gameHeight * 0.3);

                    cloud.style.left = `${cloudX}px`;
                    cloud.style.top = `${cloudY}px`;

                    gameContainer.appendChild(cloud);
                }
            }

            function generateStars() {
                const starCount = 50;

                for (let i = 0; i < starCount; i++) {
                    const star = document.createElement('div');
                    star.className = 'star';

                    const starSize = Math.random() * 2 + 1;
                    star.style.width = `${starSize}px`;
                    star.style.height = `${starSize}px`;

                    const starX = Math.random() * gameWidth;
                    const starY = Math.random() * (gameHeight * 0.5);

                    star.style.left = `${starX}px`;
                    star.style.top = `${starY}px`;

                    star.style.animationDelay = `${Math.random() * 2}s`;

                    stars.appendChild(star);
                }
            }

            function dropPackage() {
                if (!gameActive || isPaused) return;

                const droneRect = drone.getBoundingClientRect();

                const packageElement = document.createElement('div');
                packageElement.className = 'package';

                const packageX = droneRect.left + droneRect.width / 2 - 10;
                const packageY = droneRect.bottom;

                packageElement.style.left = `${packageX}px`;
                packageElement.style.top = `${packageY}px`;

                gameContainer.appendChild(packageElement);

                packages.push({
                    element: packageElement,
                    x: packageX,
                    y: packageY,
                    velocityY: 0,
                    width: 20,
                    height: 20,
                    hasParachute: activePowerup === 'Parachute'
                });

                packagesDropped++;
            }

            function movePackages() {
                const gravity = activePowerup === 'Time Slow' ? 0.2 : 0.5;

                packages.forEach((pkg, index) => {
                    pkg.velocityY += gravity;

                    if (pkg.hasParachute && pkg.velocityY > 3) {
                        pkg.velocityY = 3;
                    }

                    pkg.y += pkg.velocityY;
                    pkg.element.style.top = `${pkg.y}px`;

                    if (pkg.y > gameHeight) {
                        pkg.element.remove();
                        packages.splice(index, 1);
                        combo = 0;
                        packagesMissed++;
                    }
                });
            }

            function checkCollisions() {
                packages.forEach((pkg, pkgIndex) => {
                    targets.forEach((target, targetIndex) => {
                        if (isColliding(pkg, target)) {
                            handleTargetHit(pkg, target, pkgIndex);
                        }
                    });

                    obstacles.forEach((obstacle, obstacleIndex) => {
                        if (isColliding(pkg, obstacle)) {
                            handleObstacleHit(pkg, obstacle, pkgIndex);
                        }
                    });

                    buildings.forEach(building => {
                        if (isColliding(pkg, building)) {
                            handleBuildingHit(pkg, building, pkgIndex);
                        }
                    });
                });

                const droneRect = drone.getBoundingClientRect();
                const droneObj = {
                    x: droneRect.left,
                    y: droneRect.top,
                    width: droneRect.width,
                    height: droneRect.height
                };

                powerups.forEach((powerup, powerupIndex) => {
                    if (isColliding(droneObj, powerup)) {
                        handlePowerupCollected(powerup, powerupIndex);
                    }
                });

                coins.forEach((coin, coinIndex) => {
                    if (isColliding(droneObj, coin)) {
                        handleCoinCollected(coin, coinIndex);
                    }
                });
            }

            function isColliding(obj1, obj2) {
                return (
                    obj1.x < obj2.x + obj2.width &&
                    obj1.x + obj1.width > obj2.x &&
                    obj1.y < obj2.y + obj2.height &&
                    obj1.y + obj1.height > obj2.y
                );
            }

            function handleTargetHit(pkg, target, pkgIndex) {
                pkg.element.remove();
                packages.splice(pkgIndex, 1);
                createExplosion(pkg.x, pkg.y);
                const basePoints = 10;
                const points = basePoints * (combo + 1);
                score += points;
                scoreElement.textContent = score;
                combo++;
                showComboIndicator(pkg.x, pkg.y);
                deliveriesCompleted++;
                const progress = (deliveriesCompleted / deliveriesNeeded) * 100;
                progressElement.style.width = `${progress}%`;
                if (deliveriesCompleted >= deliveriesNeeded) {
                    levelCompleted();
                } else {
                    createTarget();
                }
            }

            function handleObstacleHit(pkg, obstacle, pkgIndex) {
                pkg.element.remove();
                packages.splice(pkgIndex, 1);
                createExplosion(pkg.x, pkg.y);
                combo = 0;
                packagesMissed++;
                showNotification('🐦', 'Package intercepted by bird!');
            }

            function handleBuildingHit(pkg, building, pkgIndex) {
                pkg.element.remove();
                packages.splice(pkgIndex, 1);
                createExplosion(pkg.x, pkg.y);
                combo = 0;
                packagesMissed++;
                showNotification('🏢', 'Package hit a building!');
            }

            function handlePowerupCollected(powerup, powerupIndex) {
                powerup.element.remove();
                powerups.splice(powerupIndex, 1);
                activatePowerup(powerup.type, powerup.icon);
                showNotification(powerup.icon, `${powerup.type} activated!`);
            }

            function handleCoinCollected(coin, coinIndex) {
                coin.element.remove();
                coins.splice(coinIndex, 1);
                score += 5;
                scoreElement.textContent = score;
                showCoinIndicator(coin.x, coin.y, 5);
            }

            function activatePowerup(type, icon) {
                if (powerupTimer) {
                    clearTimeout(powerupTimer);
                }
                activePowerup = type;
                powerupIcon.textContent = icon;
                powerupName.textContent = type;
                powerupIndicator.style.opacity = '1';
                powerupTimerProgress.style.width = '100%';
                const duration = 10000;
                powerupTimerProgress.style.transition = `width ${duration}ms linear`;
                setTimeout(() => {
                    powerupTimerProgress.style.width = '0%';
                }, 50);
                powerupTimer = setTimeout(() => {
                    activePowerup = null;
                    powerupIndicator.style.opacity = '0';
                }, duration);
                if (type === 'Speed Boost') {
                    droneSpeed = 10;
                    setTimeout(() => {
                        droneSpeed = 5;
                    }, duration);
                }
            }

            function createExplosion(x, y) {
                const explosion = document.createElement('div');
                explosion.className = 'explosion';
                explosion.style.left = `${x}px`;
                explosion.style.top = `${y}px`;
                gameContainer.appendChild(explosion);
                setTimeout(() => {
                    explosion.remove();
                }, 500);
            }

            function showComboIndicator(x, y) {
                const comboIndicator = document.createElement('div');
                comboIndicator.className = 'combo-indicator';
                comboIndicator.textContent = `${combo}x Combo!`;
                comboIndicator.style.left = `${x}px`;
                comboIndicator.style.top = `${y - 30}px`;
                gameContainer.appendChild(comboIndicator);
                setTimeout(() => {
                    comboIndicator.style.opacity = '1';
                    comboIndicator.style.transform = 'translateY(-20px)';
                }, 50);
                setTimeout(() => {
                    comboIndicator.style.opacity = '0';
                    setTimeout(() => {
                        comboIndicator.remove();
                    }, 300);
                }, 1000);
            }

            function showCoinIndicator(x, y, amount) {
                const coinIndicator = document.createElement('div');
                coinIndicator.className = 'coin-indicator';
                coinIndicator.textContent = `+${amount}`;
                coinIndicator.style.left = `${x}px`;
                coinIndicator.style.top = `${y - 20}px`;
                gameContainer.appendChild(coinIndicator);
                setTimeout(() => {
                    coinIndicator.style.opacity = '1';
                    coinIndicator.style.transform = 'translateY(-20px)';
                }, 50);
                setTimeout(() => {
                    coinIndicator.style.opacity = '0';
                    setTimeout(() => {
                        coinIndicator.remove();
                    }, 300);
                }, 1000);
            }

            function showNotification(icon, text) {
                notificationIcon.textContent = icon;
                notificationText.textContent = text;
                notification.classList.add('show');
                setTimeout(() => {
                    notification.classList.remove('show');
                }, 3000);
            }

            function levelCompleted() {
                gameActive = false;
                clearInterval(gameTimerInterval);
                const levelTime = Math.floor((Date.now() - levelStartTime) / 1000);
                const accuracy = packagesDropped > 0 ? Math.floor((deliveriesCompleted / packagesDropped) * 100) : 0;
                const levelCoinsEarned = 50 + level * 10;
                const levelXpEarned = 100 + level * 20;
                let starsEarned = 0;
                starsEarned++;
                if (accuracy >= 75) {
                    starsEarned++;
                }
                if (levelTime <= 60) {
                    starsEarned++;
                }
                levelScore.textContent = score;
                levelDeliveries.textContent = deliveriesCompleted;
                levelTime.textContent = formatTime(levelTime);
                levelAccuracy.textContent = `${accuracy}%`;
                levelCoins.textContent = `+${levelCoinsEarned}`;
                levelXp.textContent = `+${levelXpEarned}`;
                star1.classList.remove('earned');
                star2.classList.remove('earned');
                star3.classList.remove('earned');
                setTimeout(() => {
                    if (starsEarned >= 1) star1.classList.add('earned');
                }, 500);
                setTimeout(() => {
                    if (starsEarned >= 2) star2.classList.add('earned');
                }, 1000);
                setTimeout(() => {
                    if (starsEarned >= 3) star3.classList.add('earned');
                }, 1500);
                level++;
                setTimeout(() => {
                    levelCompleteScreen.style.display = 'flex';
                }, 1000);
            }

            function gameOver() {
                gameActive = false;
                clearInterval(gameTimerInterval);
                finalScoreElement.textContent = score;
                finalDeliveriesElement.textContent = deliveriesCompleted;
                finalLevelElement.textContent = level;
                finalTimeElement.textContent = formatTime(gameTimer);
                gameOverScreen.style.display = 'flex';
            }

            function gameLoop() {
                if (!gameActive || isPaused) return;
                moveDrone();
                movePackages();
                checkCollisions();
                requestAnimationFrame(gameLoop);
            }

            function moveDrone() {
                if (leftPressed) {
                    droneX -= droneSpeed;
                    drone.style.transform = 'scaleX(-1)';
                }
                if (rightPressed) {
                    droneX += droneSpeed;
                    drone.style.transform = 'scaleX(1)';
                }
                if (droneX < 0) droneX = 0;
                if (droneX > gameWidth - 60) droneX = gameWidth - 60;
                drone.style.left = `${droneX}px`;
                drone.style.top = `${droneY}px`;
            }

            function updateGameTimer() {
                gameTimer++;
                updateTimerDisplay();
            }

            function updateTimerDisplay() {
                const minutes = Math.floor(gameTimer / 60);
                const seconds = gameTimer % 60;
                timerElement.textContent = `${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}`;
            }

            function formatTime(seconds) {
                const mins = Math.floor(seconds / 60);
                const secs = seconds % 60;
                return `${mins.toString().padStart(2, '0')}:${secs.toString().padStart(2, '0')}`;
            }

            function togglePause() {
                isPaused = !isPaused;
                if (isPaused) {
                    pauseScreen.style.display = 'flex';
                    clearInterval(gameTimerInterval);
                } else {
                    resumeGame();
                }
            }

            function resumeGame() {
                isPaused = false;
                pauseScreen.style.display = 'none';
                gameTimerInterval = setInterval(updateGameTimer, 1000);
                requestAnimationFrame(gameLoop);
            }

            function quitGame() {
                gameActive = false;
                isPaused = false;
                pauseScreen.style.display = 'none';
                clearInterval(gameTimerInterval);
                splashScreen.style.display = 'flex';
            }

            function retryLevel() {
                levelCompleteScreen.style.display = 'none';
                level--;
                startGame();
            }

            function nextLevel() {
                levelCompleteScreen.style.display = 'none';
                deliveriesNeeded = 5 + level;
                gameActive = true;
                isPaused = false;
                deliveriesCompleted = 0;
                gameTimer = 0;
                clearInterval(gameTimerInterval);
                gameTimerInterval = setInterval(updateGameTimer, 1000);
                updateTimerDisplay();
                packages = [];
                targets = [];
                obstacles = [];
                powerups = [];
                coins = [];
                packagesMissed = 0;
                packagesDropped = 0;
                levelStartTime = Date.now();
                document.querySelectorAll('.package, .target, .obstacle, .powerup, .coin, .explosion, .combo-indicator, .coin-indicator').forEach(el => {
                    el.remove();
                });
                levelElement.textContent = level;
                progressElement.style.width = '0%';
                createTarget();
                requestAnimationFrame(gameLoop);
            }

            function repositionElements() {
                createBuildings();
                document.querySelectorAll('.target').forEach(el => el.remove());
                targets = [];
                createTarget();
                document.querySelectorAll('.cloud').forEach(el => el.remove());
                createClouds();
                document.querySelectorAll('.star').forEach(el => el.remove());
                generateStars();
            }

            init();
        });
    </script>

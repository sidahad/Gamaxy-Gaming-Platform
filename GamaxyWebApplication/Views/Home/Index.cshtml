        .testimonial-card {
            background: #000; /* keeps card bg */
            border-radius: 1.5rem;
            padding: 25px;
            margin: 20px; /* gap between cards */
            position: relative;
        }


                /* Gradient border glow */
                .testimonial-card::before {
                    content: "";
                    position: absolute;
                    inset: -2px;
                    border-radius: 1.5rem;
                    padding: 2px;
                    background: linear-gradient(to right, #008dff, #D400FF, #008dff);
                    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
                    -webkit-mask-composite: xor;
                    mask-composite: exclude;
                    pointer-events: none;
                }

            .owl-item.active.center .testimonial-text {
                    background-color: transparent;
                }
        /* Gradient text */
        .text-gradient {
            background: linear-gradient(to right, #008dff, #D400FF, #008dff);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        /* Gradient border effect */
        .gradient-border {
            position: relative;
            background: black;
            border-radius: 15px;
            padding: 25px;
            overflow: hidden;
        }

            .gradient-border::before {
                content: "";
                position: absolute;
                inset: 0;
                padding: 5px;
                border-radius: 15px;
                background: linear-gradient(to right, #008dff, #D400FF, #008dff);
                -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
                -webkit-mask-composite: xor;
                mask-composite: exclude;
                z-index: -1;
            }

        .testimonial-text {
            color: #ddd;
            font-size: 16px;
            line-height: 1.6;
            text-align: center;
        }

        .testimonial-name {
            color: #fff;
            font-weight: 700;
            margin-top: 10px;
        }

        .testimonial-position {
            font-size: 14px;
            color: #008dff;
        }


        </style>

        <div class="section-full content-inner-2" style="background-color:black;">
            <div class="container">
                <div class="row">
                    <div class="col-lg-12">
                        <div class="sort-title clearfix text-center">
                            <h2 class="text-gradient title fw-bold"> What People Are Saying</h2>
                        </div>
                    </div>
                </div>

                <div class="section-content">
                    <div class="testimonial-six owl-carousel owl-btn-center-lr owl-btn-2 primary testimonial-13-area dots-style-3 owl-theme">

                        <!-- Testimonial Card -->
                        <div class="item">
                            <div class="testimonial-card">
                                <div class="testimonial-text">
                                    <i class="fas fa-quote-left text-gradient fa-2x mb-3"></i>
                                <p>
                                    “Gamaxy changed the way I discover games. The smooth design
                                    make it my go-to hub for gaming.”
                                </p>
                                </div>
                                <div class="testimonial-detail text-center">
                                <h5 class="testimonial-name m-t10 m-b5">Ayesha Khan</h5>
                                    <span class="testimonial-position text-primary">aye@gmail.com</span>
                                    <span>26-08-2025</span>
                                </div>
                            </div>
                        </div>

                        <!-- Repeat -->
                        <div class="item">
                            <div class="testimonial-card">
                                <div class="testimonial-text">
                                    <i class="fas fa-quote-left text-gradient fa-2x mb-3"></i>
                                <p>
                                    “I love how easy it is to upload and share my games on Gamaxy.
                                    It feels like the future of gaming platforms.”
                                </p>
                                </div>
                                <div class="testimonial-detail text-center">
                                <h5 class="testimonial-name m-t10 m-b5">Zain Malik</h5>
                                    <span class="testimonial-position text-primary">zain@gmail.com</span>
                                <span>26-08-2025</span>
                                </div>
                            </div>
                        </div>
                    <div class="item">
                        <div class="testimonial-card">
                            <div class="testimonial-text">
                                <i class="fas fa-quote-left text-gradient fa-2x mb-3"></i>
                                <p>
                                    “Gamaxy isn’t just a website — it’s a universe.
                                    The gradient style and futuristic feel make it stand out.”
                                </p>
                            </div>
                            <div class="testimonial-detail text-center">
                                <h5 class="testimonial-name m-t10 m-b5">Sara Ahmed</h5>
                                <span class="testimonial-position text-primary">saraah@gmail.com</span>
                                <span>26-08-2025</span>
                            </div>
                        </div>
                    </div>
                    @foreach (var player in Model)
                    {
                        if (player.Feedbackss != null && player.Feedbackss.Any())
                        {
                            foreach (var feedback in player.Feedbackss)
                            {
                        <div class="item">
                                    <div class="testimonial-card">
                                        <div class="mb-2">
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                if (i <= feedback.Rating)
                                                {
                                                    <i class="fa-solid fa-star text-warning"></i>
                                                }
                                                else
                                                {
                                                    <i class="fa-regular fa-star text-warning"></i>
                                                }
                                            }
                                        </div>
                                <div class="testimonial-text">
                                    <i class="fas fa-quote-left text-gradient fa-2x mb-3"></i>
                                                <p>"@feedback.Comment"</p>
                                </div>
                                <div class="testimonial-detail text-center">
                                            <h5 class="testimonial-name m-t10 m-b5">@feedback.Name</h5>
                                                <span class="testimonial-position text-primary">(@feedback.Email)</span>
                                                <span> @feedback.DateSubmitted.ToString("MMM dd, yyyy hh:mm tt")</span>

                                </div>
                            </div>
                        </div>
                                    }
                                    }
                                    }

                    </div>
                </div>
            </div>
        </div>

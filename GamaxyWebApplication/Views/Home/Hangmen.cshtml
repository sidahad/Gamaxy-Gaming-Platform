                { word: "ARTIFICIAL", hint: "Man-made intelligence in computers", definition: "The simulation of human intelligence processes by machines, especially computer systems, including learning, reasoning, and self-correction." }
            ],
            Sports: [
                { word: "SOCCER", hint: "Sport played with a round ball and feet", definition: "A team sport played between two teams of eleven players with a spherical ball. It is played by 250 million players in over 200 countries, making it the world's most popular sport." },
                { word: "CRICKET", hint: "Bat-and-ball game popular in Commonwealth countries", definition: "A bat-and-ball game played between two teams of eleven players on a field with a 22-yard pitch in the center, particularly popular in Commonwealth countries." },
                { word: "TENNIS", hint: "Racket sport played on a court", definition: "A racket sport that can be played individually against a single opponent (singles) or between two teams of two players each (doubles), using a felt-covered rubber ball and rackets." },
                { word: "HOCKEY", hint: "Sport played with sticks and a puck or ball", definition: "A family of sports in which two teams play against each other by trying to maneuver a ball or a puck into the opponent's goal using a hockey stick." },
                { word: "BASKETBALL", hint: "Sport where players shoot a ball through a hoop", definition: "A team sport in which two teams, most commonly of five players each, opposing one another on a rectangular court, compete with the primary objective of shooting a basketball through the defender's hoop." },
                { word: "SWIMMING", hint: "Sport performed in water", definition: "The sport or activity of propelling oneself through water using the limbs, often as a competitive sport or for exercise." },
                { word: "VOLLEYBALL", hint: "Team sport where you hit a ball over a net", definition: "A team sport in which two teams of six players are separated by a net, with the objective of scoring points by sending a ball over the net to ground it on the opponent's court." },
                { word: "GYMNASTICS", hint: "Sport involving physical exercises requiring balance, strength, and flexibility", definition: "A sport involving the performance of exercises requiring physical strength, flexibility, agility, coordination, balance, and grace." },
                { word: "BADMINTON", hint: "Racket sport played with a shuttlecock", definition: "A racket sport played using rackets to hit a shuttlecock across a net, either as singles or doubles." }
            ],
            Science: [
                { word: "GRAVITY", hint: "Force that attracts objects toward each other", definition: "The force that attracts a body toward the center of the earth, or toward any other physical body having mass." },
                { word: "MOLECULE", hint: "Group of atoms bonded together", definition: "A group of atoms bonded together, representing the smallest fundamental unit of a chemical compound that can take part in a chemical reaction." },
                { word: "QUANTUM", hint: "Smallest discrete unit of a phenomenon", definition: "The minimum amount of any physical entity involved in an interaction, especially in quantum mechanics where it represents the fundamental unit of energy and matter." },
                { word: "EVOLUTION", hint: "Process of biological change over time", definition: "The process by which different kinds of living organisms are thought to have developed and diversified from earlier forms during the history of the earth." },
                { word: "PHOTOSYNTHESIS", hint: "Process plants use to make food from sunlight", definition: "The process by which green plants and some other organisms use sunlight to synthesize foods with carbon dioxide and water, generating oxygen as a byproduct." },
                { word: "NEURON", hint: "Cell that transmits nerve impulses", definition: "A specialized cell transmitting nerve impulses; a nerve cell, consisting of a cell body, an axon, and dendrites." },
                { word: "ECOSYSTEM", hint: "Community of living organisms and their environment", definition: "A biological community of interacting organisms and their physical environment, functioning together as a unit." },
                { word: "RELATIVITY", hint: "Einstein's theory about space and time", definition: "The dependence of various physical phenomena on relative motion of the observer and the observed objects, especially regarding the nature and behavior of light, space, time, and gravity." },
                { word: "CHROMOSOME", hint: "Structure containing genetic information", definition: "A thread-like structure of nucleic acids and protein found in the nucleus of most living cells, carrying genetic information in the form of genes." }
            ],
            Movies: [
                { word: "AVATAR", hint: "Highest-grossing film about blue aliens", definition: "A 2009 science fiction film directed by James Cameron, set in the mid-22nd century when humans are colonizing a habitable moon called Pandora, inhabited by the Na'vi, a humanoid species." },
                { word: "INCEPTION", hint: "Dream within a dream concept film", definition: "A 2010 science fiction action film written and directed by Christopher Nolan, involving a thief who steals corporate secrets through the use of dream-sharing technology." },
                { word: "TITANIC", hint: "Film about a famous shipwreck", definition: "A 1997 American epic romance and disaster film directed by James Cameron, based on accounts of the sinking of the RMS Titanic in 1912." },
                { word: "MATRIX", hint: "Film about a simulated reality", definition: "A 1999 science fiction action film depicting a dystopian future in which humanity is unknowingly trapped inside a simulated reality called the Matrix." },
                { word: "GLADIATOR", hint: "Roman warrior film with Russell Crowe", definition: "A 2000 epic historical drama film directed by Ridley Scott, featuring Russell Crowe as a former Roman general who is forced to become a gladiator." },
                { word: "FROZEN", hint: "Animated film about a snow queen", definition: "A 2013 American 3D computer-animated musical fantasy film produced by Walt Disney Animation Studios, inspired by Hans Christian Andersen's fairy tale 'The Snow Queen'." },
                { word: "INTERSTELLAR", hint: "Space exploration film by Christopher Nolan", definition: "A 2014 epic science fiction film directed by Christopher Nolan, set in a dystopian future where humanity is struggling to survive, following a group of astronauts who travel through a wormhole in search of a new home for humanity." },
                { word: "PARASITE", hint: "Oscar-winning Korean film about social inequality", definition: "A 2019 South Korean black comedy thriller film directed by Bong Joon-ho, which follows a poor family who scheme to become employed by a wealthy family by infiltrating their household and posing as unrelated, highly qualified individuals." },
                { word: "JOKER", hint: "Origin story of Batman's arch-nemesis", definition: "A 2019 psychological thriller film directed by Todd Phillips, based on DC Comics characters, that follows the life of Arthur Fleck, a failed clown and stand-up comedian whose descent into insanity and nihilism inspires a violent counter-cultural revolution." }
            ],
            Food: [
                { word: "SUSHI", hint: "Japanese dish with vinegared rice", definition: "A Japanese dish consisting of small balls or rolls of vinegar-flavored cold cooked rice served with a garnish of raw fish, vegetables, or egg." },
                { word: "PIZZA", hint: "Italian dish with a round, flat base", definition: "A dish of Italian origin consisting of a flattened disk of bread dough topped with various ingredients such as tomato sauce, cheese, and often meat or vegetables, then baked." },
                { word: "CHOCOLATE", hint: "Sweet food made from cacao beans", definition: "A food preparation in the form of a paste or solid block made from roasted and ground cacao seeds, typically sweetened and eaten as confectionery." },
                { word: "PASTA", hint: "Italian food made from dough", definition: "A type of food typically made from an unleavened dough of wheat flour mixed with water or eggs, formed into sheets or other shapes, then cooked by boiling or baking." },
                { word: "CURRY", hint: "Spiced dish from Indian subcontinent", definition: "A dish of meat, vegetables, etc., cooked in an Indian-style sauce of strong spices and typically served with rice." },
                { word: "HAMBURGER", hint: "Sandwich with a patty of ground beef", definition: "A sandwich consisting of one or more cooked patties of ground meat, usually beef, placed inside a sliced bread roll or bun, often served with various condiments and toppings." },
                { word: "CROISSANT", hint: "French crescent-shaped pastry", definition: "A French crescent-shaped roll made of sweet flaky pastry, often eaten for breakfast." },
                { word: "GUACAMOLE", hint: "Avocado-based dip from Mexico", definition: "A dip made from mashed avocados, typically with added lime juice, onion, tomato, garlic, and seasonings, originating from Mexico." },
                { word: "TIRAMISU", hint: "Italian coffee-flavored dessert", definition: "An Italian dessert consisting of layers of sponge cake soaked in coffee and brandy or liqueur with powdered chocolate and mascarpone cheese." }
            ]
        };

        // Game variables
        let word = "";
        let wordObj = null;
        let guessed = [];
        let wrongGuesses = 0;
        let score = 0;
        let highScore = localStorage.getItem("hangmanHighScore") || 0;
        let timer = 60;
        let timerInterval;
        let streak = 0;
        let maxStreak = localStorage.getItem("hangmanMaxStreak") || 0;
        let hintsUsed = 0;
        let difficulty = "easy";
        let maxWrong = 6;
        let gameActive = false;
        let totalGames = parseInt(localStorage.getItem("hangmanTotalGames")) || 0;
        let gamesWon = parseInt(localStorage.getItem("hangmanGamesWon")) || 0;
        let totalScore = parseInt(localStorage.getItem("hangmanTotalScore")) || 0;
        let letterPoints = 10;
        let animationFrameId;
        let hangmanAnimationProgress = 0;

        // Initialize the game
        function init() {
            // Update high score display
            highScoreEl.textContent = highScore;
            streakEl.textContent = streak;

            // Create keyboard
            createKeyboard();

            // Set theme from localStorage or default
            const savedTheme = localStorage.getItem("hangmanTheme") || "dark";
            themeSelect.value = savedTheme;
            applyTheme(savedTheme);

            // Set category from localStorage or default
            const savedCategory = localStorage.getItem("hangmanCategory") || "Animals";
            categorySelect.value = savedCategory;

            // Set difficulty from localStorage or default
            const savedDifficulty = localStorage.getItem("hangmanDifficulty") || "easy";
            difficultySelect.value = savedDifficulty;
            setDifficulty(savedDifficulty);

            // Start a new game
            restartGame();
        }

        // Create keyboard
        function createKeyboard() {
            const letters = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";
            keyboardEl.innerHTML = "";

            for (let letter of letters) {
                const key = document.createElement("button");
                key.classList.add("key");
                key.textContent = letter;
                key.addEventListener("click", () => handleGuess(letter));
                keyboardEl.appendChild(key);
            }
        }

        // Apply theme
        function applyTheme(theme) {
            document.body.className = theme === "dark" ? "" : `theme-${theme}`;
            localStorage.setItem("hangmanTheme", theme);

            // Redraw hangman with new theme colors
            if (gameActive) {
                drawHangman(wrongGuesses);
            }
        }

        // Set difficulty
        function setDifficulty(level) {
            difficulty = level;
            localStorage.setItem("hangmanDifficulty", level);

            // Update difficulty indicator
            const dots = difficultyIndicator.querySelectorAll(".difficulty-dot");
            dots.forEach(dot => dot.classList.remove("active", "easy", "medium", "hard"));

            switch(level) {
                case "easy":
                    dots[0].classList.add("active", "easy");
                    letterPoints = 10;
                    timer = 60;
                    break;
                case "medium":
                    dots[0].classList.add("active", "medium");
                    dots[1].classList.add("active", "medium");
                    letterPoints = 20;
                    timer = 45;
                    break;
                case "hard":
                    dots.forEach(dot => dot.classList.add("active", "hard"));
                    letterPoints = 30;
                    timer = 30;
                    break;
            }

            timerEl.textContent = timer;
        }

        // Pick a random word based on category and difficulty
        function pickWord() {
            const category = categorySelect.value;
            const words = wordBank[category];

            // Filter words based on difficulty
            let filteredWords = words;
            if (difficulty === "easy") {
                filteredWords = words.filter(w => w.word.length <= 6);
            } else if (difficulty === "medium") {
                filteredWords = words.filter(w => w.word.length > 4 && w.word.length <= 8);
            } else {
                filteredWords = words.filter(w => w.word.length > 6);
            }

            // If no words match the criteria, use all words
            if (filteredWords.length === 0) {
                filteredWords = words;
            }

            const randomIndex = Math.floor(Math.random() * filteredWords.length);
            return filteredWords[randomIndex];
        }

        // Display the word with blanks for unguessed letters
        function displayWord() {
            wordDisplay.innerHTML = "";
            let correctCount = 0;

            for (let i = 0; i < wordObj.word.length; i++) {
                const letter = wordObj.word[i];
                const letterBox = document.createElement("div");
                letterBox.classList.add("letter-box");

                if (letter === " ") {
                    letterBox.classList.add("space");
                    correctCount++;
                } else if (guessed.includes(letter)) {
                    letterBox.textContent = letter;
                    letterBox.classList.add("revealed");
                    correctCount++;
                }

                wordDisplay.appendChild(letterBox);
            }

            // Check if all letters are guessed
            if (correctCount === wordObj.word.replace(/ /g, "").length) {
                gameWon();
            }
        }

        // Handle letter guess
        function handleGuess(letter) {
            if (!gameActive) return;

            // If already guessed, do nothing
            if (guessed.includes(letter)) return;

            // Add to guessed letters
            guessed.push(letter);
            updateGuessedLettersDisplay(letter, wordObj.word.includes(letter));

            // Find all keys with this letter
            const keys = keyboardEl.querySelectorAll(".key");
            keys.forEach(key => {
                if (key.textContent === letter) {
                    if (wordObj.word.includes(letter)) {
                        key.classList.add("correct");
                        playSound("correct");

                        // Calculate points based on letter frequency
                        const letterCount = (wordObj.word.match(new RegExp(letter, "g")) || []).length;
                        addScore(letterPoints * letterCount);

                        // Reveal letters with animation
                        const letterBoxes = wordDisplay.querySelectorAll(".letter-box:not(.space)");
                        let revealCount = 0;

                        for (let i = 0; i < wordObj.word.length; i++) {
                            if (wordObj.word[i] === letter) {
                                setTimeout(() => {
                                    letterBoxes[i - revealCount].textContent = letter;
                                    letterBoxes[i - revealCount].classList.add("revealed");
                                }, 150 * (i - revealCount));
                            } else if (wordObj.word[i] === " ") {
                                revealCount++;
                            }
                        }
                    } else {
                        key.classList.add("wrong");
                        wrongGuess();
                    }
                    key.classList.add("used");
                }
            });

            // Check if word is complete
            if (!wordObj.word.split("").some(letter => !guessed.includes(letter) && letter !== " ")) {
                gameWon();
            }
        }

        // Update guessed letters display
        function updateGuessedLettersDisplay(letter, isCorrect) {
            const letterEl = document.createElement("div");
            letterEl.classList.add("guessed-letter");
            letterEl.classList.add(isCorrect ? "correct" : "wrong");
            letterEl.textContent = letter;
            guessedLettersEl.appendChild(letterEl);
        }

        // Handle wrong guess
        function wrongGuess() {
            wrongGuesses++;
            playSound("wrong");

            // Animate hangman drawing
            animateHangman(wrongGuesses - 1, wrongGuesses);

            // Shake the canvas
            canvas.classList.add("shake");
            setTimeout(() => canvas.classList.remove("shake"), 500);

            if (wrongGuesses >= maxWrong) {
                gameLost();
            }
        }

        // Animate hangman drawing
        function animateHangman(fromStage, toStage) {
            if (animationFrameId) {
                cancelAnimationFrame(animationFrameId);
            }

            hangmanAnimationProgress = 0;

            function animate() {
                hangmanAnimationProgress += 0.05;

                if (hangmanAnimationProgress >= 1) {
                    hangmanAnimationProgress = 1;
                    drawHangman(toStage);
                    cancelAnimationFrame(animationFrameId);
                    return;
                }

                // Draw intermediate stage
                drawHangman(fromStage + hangmanAnimationProgress);
                animationFrameId = requestAnimationFrame(animate);
            }

            animate();
        }

        // Draw hangman based on wrong guesses
        function drawHangman(stage) {
            ctx.clearRect(0, 0, canvas.width, canvas.height);

            // Get hangman color from CSS variable
            const hangmanColor = getComputedStyle(document.documentElement).getPropertyValue('--success').trim();

            ctx.lineWidth = 6;
            ctx.strokeStyle = hangmanColor;
            ctx.lineCap = "round";
            ctx.lineJoin = "round";

            // Draw gallows
            ctx.beginPath();
            ctx.moveTo(80, 380);
            ctx.lineTo(320, 380);
            ctx.stroke();

            if (stage >= 0.1) {
                ctx.beginPath();
                ctx.moveTo(120, 380);
                ctx.lineTo(120, 80);
                const height = Math.min(300, 300 * ((stage - 0.1) / 0.2));
                ctx.lineTo(120, 380 - height);
                ctx.stroke();
            }

            if (stage >= 0.3) {
                ctx.beginPath();
                ctx.moveTo(120, 80);
                const width = Math.min(150, 150 * ((stage - 0.3) / 0.2));
                ctx.lineTo(120 + width, 80);
                ctx.stroke();
            }

            if (stage >= 0.5) {
                ctx.beginPath();
                ctx.moveTo(270, 80);
                const height = Math.min(50, 50 * ((stage - 0.5) / 0.1));
                ctx.lineTo(270, 80 + height);
                ctx.stroke();
            }

            // Draw hangman parts based on wrong guesses
            if (stage >= 0.6) {
                // Head
                ctx.beginPath();
                ctx.arc(270, 160, Math.min(30, 30 * ((stage - 0.6) / 0.1)), 0, Math.PI * 2);
                ctx.stroke();
            }

            if (stage >= 0.7) {
                // Body
                ctx.beginPath();
                ctx.moveTo(270, 190);
                const height = Math.min(80, 80 * ((stage - 0.7) / 0.1));
                ctx.lineTo(270, 190 + height);
                ctx.stroke();
            }

            if (stage >= 0.8) {
                // Left arm
                ctx.beginPath();
                ctx.moveTo(270, 220);
                const length = Math.min(40, 40 * ((stage - 0.8) / 0.05));
                ctx.lineTo(270 - length, 220 + length * 0.8);
                ctx.stroke();
            }

            if (stage >= 0.85) {
                // Right arm
                ctx.beginPath();
                ctx.moveTo(270, 220);
                const length = Math.min(40, 40 * ((stage - 0.85) / 0.05));
                ctx.lineTo(270 + length, 220 + length * 0.8);
                ctx.stroke();
            }

            if (stage >= 0.9) {
                // Left leg
                ctx.beginPath();
                ctx.moveTo(270, 270);
                const length = Math.min(50, 50 * ((stage - 0.9) / 0.05));
                ctx.lineTo(270 - length * 0.5, 270 + length);
                ctx.stroke();
            }

            if (stage >= 0.95) {
                // Right leg
                ctx.beginPath();
                ctx.moveTo(270, 270);
                const length = Math.min(50, 50 * ((stage - 0.95) / 0.05));
                ctx.lineTo(270 + length * 0.5, 270 + length);
                ctx.stroke();

                // Face details for complete hangman
                if (stage >= 1) {
                    // X eyes for dead hangman
                    ctx.beginPath();
                    ctx.moveTo(260, 155);
                    ctx.lineTo(270, 165);
                    ctx.moveTo(270, 155);
                    ctx.lineTo(260, 165);
                    ctx.stroke();

                    ctx.beginPath();
                    ctx.moveTo(270, 155);
                    ctx.lineTo(280, 165);
                    ctx.moveTo(280, 155);
                    ctx.lineTo(270, 165);
                    ctx.stroke();

                    // Sad mouth
                    ctx.beginPath();
                    ctx.arc(270, 175, 10, 0, Math.PI, true);
                    ctx.stroke();
                }
            }
        }

        // Game won
        function gameWon() {
            if (!gameActive) return;
            gameActive = false;
            clearInterval(timerInterval);

            // Bonus points for remaining time and fewer wrong guesses
            const timeBonus = timer * 5;
            const accuracyBonus = (maxWrong - wrongGuesses) * 50;
            const difficultyBonus = difficulty === "easy" ? 0 : (difficulty === "medium" ? 100 : 250);
            const totalBonus = timeBonus + accuracyBonus + difficultyBonus;

            addScore(totalBonus);

            // Update streak
            streak++;
            streakEl.textContent = streak;
            streakBadge.textContent = streak;
            streakBadge.classList.add("active");
            setTimeout(() => streakBadge.classList.remove("active"), 3000);

            if (streak > maxStreak) {
                maxStreak = streak;
                localStorage.setItem("hangmanMaxStreak", maxStreak);
            }

            // Update stats
            totalGames++;
            gamesWon++;
            totalScore += score;
            localStorage.setItem("hangmanTotalGames", totalGames);
            localStorage.setItem("hangmanGamesWon", gamesWon);
            localStorage.setItem("hangmanTotalScore", totalScore);

            // Show definition
            showDefinition();

            // Show success message
            messageEl.innerHTML = `<span>Excellent! You guessed the word correctly!</span>`;
            messageEl.className = "message-display success";

            // Create confetti effect
            createConfetti();

            // Play success sound
            playSound("win");

            // Show modal after a delay
            setTimeout(() => {
                modalTitle.textContent = "Victory!";
                modalTitle.style.color = "var(--success)";
                modalMessage.innerHTML = `
                    <p>You guessed <strong>${wordObj.word}</strong> correctly!</p>
                    <div class="stats-grid">
                        <div class="stats-item">
                            <div class="stats-item-label">Score</div>
                            <div class="stats-item-value">${score}</div>
                        </div>
                        <div class="stats-item">
                            <div class="stats-item-label">Streak</div>
                            <div class="stats-item-value">${streak}</div>
                        </div>
                        <div class="stats-item">
                            <div class="stats-item-label">Time Bonus</div>
                            <div class="stats-item-value">+${timeBonus}</div>
                        </div>
                        <div class="stats-item">
                            <div class="stats-item-label">Accuracy Bonus</div>
                            <div class="stats-item-value">+${accuracyBonus}</div>
                        </div>
                    </div>
                `;
                gameOverModal.classList.add("active");
            }, 2000);
        }

        // Game lost
        function gameLost() {
            if (!gameActive) return;
            gameActive = false;
            clearInterval(timerInterval);

            // Reset streak
            streak = 0;
            streakEl.textContent = streak;

            // Update stats
            totalGames++;
            localStorage.setItem("hangmanTotalGames", totalGames);

            // Reveal the word
            const letterBoxes = wordDisplay.querySelectorAll(".letter-box:not(.space)");
            let nonSpaceIndex = 0;

            for (let i = 0; i < wordObj.word.length; i++) {
                const letter = wordObj.word[i];
                if (letter !== " ") {
                    if (!guessed.includes(letter)) {
                        setTimeout(() => {
                            letterBoxes[nonSpaceIndex].textContent = letter;
                            letterBoxes[nonSpaceIndex].classList.add("revealed", "wrong");
                        }, 100 * nonSpaceIndex);
                    }
                    nonSpaceIndex++;
                }
            }

            // Show definition
            showDefinition();

            // Show failure message
            messageEl.innerHTML = `<span>Game Over! The word was ${wordObj.word}</span>`;
            messageEl.className = "message-display error";

            // Play failure sound
            playSound("lose");

            // Show modal after a delay
            setTimeout(() => {
                modalTitle.textContent = "Game Over";
                modalTitle.style.color = "var(--danger)";
                modalMessage.innerHTML = `
                    <p>The word was <strong>${wordObj.word}</strong></p>
                    <div class="stats-grid">
                        <div class="stats-item">
                            <div class="stats-item-label">Final Score</div>
                            <div class="stats-item-value">${score}</div>
                        </div>
                        <div class="stats-item">
                            <div class="stats-item-label">High Score</div>
                            <div class="stats-item-value">${highScore}</div>
                        </div>
                    </div>
                    <p style="margin-top: 1rem;">Better luck next time!</p>
                `;
                gameOverModal.classList.add("active");
            }, 2000);
        }

        // Show definition
        function showDefinition() {
            definitionText.textContent = wordObj.definition;
            definitionSection.classList.add("active");
        }

        // Add score
        function addScore(points) {
            score += points;
            scoreEl.textContent = score;

            // Update high score if needed
            if (score > highScore) {
                highScore = score;
                highScoreEl.textContent = highScore;
                localStorage.setItem("hangmanHighScore", highScore);

                // Highlight high score
                highScoreEl.classList.add("pulse");
                setTimeout(() => highScoreEl.classList.remove("pulse"), 1000);
            }

            // Animate score
            scoreEl.classList.add("pulse");
            setTimeout(() => scoreEl.classList.remove("pulse"), 500);
        }

        // Get hint
        function getHint() {
            if (!gameActive || hintsUsed > 0) return;

            // Deduct points for using hint
            addScore(-50);
            hintsUsed++;

            // Show hint
            hintText.textContent = wordObj.hint;
            hintText.classList.add("active");

            // Disable hint button
            hintBtn.disabled = true;

            // Play hint sound
            playSound("hint");

            // Show message
            messageEl.innerHTML = "<span>Hint used! -50 points</span>";
            messageEl.className = "message-display info";
            setTimeout(() => {
                messageEl.innerHTML = "";
                messageEl.className = "message-display";
            }, 3000);
        }

        // Start timer
        function startTimer() {
            clearInterval(timerInterval);
            timer = difficulty === "easy" ? 60 : (difficulty === "medium" ? 45 : 30);
            timerEl.textContent = timer;
            timerBar.style.width = "100%";
            timerBar.classList.remove("warning");

            timerInterval = setInterval(() => {
                timer--;
                timerEl.textContent = timer;
                timerBar.style.width = `${(timer / (difficulty === "easy" ? 60 : (difficulty === "medium" ? 45 : 30))) * 100}%`;

                if (timer <= 10) {
                    timerBar.classList.add("warning");
                    if (timer <= 5) {
                        playSound("tick");
                    }
                } else {
                    timerBar.classList.remove("warning");
                }

                if (timer <= 0) {
                    clearInterval(timerInterval);
                    gameLost();
                }
            }, 1000);
        }

        // Restart game
        function restartGame() {
            // Reset game state
            gameActive = true;
            wordObj = pickWord();
            guessed = [];
            wrongGuesses = 0;
            hintsUsed = 0;
            score = 0;
            scoreEl.textContent = "0";

            // Clear UI
            guessedLettersEl.innerHTML = "";
            messageEl.innerHTML = "";
            messageEl.className = "message-display";
            hintText.textContent = "";
            hintText.classList.remove("active");
            hintBtn.disabled = false;
            definitionSection.classList.remove("active");

            // Reset keyboard
            const keys = keyboardEl.querySelectorAll(".key");
            keys.forEach(key => {
                key.classList.remove("used", "correct", "wrong");
                key.disabled = false;
            });

            // Draw empty gallows
            drawHangman(0);

            // Display word
            displayWord();

            // Start timer
            startTimer();

            // Hide modal if open
            gameOverModal.classList.remove("active");

            // Save category preference
            localStorage.setItem("hangmanCategory", categorySelect.value);

            // Log for debugging
            console.log("New word:", wordObj.word);
        }

        // Play sound effects
        function playSound(type) {
            try {
                const audioContext = new (window.AudioContext || window.webkitAudioContext)();
                const gainNode = audioContext.createGain();
                gainNode.connect(audioContext.destination);

                switch(type) {
                    case "correct":
                        const correctOsc = audioContext.createOscillator();
                        correctOsc.connect(gainNode);
                        correctOsc.type = "sine";
                        correctOsc.frequency.setValueAtTime(800, audioContext.currentTime);
                        correctOsc.frequency.exponentialRampToValueAtTime(1200, audioContext.currentTime + 0.1);
                        gainNode.gain.setValueAtTime(0.3, audioContext.currentTime);
                        gainNode.gain.exponentialRampToValueAtTime(0.01, audioContext.currentTime + 0.3);
                        correctOsc.start();
                        correctOsc.stop(audioContext.currentTime + 0.3);
                        break;

                    case "wrong":
                        const wrongOsc = audioContext.createOscillator();
                        wrongOsc.connect(gainNode);
                        wrongOsc.type = "sawtooth";
                        wrongOsc.frequency.setValueAtTime(200, audioContext.currentTime);
                        wrongOsc.frequency.exponentialRampToValueAtTime(100, audioContext.currentTime + 0.2);
                        gainNode.gain.setValueAtTime(0.3, audioContext.currentTime);
                        gainNode.gain.exponentialRampToValueAtTime(0.01, audioContext.currentTime + 0.3);
                        wrongOsc.start();
                        wrongOsc.stop(audioContext.currentTime + 0.3);
                        break;

                    case "win":
                        // First note
                        const winOsc1 = audioContext.createOscillator();
                        const winGain1 = audioContext.createGain();
                        winOsc1.connect(winGain1);
                        winGain1.connect(audioContext.destination);
                        winOsc1.type = "sine";
                        winOsc1.frequency.setValueAtTime(500, audioContext.currentTime);
                        winOsc1.frequency.exponentialRampToValueAtTime(800, audioContext.currentTime + 0.1);
                        winGain1.gain.setValueAtTime(0.3, audioContext.currentTime);
                        winGain1.gain.exponentialRampToValueAtTime(0.01, audioContext.currentTime + 0.4);
                        winOsc1.start();
                        winOsc1.stop(audioContext.currentTime + 0.4);

                        // Second note
                        setTimeout(() => {
                            const winOsc2 = audioContext.createOscillator();
                            const winGain2 = audioContext.createGain();
                            winOsc2.connect(winGain2);
                            winGain2.connect(audioContext.destination);
                            winOsc2.type = "sine";
                            winOsc2.frequency.setValueAtTime(800, audioContext.currentTime);
                            winOsc2.frequency.exponentialRampToValueAtTime(1200, audioContext.currentTime + 0.2);
                            winGain2.gain.setValueAtTime(0.3, audioContext.currentTime);
                            winGain2.gain.exponentialRampToValueAtTime(0.01, audioContext.currentTime + 0.4);
                            winOsc2.start();
                            winOsc2.stop(audioContext.currentTime + 0.4);
                        }, 200);

                        // Third note
                        setTimeout(() => {
                            const winOsc3 = audioContext.createOscillator();
                            const winGain3 = audioContext.createGain();
                            winOsc3.connect(winGain3);
                            winGain3.connect(audioContext.destination);
                            winOsc3.type = "sine";
                            winOsc3.frequency.setValueAtTime(1200, audioContext.currentTime);
                            winOsc3.frequency.exponentialRampToValueAtTime(1600, audioContext.currentTime + 0.2);
                            winGain3.gain.setValueAtTime(0.3, audioContext.currentTime);
                            winGain3.gain.exponentialRampToValueAtTime(0.01, audioContext.currentTime + 0.6);
                            winOsc3.start();
                            winOsc3.stop(audioContext.currentTime + 0.6);
                        }, 400);
                        break;

                    case "lose":
                        // First note
                        const loseOsc1 = audioContext.createOscillator();
                        const loseGain1 = audioContext.createGain();
                        loseOsc1.connect(loseGain1);
                        loseGain1.connect(audioContext.destination);
                        loseOsc1.type = "sawtooth";
                        loseOsc1.frequency.setValueAtTime(400, audioContext.currentTime);
                        loseOsc1.frequency.exponentialRampToValueAtTime(200, audioContext.currentTime + 0.2);
                        loseGain1.gain.setValueAtTime(0.3, audioContext.currentTime);
                        loseGain1.gain.exponentialRampToValueAtTime(0.01, audioContext.currentTime + 0.4);
                        loseOsc1.start();
                        loseOsc1.stop(audioContext.currentTime + 0.4);

                        // Second note
                        setTimeout(() => {
                            const loseOsc2 = audioContext.createOscillator();
                            const loseGain2 = audioContext.createGain();
                            loseOsc2.connect(loseGain2);
                            loseGain2.connect(audioContext.destination);
                            loseOsc2.type = "sawtooth";
                            loseOsc2.frequency.setValueAtTime(300, audioContext.currentTime);
                            loseOsc2.frequency.exponentialRampToValueAtTime(100, audioContext.currentTime + 0.3);
                            loseGain2.gain.setValueAtTime(0.3, audioContext.currentTime);
                            loseGain2.gain.exponentialRampToValueAtTime(0.01, audioContext.currentTime + 0.5);
                            loseOsc2.start();
                            loseOsc2.stop(audioContext.currentTime + 0.5);
                        }, 300);
                        break;

                    case "hint":
                        const hintOsc = audioContext.createOscillator();
                        hintOsc.connect(gainNode);
                        hintOsc.type = "triangle";
                        hintOsc.frequency.setValueAtTime(600, audioContext.currentTime);
                        hintOsc.frequency.exponentialRampToValueAtTime(900, audioContext.currentTime + 0.1);
                        hintOsc.frequency.exponentialRampToValueAtTime(600, audioContext.currentTime + 0.2);
                        gainNode.gain.setValueAtTime(0.2, audioContext.currentTime);
                        gainNode.gain.exponentialRampToValueAtTime(0.01, audioContext.currentTime + 0.3);
                        hintOsc.start();
                        hintOsc.stop(audioContext.currentTime + 0.3);
                        break;

                    case "tick":
                        const tickOsc = audioContext.createOscillator();
                        tickOsc.connect(gainNode);
                        tickOsc.type = "sine";
                        tickOsc.frequency.setValueAtTime(800, audioContext.currentTime);
                        gainNode.gain.setValueAtTime(0.1, audioContext.currentTime);
                        gainNode.gain.exponentialRampToValueAtTime(0.01, audioContext.currentTime + 0.1);
                        tickOsc.start();
                        tickOsc.stop(audioContext.currentTime + 0.1);
                        break;
                }
            } catch (e) {
                console.log("Audio not available");
            }
        }

        // Create confetti effect
        function createConfetti() {
            const colors = ["#ff0000", "#00ff00", "#0000ff", "#ffff00", "#ff00ff", "#00ffff", "#ff8800", "#00ff88"];

            for (let i = 0; i < 100; i++) {
                const confetti = document.createElement("div");
                confetti.classList.add("confetti");
                confetti.style.left = `${Math.random() * 100}%`;
                confetti.style.backgroundColor = colors[Math.floor(Math.random() * colors.length)];
                confetti.style.width = `${Math.random() * 8 + 4}px`;
                confetti.style.height = `${Math.random() * 8 + 4}px`;
                confetti.style.animationDelay = `${Math.random() * 2}s`;
                confetti.style.animationDuration = `${Math.random() * 2 + 2}s`;

                document.body.appendChild(confetti);

                // Remove after animation completes
                setTimeout(() => {
                    confetti.remove();
                }, 5000);
            }
        }

        // Show stats
        function showStats() {
            const winRate = totalGames > 0 ? Math.round((gamesWon / totalGames) * 100) : 0;

            modalTitle.textContent = "Your Statistics";
            modalTitle.style.color = "var(--info)";
            modalMessage.innerHTML = `
                <div class="stats-grid">
                    <div class="stats-item">
                        <div class="stats-item-label">Games Played</div>
                        <div class="stats-item-value">${totalGames}</div>
                    </div>
                    <div class="stats-item">
                        <div class="stats-item-label">Games Won</div>
                        <div class="stats-item-value">${gamesWon}</div>
                    </div>
                    <div class="stats-item">
                        <div class="stats-item-label">Win Rate</div>
                        <div class="stats-item-value">${winRate}%</div>
                    </div>
                    <div class="stats-item">
                        <div class="stats-item-label">Max Streak</div>
                        <div class="stats-item-value">${maxStreak}</div>
                    </div>
                </div>
                <div style="margin-top: 1rem;">
                    <div style="margin-bottom: 0.5rem;">Total Score: ${totalScore}</div>
                    <div class="progress-bar-container">
                        <div class="progress-bar" style="width: ${winRate}%"></div>
                    </div>
                </div>
            `;
        }

        // Handle window resize
        function handleResize() {
            // Redraw hangman canvas on resize
            if (gameActive) {
                drawHangman(wrongGuesses);
            }
        }

        // Event listeners
        themeSelect.addEventListener("change", () => applyTheme(themeSelect.value));
        difficultySelect.addEventListener("change", () => setDifficulty(difficultySelect.value));
        restartBtn.addEventListener("click", restartGame);
        hintBtn.addEventListener("click", getHint);
        playAgainBtn.addEventListener("click", restartGame);
        viewStatsBtn.addEventListener("click", showStats);
        window.addEventListener("resize", handleResize);

        // Keyboard event listener
        document.addEventListener("keydown", (e) => {
            if (!gameActive) return;

            const key = e.key.toUpperCase();
            if (/^[A-Z]$/.test(key)) {
                handleGuess(key);
            }
        });

        // Modal close on background click
        gameOverModal.addEventListener("click", (e) => {
            if (e.target === gameOverModal) {
                gameOverModal.classList.remove("active");
            }
        });

        // Prevent scrolling on mobile
        document.addEventListener("touchmove", (e) => {
            if (e.target.closest('.game-info-section') || e.target.closest('.modal')) {
                return; // Allow scrolling in these areas
            }
            e.preventDefault();
        }, { passive: false });

        // Initialize the game
        init();
    </script>
</body>

@model GameUploadViewModel;
@{
    ViewData["Title"] = "PremiumGames Page";
}
<!-- Swiper CSS -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@10/swiper-bundle.min.css" />

<!-- Swiper JS -->
<script src="https://cdn.jsdelivr.net/npm/swiper@10/swiper-bundle.min.js"></script>
<!-- Bootstrap 5.3 CSS -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
    body {
        background-color: black;
    }

    .bg-white {
        background-color: #000000 !important;
    }

    .step-card {
        width: 180px;
        padding: 20px;
        border-radius: 10px;
        position: relative;
        text-align: center;
        color: white;
        min-height: 160px;
        transition: transform 0.3s ease;
        clip-path: polygon(0 0, 90% 0, 100% 50%, 90% 100%, 0 100%, 10% 50%);
    }

        .step-card .icon {
            font-size: 2rem;
            margin-bottom: 10px;
        }

        .step-card:hover {
            transform: scale(1.05);
        }

    .step-3d {
        width: 190px;
        padding: 20px;
        color: white;
        text-align: center;
        position: relative;
        border-radius: 10px;
        clip-path: polygon(0 0, 90% 0, 100% 50%, 90% 100%, 0 100%, 10% 50%);
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.4);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        background: linear-gradient(145deg, #2c2c2c, #1c1c1c);
    }

        .step-3d:hover {
            transform: translateY(-5px) scale(1.03);
            box-shadow: 0 12px 25px rgba(0, 0, 0, 0.6);
        }

        .step-3d .icon {
            font-size: 2rem;
            margin-bottom: 10px;
        }

    .bg-blue {
        background: linear-gradient(135deg, #008dff, #0056b3);
    }

    .bg-purple {
        background: linear-gradient(135deg, #D400FF, #8e00b3);
    }

    .bg-green {
        background: linear-gradient(135deg, #008dff, #0056b3);
    }

    .bg-yellow {
        background: linear-gradient(135deg, #D400FF, #8e00b3);
    }

    .bg-orange {
        background: linear-gradient(135deg, #008dff, #0056b3);
    }

    .bg-pink {
        background: linear-gradient(135deg, #D400FF, #8e00b3);
    }

    .launch-game-section {
        background: linear-gradient(135deg, #1a1a1a, #121212);
        border-top: 2px solid #008dff;
        border-bottom: 2px solid #D400FF;
        box-shadow: inset 0 0 60px rgba(255, 255, 255, 0.03);
    }

        .launch-game-section h2 {
            font-size: 2.5rem;
            color: #fff;
            text-shadow: 0 0 6px rgba(0, 141, 255, 0.6);
        }

        .launch-game-section p {
            font-size: 1.1rem;
            color: #ccc;
            max-width: 600px;
        }

    .text-glow {
        text-shadow: 0 0 10px #008dff, 0 0 20px #D400FF;
    }

    .launch-btn {
        display: inline-block;
        padding: 14px 30px;
        font-size: 1.1rem;
        color: white;
        background: linear-gradient(to right, #008dff, #D400FF, #008dff);
        border: none;
        border-radius: 10px;
        font-weight: 600;
        text-decoration: none;
        box-shadow: 0 0 15px rgba(0, 141, 255, 0.3);
        transition: all 0.3s ease-in-out;
    }

        .launch-btn:hover {
            transform: scale(1.05);
            box-shadow: 0 0 25px rgba(0, 141, 255, 0.7), 0 0 20px rgba(212, 0, 255, 0.5);
        }

        .launch-btn::after {
            content: "";
            position: absolute;
            top: 0;
            left: -75%;
            width: 150%;
            height: 100%;
            background: linear-gradient(120deg, transparent, rgba(255, 255, 255, 0.3), transparent);
            transform: skewX(-25deg);
            animation: light-flash 2.5s infinite linear;
            z-index: 0;
        }

    @@keyframes light-flash {
        0% {
            left: -75%;
        }

        100% {
            left: 100%;
        }
    }

    .glow-container {
        display: inline-block;
        position: relative;
    }

    .glowing-img {
        border-radius: 12px;
        box-shadow: 0 0 30px rgba(0, 141, 255, 0.5), 0 0 60px rgba(212, 0, 255, 0.3);
        transition: 0.3s ease-in-out;
    }

        .glowing-img:hover {
            transform: scale(1.03);
            box-shadow: 0 0 50px rgba(0, 141, 255, 0.6), 0 0 80px rgba(212, 0, 255, 0.4);
        }

    .glow-effect-bg {
        content: "";
        position: absolute;
        top: 30%;
        right: 0;
        width: 300px;
        height: 300px;
        background: radial-gradient(circle, rgba(255, 255, 255, 0.15), transparent 70%);
        filter: blur(60px);
        z-index: 1;
    }

    .section-full {
        padding: 60px 0;
    }

    .section-head {
        margin-bottom: 40px;
    }

        .section-head h2 {
            font-size: 32px;
            margin-bottom: 10px;
            color: #333;
        }

        .section-head p {
            color: #555;
            font-size: 16px;
            max-width: 600px;
            margin: 0 auto;
        }

    .game-category {
        background: black;
        border-radius: 12px;
        padding: 20px 10px;
        transition: 0.3s ease-in-out;
        cursor: pointer;
        height: 120px;
        border: 4px solid #008dff;
        width: 100px;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.05);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
    }

        .game-category i {
            font-size: 30px;
            color: #D400FF;
            margin-bottom: 10px;
            transition: color 0.3s ease;
        }

        .game-category span {
            font-size: 14px;
            color: #ffffff;
            font-weight: 600;
        }

        .game-category:hover {
            background: linear-gradient(135deg, #008dff, #d400ff);
            transform: translateY(-5px);
        }

            .game-category:hover i,
            .game-category:hover span {
                color: #fff;
            }

    .category-slider .swiper-slide {
        width: auto !important;
        padding: 10px;
    }

    .swiper-slide.active .game-category {
        background: linear-gradient(45deg, #008dff, #D400FF);
        color: #fff;
        transition: 0.3s;
    }

    .card-container {
        transition: opacity 0.3s ease, transform 0.3s ease; /* Smooth transition for filtering */
    }

        .card-container[style*="display: none"] {
            opacity: 0;
            transform: scale(0.95);
        }

    .card-container {
        opacity: 1;
        transform: scale(1);
    }

    .no-games-message {
        color: #ffffff;
        font-size: 1.2rem;
        margin-top: 20px;
    }

    .carousel {
        position: relative;
    }

    .carousel-item.body {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 100%;
        height: 550px;
        overflow: hidden;
        margin: 0;
        background: #fff;
        color: white;
    }

    picture {
        position: relative;
        width: 100%;
        height: 100%;
        overflow: hidden;
    }

        picture img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        picture::before,
        picture::after {
            position: absolute;
            content: "";
            width: 25%;
            height: 25%;
            top: 0;
            left: 0;
            background-color: transparent;
        }

        picture::before {
            animation: a 20s ease infinite;
        }

        picture::after {
            animation: b 10s ease infinite;
        }

    @@keyframes a {
        0%, 100% {
            width: 25%;
            height: 25%;
            left: 0;
            top: 0;
            backdrop-filter: blur(2vmin) hue-rotate(0deg);
        }

        12.5% {
            width: 100%;
            left: unset;
            backdrop-filter: blur(0vmin) hue-rotate(150deg);
        }

        25% {
            width: 25%;
            height: 25%;
            backdrop-filter: blur(2vmin) hue-rotate(300deg);
        }

        37.5% {
            height: 100%;
            top: unset;
            backdrop-filter: blur(0vmin) hue-rotate(150deg);
        }

        50% {
            width: 25%;
            height: 25%;
            backdrop-filter: blur(2vmin) hue-rotate(0deg);
        }

        62.5% {
            width: 100%;
            height: 100%;
            backdrop-filter: blur(0vmin) hue-rotate(150deg);
        }

        75% {
            width: 25%;
            height: 25%;
            backdrop-filter: blur(2vmin) hue-rotate(300deg);
        }

        87.5% {
            height: 100%;
            top: 0;
            backdrop-filter: blur(0vmin) hue-rotate(150deg);
        }
    }

    @@keyframes b {
        0%, 100% {
            width: 25%;
            height: 25%;
            left: 0;
            top: 0;
            backdrop-filter: blur(2vmin) hue-rotate(0deg);
        }

        12.5% {
            height: 100%;
            top: unset;
            backdrop-filter: blur(0vmin) hue-rotate(150deg);
        }

        25% {
            width: 25%;
            height: 25%;
            backdrop-filter: blur(2vmin) hue-rotate(300deg);
        }

        37.5% {
            width: 100%;
            left: unset;
            backdrop-filter: blur(0vmin) hue-rotate(150deg);
        }

        50% {
            width: 25%;
            height: 25%;
            backdrop-filter: blur(2vmin) hue-rotate(0deg);
        }

        62.5% {
            height: 100%;
            top: 0;
            backdrop-filter: blur(0vmin) hue-rotate(150deg);
        }

        75% {
            width: 25%;
            height: 25%;
            backdrop-filter: blur(2vmin) hue-rotate(300deg);
        }

        87.5% {
            width: 100%;
            left: 0;
            backdrop-filter: blur(0vmin) hue-rotate(150deg);
        }
    }

    #caroheading {
        border-top-right-radius: 45px;
        border-bottom-left-radius: 45px;
        padding: 6px;
        background-color: rgba(0, 0, 0, 0.759);
        border: 2px solid #ffffff7b;
    }

    .carousel-caption .btn-container button {
        padding: 10px 20px;
        font-size: 1rem;
        letter-spacing: 1px;
        border-radius: 10px;
        border: solid 1px #ffffff;
        color: #fff;
        font-weight: bolder;
        transition: all 0.2s ease;
    }

    .swiper-button-next,
    .swiper-button-prev {
        color: #ffffff;
        background-color: rgba(0, 141, 255, 0.5);
        padding: 10px;
        border-radius: 50%;
        box-shadow: 0 0 10px #D400FF;
    }

    .swiper-pagination-bullet {
        background: #888;
        opacity: 0.8;
    }

    .swiper-pagination-bullet-active {
        background: #D400FF;
    }

    .how-to-play-btn:hover {
        background-color: #d400ff;
        color: white;
        border-color: #d400ff;
    }
</style>

@if (Model.Games == null || !Model.Games.Any())
{
    <p>No games uploaded yet.</p>
}
else
{
    <section class="carousel">
        <div id="carouselExample" class="carousel slide" data-bs-ride="carousel">
            <div class="carousel-inner">
                <div class="carousel-item body">
                    <picture>
                        <img src="@Url.Content("~/web/assets/images/bg6.jpg")" class="img-fluid d-block w-100" height="600px">
                    </picture>
                    <div class="carousel-caption" style="padding-bottom:140px;">
                        <div id="caroheading" style="background-color: rgba(0, 0, 0, 0.759); margin-bottom: 10px;">
                            <a href="aboutus.html" style="text-decoration: none; color: white;">
                                <h2 class="animated fadeInLeft pt-3"
                                    style="font-size: 60px; font-family: Concert One, sans-serif; color: #ffffff;">
                                    Explore the World of Gamaxy!
                                </h2>
                                <div class="headline pt-2 pb-3">
                                    <h3 style="color: #ffffff; font-family: Manrope, sans-serif;">
                                        *<span class="text-change"></span>
                                    </h3>
                                </div>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="game-category-section py-5" style="background-color: rgb(0, 0, 0);">
        @{
            var radiusStyles = new[]
            {
        "border-top-left-radius:250px;border-top-right-radius:250px;",
        "border-bottom-left-radius:250px;border-bottom-right-radius:250px;"
        };
            int styleIndex = 0;
        }
        <div class="swiper category-slider" id="categorySwiper">
            <div class="swiper-wrapper">
                <!-- "All" Category -->
                <div class="swiper-slide active" data-filter="">
                    <div class="game-category text-center" style="border-top-left-radius:250px;border-top-right-radius:250px;">
                        <i class="fa-solid fa-shapes"></i><span>All</span>
                    </div>
                </div>

                <!-- Dynamic Categories -->
                @foreach (var cat in Model.Categories)
                {
                    var style = radiusStyles[styleIndex % 2];
                    styleIndex++;
                    var icon = !string.IsNullOrEmpty(cat.IconClass) ? cat.IconClass : "fa-solid fa-gamepad";
                    var filter = cat.CategoryName?.ToLower().Replace(" ", "");
                    <div class="swiper-slide" data-filter="@filter">
                        <div class="game-category text-center" style="@style">
                            <i class="@icon"></i><span>@cat.CategoryName</span>
                        </div>
                    </div>
                }
            </div>
            <div class="swiper-button-next"></div>
            <div class="swiper-button-prev"></div>
            <div class="swiper-pagination"></div>
        </div>
    </section>

    <section class="section-full bg-white content-inner-2 mb-10">
        <div class="container">
            <div class="row">
                @foreach (var game in Model.Games)
                {
                    <div class="col-12 col-sm-6 col-md-6 col-lg-3 mb-4 card-container"
                         data-category="@game.Category?.CategoryName?.ToLower().Replace(" ", "")">
                        <div class="card border-0 game-card h-100"
                             style="border-radius: 10px; box-shadow: 0 4px 20px #008dff, 0 0 10px #D400FF, 0 0 5px #008dff;">
                            <div class="dlab-team6"
                                 style="border-radius: 10px; box-shadow: 0 4px 20px #008dff, 0 0 10px #D400FF, 0 0 5px #008dff;">
                                <div>
                                    <img src="@(string.IsNullOrEmpty(game.ImagePath) ? "/default-image.jpg" : game.ImagePath)"
                                         class="card-img-top"
                                         alt="@game.Title"
                                         style="height: 240px; object-fit: cover; border-top-left-radius: 10px; border-top-right-radius: 10px;">
                                </div>
                                <div class="dlab-info mt-2">
                                    <span class="dlab-position">Play Now</span>
                                </div>
                            </div>
                            <div class="card-body text-dark"
                                 style="background-image: linear-gradient(to right, #008dff 0%, #D400FF 50%,#008dff 100%); opacity: 1; border-bottom-left-radius: 10px; border-bottom-right-radius: 10px;">
                                <h3 class="card-title fw-bold text-center">
                                    <a asp-controller="Launcher" asp-action="Details" asp-route-slug="@game.Slug"
                                       class="text-decoration-none text-white" target="_blank">
                                        @game.Title
                                    </a>
                                </h3>
                                <p class="card-text small text-white text-center">@game.ShortDescription</p>
                                <div class="d-flex flex-column flex-md-row gap-2 mt-3">
                                    <button type="button"
                                            class="btn btn-outline-light how-to-play-btn text-dark w-100"
                                            style="background-color: white;"
                                            data-title="@game.Title"
                                            data-instruction="@game.HowToPlay">
                                        <i class="fa fa-question-circle me-1"></i> How to Play
                                    </button>
                                    <a asp-controller="Launcher" asp-action="Details" asp-route-slug="@game.Slug"
                                       class="btn btn-outline-light btn-primary text-dark w-100"
                                       target="_blank" style="background-color: white;">
                                        <i class="fa fa-play me-1"></i> Details
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
            <div class="modal fade" id="howToPlayModal" tabindex="-1" aria-labelledby="howToPlayLabel" aria-hidden="true">
                <div class="modal-dialog modal-dialog-scrollable modal-lg">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title" id="howToPlayLabel">How to Play</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body" id="howToPlayBody"></div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
}

<!-- Bootstrap 5.3 JS Bundle (includes Popper) -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<!-- jQuery and related scripts -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.1.1/jquery.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jqueryui/1.12.1/jquery-ui.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-localScroll/1.4.0/jquery.localScroll.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-scrollTo/2.1.2/jquery.scrollTo.js"></script>

<script>
    $(document).ready(function () {
        // Text animation for carousel headline
        var str = [
            " From Action to Adventure — All in One Place * ",
            " Play Smart. Play Fast. Play Gamaxy * ",
            " Your Ultimate Gaming Destination * "
        ];
        var pos = 0, a = 0, html = "";
        function displayText() {
            if (pos > 2) pos = 0;
            if (a < str[pos].length) {
                html += str[pos].charAt(a);
                $(".text-change").html(html);
                a++;
            } else {
                a = 0;
                pos++;
                html = "";
            }
        }
        setTimeout(() => setInterval(displayText, 150), 100);

        // Initialize Swiper
        var swiper = new Swiper('#categorySwiper', {
            slidesPerView: 'auto',
            spaceBetween: 10,
            navigation: {
                nextEl: '.swiper-button-next',
                prevEl: '.swiper-button-prev',
            },
            pagination: {
                el: '.swiper-pagination',
                clickable: true,
            }
        });

        // Category filter logic
        $('.swiper-slide').on('click', function () {
            $('.swiper-slide').removeClass('active');
            $(this).addClass('active');
            var filter = $(this).data('filter');
            $('.no-games-message').remove();
            $('.card-container').hide();
            if (filter === '') {
                $('.card-container').show();
            } else {
                var visibleCards = $(`.card-container[data-category="${filter}"]`);
                if (visibleCards.length === 0) {
                    $('.section-full .container .row').append(
                        '<p class="no-games-message text-center text-white">No games found in this category.</p>'
                    );
                } else {
                    visibleCards.show();
                }
            }
        });

        // How-to-play modal logic
        const howToPlayButtons = document.querySelectorAll(".how-to-play-btn");
        const modalTitle = document.getElementById("howToPlayLabel");
        const modalBody = document.getElementById("howToPlayBody");

        howToPlayButtons.forEach(button => {
            button.addEventListener("click", () => {
                const title = button.getAttribute("data-title");
                const instruction = button.getAttribute("data-instruction");
                modalTitle.innerText = `How to Play - ${title}`;
                modalBody.innerHTML = instruction && instruction.trim() !== ""
                    ? `<p>${instruction}</p>`
                    : `<p>No instructions provided for this game yet.</p>`;
                new bootstrap.Modal(document.getElementById('howToPlayModal')).show();
            });
        });
    });
</script>
<style>
    .overlay-bx {
        display: block !important;
        opacity: 1 !important;
        visibility: visible !important;
    }
</style>
                    image: "data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 160 40'%3E%3Cpath d='M20,30 Q80,10 140,30 L140,35 Q80,15 20,35 Z' fill='%23F5B041'/%3E%3Cpath d='M20,30 Q80,10 140,30 L130,15 Q80,-5 30,15 Z' fill='%23F8C471'/%3E%3Ccircle cx='50' cy='15' r='2' fill='%23FFFFFF'/%3E%3Ccircle cx='70' cy='10' r='2' fill='%23FFFFFF'/%3E%3Ccircle cx='90' cy='10' r='2' fill='%23FFFFFF'/%3E%3Ccircle cx='110' cy='15' r='2' fill='%23FFFFFF'/%3E%3C/svg%3E"

            let ingredientWidth = 160;
            let tiltMode = false;
            let tiltValue = 0;
            let stackTilt = 0;
            let stackHeight = 0;
            let gameWidth;
            let gameHeight;
            let activePowerups = [];
            let achievements = {};
            let showTutorial = true;
            let tutorialStep = 0;
            let stackTop = 0;
            let touchStartX = 0;
            let lastFrameTime = 0;
            let fps = 60;
            let frameCount = 0;
            let lastFpsUpdate = 0;


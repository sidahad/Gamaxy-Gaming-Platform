    <style>
        .games-section {
            position: relative;
            padding: 60px 20px;
            color: #fff;
            overflow: hidden;
            z-index: 1;
            background: #000; /* fallback */
        }

            /* 3D Infinite Neon Grid Background */
            .games-section::before {
                content: "";
                position: absolute;
                inset: 0;
                background: linear-gradient(#008dff 1px, transparent 1px), linear-gradient(90deg, #D400FF 1px, transparent 1px);
                background-size: 80px 80px;
                transform: perspective(800px) rotateX(60deg);
                animation: moveGrid 5s linear infinite;
                opacity: 0.3;
                z-index: 0;
            }

            /* Neon Glow Overlay */
            .games-section::after {
                content: "";
                position: absolute;
                inset: 0;
                background: radial-gradient(circle at center, rgba(0,141,255,0.2), rgba(212,0,255,0.2), transparent 70%);
                animation: pulseGlow 6s ease-in-out infinite alternate;
                z-index: 0;
            }

            /* Keep content above background */
            .games-section * {
                position: relative;
                z-index: 1;
            }

        /* Animations */
        @@keyframes moveGrid {
            0%

        {
            background-position: 0 0, 0 0;
        }

        100% {
            background-position: 0 80px, 80px 0;
        }

        }

        @@keyframes pulseGlow {
            0%

        {
            opacity: 0.15;
        }

        100% {
            opacity: 0.35;
        }

        }


        .section-title {
            font-size: 2.2rem;
            font-weight: 800;
            background: linear-gradient(to right,0% #008dff, 50% #D400FF, 100% #008dff);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .section-subtitle {
            color: #aaa;
            font-size: 1rem;
            margin-top: 8px;
        }

        .slider {
            display: flex;
            align-items: center;
            position: relative;
            margin-top: 30px;
        }

        .game-grid {
            display: flex;
            gap: 20px;
            overflow-x: auto;
            scroll-behavior: smooth;
            padding: 15px 10px;
        }

        .game-card {
            min-width: 300px;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 16px;
            backdrop-filter: blur(10px);
            border: 2px solid transparent;
            transition: 0.3s;
            text-align: center;
            cursor: pointer;
            box-shadow: 0 0 12px rgba(0, 141, 255, 0.2);
        }

            .game-card img {
                width: 100%;
                border-radius: 12px;
            }

            .game-card:hover {
                transform: scale(1.08);
                border-color: #008dff;
                box-shadow: 0 0 20px rgba(212, 0, 255, 0.5);
            }

        .game-title {
            display: block;
            margin: 10px 0;
            font-size: 1rem;
            color: #fff;
        }

        .slide-btn {
            background: rgba(0, 0, 0, 0.6);
            border: none;
            color: #fff;
            font-size: 1.5rem;
            padding: 12px;
            cursor: pointer;
            border-radius: 50%;
            transition: 0.3s;
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            z-index: 5;
        }

            .slide-btn.left {
                left: 5px;
            }

            .slide-btn.right {
                right: 5px;
            }

            .slide-btn:hover {
              background:linear-gradient(to right,0% #008dff, 50% #D400FF, 100% #008dff);
            }
    </style>


    <script>
        let slideIndex = 0;

        function moveSlide(direction) {
            const slideTrack = document.getElementById("slideTrack");
            const slideWidth = 315; // 300px + 15px gap
            slideIndex += direction;

            if (slideIndex < 0) slideIndex = 0;
            if (slideIndex > slideTrack.children.length - 3) slideIndex = slideTrack.children.length - 3;

            slideTrack.style.transform = `translateX(-${slideWidth * slideIndex}px)`;
        }

        function moveGameSlide(button, direction) {
            const grid = button.parentElement.querySelector(".game-grid");
            const scrollAmount = 210; // image width + gap
            grid.scrollBy({ left: direction * scrollAmount, behavior: "smooth" });
        }
    </script>

@model List<GamerPlayinghistory>

@{
    ViewData["Title"] = "Playing History";
}

<div class="container mt-5 p-5 playing-history-container">
    <h2 class="history-title"> Playing History - @ViewBag.Name</h2>

    @if (ViewBag.NoHistory != null)
    {
        <div class="no-history-card">
            <i class="fas fa-gamepad"></i>
            <p>@ViewBag.NoHistory</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table custom-history-table mt-5">
                <thead>
                    <tr>
                        <th>Game Title</th>
                        <th>Category</th>
                        <th>Played On</th>
                        <th>Score</th>
                        <th>Duration</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var h in Model)
                    {
                        <tr>
                            <td>@h.PremiumGame?.Title</td>
                            <td>@h.PremiumGame?.Category?.CategoryName</td>
                            <td>@h.PlayedOn.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>@(h.Score.HasValue ? h.Score.ToString() : "-")</td>
                            <td>@(h.Duration.HasValue ? h.Duration.ToString() : "-")</td>
                            <td>
                                <form asp-action="DeleteHistory" asp-controller="Home" method="post" style="display:inline;">
                                    <input type="hidden" name="id" value="@h.PlayHistoryId" />
                                    <button type="submit" class="btn btn-sm delete-btn"
                                            onclick="return confirm('Are you sure you want to delete this history?');">
                                        Delete
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<style>
    /* Background + Title */
    .playing-history-container {
        background: rgba(15, 15, 25, 0.95);
        border-radius: 20px;
        box-shadow: 0 0 25px rgba(0, 141, 255, 0.4), 0 0 20px rgba(212, 0, 255, 0.3);
    }

    .history-title {
        font-family: 'Orbitron', sans-serif;
        font-size: 28px;
        background: linear-gradient(90deg, #008dff, #D400FF);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        font-weight: 800;
        text-shadow: 0 0 10px rgba(0,141,255,0.6);
    }

    /* If No History */
    .no-history-card {
        margin-top: 40px;
        text-align: center;
        padding: 40px;
        border-radius: 16px;
        background: rgba(30,30,40,0.95);
        box-shadow: 0 0 20px rgba(0,141,255,0.4);
        color: #ccc;
        animation: pulse 2s infinite alternate;
    }

        .no-history-card i {
            font-size: 50px;
            color: #008dff;
            margin-bottom: 15px;
        }

        .no-history-card p {
            font-size: 18px;
        }
    @@keyframes pulse {
        from

    {
        box-shadow: 0 0 10px rgba(0,141,255,0.4);
    }

    to {
        box-shadow: 0 0 25px rgba(212,0,255,0.6);
    }

    }

    /* Table Styling */
    .custom-history-table {
        width: 100%;
        color: #fff;
        border-collapse: separate;
        border-spacing: 0 10px;
        font-family: 'Exo 2', sans-serif;
    }

        .custom-history-table thead th {
            background: linear-gradient(90deg, #008dff, #D400FF);
            border: none;
            color: #fff;
            font-weight: 700;
            text-align: center;
            padding: 12px;
            border-radius: 10px;
        }

        .custom-history-table tbody tr {
            background: rgba(25,25,35,0.9);
            transition: 0.3s;
        }

            .custom-history-table tbody tr:hover {
                background: rgba(40,40,60,0.95);
                box-shadow: 0 0 15px rgba(0,141,255,0.4), 0 0 10px rgba(212,0,255,0.4);
                transform: scale(1.01);
            }

        .custom-history-table td {
            padding: 12px;
            text-align: center;
            vertical-align: middle;
            border-top: none;
        }

    /* Delete Button */
    .delete-btn {
        background: transparent;
        border: 2px solid #ff3b3b;
        color: #ff3b3b;
        font-weight: 600;
        border-radius: 8px;
        padding: 5px 12px;
        transition: 0.3s;
    }

        .delete-btn:hover {
            background: #ff3b3b;
            color: #fff;
            box-shadow: 0 0 10px rgba(255,59,59,0.8);
            transform: scale(1.05);
        }
</style>

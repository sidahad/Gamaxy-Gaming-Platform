@model GamaxyWebApplication.Models.Registration

@{
    ViewData["Title"] = "Registration Page";
}
 <style>
 .section1 {
        position: relative;
        letter-spacing: 1px;
        color: #ffffff;
        min-height: 100vh;
        overflow-x: hidden;
        background-image: url('@Url.Content("~/web/assets/images/bg8.jpg")');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
    }
    </style>
<section class="container-fluid section1">


    @if (ViewBag.Message != null)
    {
        <div class="alert alert-danger">@ViewBag.Message</div>
    }


    <div class="body_overlay"></div>
    <div class="container-fluid d-flex justify-content-center align-items-center" style="margin-top:100px; margin-bottom:100px;">
        <div class="cardrr p-4 shadow-lg rounded border-0 body"
             style="max-width: 400px; width: 100%; background: black; border: 2px dotted white">


            <h1 style="text-align:center; color:white;" class="mt-5">Registration Form</h1>
            <div class="col-lg-12">

                <form asp-action="Registration" method="post" enctype="multipart/form-data">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Name</label>
                        <input asp-for="Name" type="text" required class="form-control form-controlrr shadow-sm" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Email</label>
                        <input asp-for="Email" type="email" required class="form-control form-controlrr shadow-sm" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Password</label>
                        <input asp-for="Password" type="password" required class="form-control form-controlrr shadow-sm" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Age</label>
                        <input asp-for="Age" type="number" required class="form-control form-controlrr shadow-sm" />
                        <span asp-validation-for="Age" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Phone Number</label>
                        <input asp-for="Phone" type="tel" required class="form-control form-controlrr shadow-sm" />
                        <span asp-validation-for="Phone" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Address</label>
                        <input asp-for="Address" type="text" required class="form-control form-controlrr shadow-sm" />
                        <span asp-validation-for="Address" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Profile Image</label>
                        <input asp-for="UserImage" type="file" accept="image/*" class="form-control form-controlrr shadow-sm" />
                        <span asp-validation-for="UserImage" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Gender</label>
                        <select asp-for="Gender" class="form-control form-controlrr shadow-sm">
                            <option value="">Select Gender</option>
                            <option value="Male">Male</option>
                            <option value="Female">Female</option>
                        </select>
                        <span asp-validation-for="Gender" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Role</label>
                        <select asp-for="Role" class="form-control form-controlrr shadow-sm" id="roleSelect" onchange="toggleGamerFields()">
                            <option value="">Select Role</option>
                            <option value="User">User</option>
                            <option value="Gamer">Gamer</option>
                        </select>
                        <span asp-validation-for="Role" class="text-danger"></span>
                    </div>

                    <!-- Gamer Specific Fields -->
                    <div class="mb-3" id="GamerCodeContainer" style="display: none;">
                        <label class="form-label fw-bold">Gamer Code</label>
                        <input name="GamerCode" type="text" class="form-control shadow-sm" placeholder="Enter Gamer Code" />
                        <span class="text-danger" asp-validation-for="GamerCode"></span>
                    </div>

                    <button type="submit" class="btn buttonrr btn-primary w-100">Register</button>
               

                <p class="text-center mt-3">
                    Already have an account?
                    <a asp-action="Login" class="text-decoration-none text-primary fw-bold">Login here</a>
                </p>
              </form>

            </div>
        </div>
    </div>
</section>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function toggleGamerFields() {
            const role = document.getElementById("roleSelect").value;
            const gamerCode = document.getElementById("GamerCodeContainer");

            const isGamer = role === "Gamer";
            gamerCode.style.display = isGamer ? "block" : "none";
        }

        // Run on page load (helpful if role was selected before reload)
        window.onload = toggleGamerFields;
    </script>
}
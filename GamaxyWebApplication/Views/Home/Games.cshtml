@{
	ViewData["Title"] = "Game Page";
	Layout = "_layout2";
}
<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<style>
		.toggle-btn {
			position: fixed;
			top: 15px;
			left: 5px;
			z-index: 1100;
			font-size: 24px;
			background-color: #5d2bf4;
			color: white;
			border: none;
			border-radius: 6px;
			padding: 8px 12px;
			cursor: pointer;
		}

		.sidebar {
			background-color: #1a1a25;
			color: #fff;
			position: fixed;
			height: 100%;
			width: 60px;
			left: 0;
			top: 0;
			padding: 15px 0;
			display: flex;
			flex-direction: column;
			align-items: center;
			overflow-y: auto;
			border-right: 1px solid #2c2c3a;
			transition: width 0.3s ease, transform 0.3s ease;
			z-index: 1000;
		}

			.sidebar:hover {
				width: 200px;
				align-items: flex-start;
				padding-left: 20px;
			}

		.sidebar-icons {
			display: flex;
			flex-direction: column;
			gap: 20px;
			width: 100%;
		}

		.sidebar-item {
			display: flex;
			align-items: center;
			gap: 15px;
			cursor: pointer;
			padding: 8px 10px;
			border-radius: 8px;
		}

			.sidebar-item:hover {
				background-color: #2c2c3a;
			}

			.sidebar-item img {
				width: 30px;
				height: 30px;
			}

			.sidebar-item span {
				white-space: nowrap;
				font-size: 14px;
				opacity: 0;
				transition: opacity 0.3s ease;
			}

		.sidebar:hover .sidebar-item span {
			opacity: 1;
		}

		.sidebar.hidden {
			transform: translateX(-100%);
		}

		body.sidebar-hidden .main-content {
			margin-left: 0;
		}

		.label {
			position: absolute;
			top: 10px;
			left: 10px;
			background: red;
			padding: 5px;
			border-radius: 5px;
			font-size: 12px;
			font-weight: bold;
		}

		.new .label {
			background: blue;
		}

		.hot .label {
			background: orangered;
		}

		.game-section {
			margin-top: 30px;
		}

		.slider {
			position: relative;
			overflow: hidden;
			border-radius: 10px;
			margin-bottom: 30px;
		}

		.slide-track {
			display: flex;
			transition: transform 0.5s ease;
			gap: 15px;
		}

		.slider img {
			width: 300px;
			height: 170px;
			object-fit: cover;
			border-radius: 10px;
			transition: transform 0.3s;
		}

			.slider img:hover {
				transform: scale(1.05);
			}

		.slide-btn {
			position: absolute;
			top: 50%;
			transform: translateY(-50%);
			background-color: rgba(0,0,0,0.5);
			color: #fff;
			font-size: 22px;
			padding: 8px 12px;
			border: none;
			cursor: pointer;
			z-index: 1;
		}

			.slide-btn.left {
				left: 5px;
			}

			.slide-btn.right {
				right: 5px;
			}
		/* Section Titles */
		.games-section h2 {
			font-size: 24px;
			margin-bottom: 10px;
		}

		/* Featured Slider (not affected by .game-grid styling) */
		.featured-slider {
			width: 100%;
			max-height: 400px;
			overflow: hidden;
			border-radius: 10px;
			margin-bottom: 30px;
		}

			.featured-slider img {
				width: 100%;
				height: auto;
				display: block;
				border-radius: 10px;
			}

		/* Game Image Sliders */
		.game-grid {
			display: flex;
			overflow-x: auto;
			gap: 10px;
			padding-bottom: 20px;
			/* Hide scrollbar */
			scrollbar-width: none; /* Firefox */
			-ms-overflow-style: none; /* Internet Explorer 10+ */
		}

			.game-grid::-webkit-scrollbar {
				display: none; /* Chrome, Safari, Opera */
			}


			.game-grid img {
				width: 200px;
				height: 140px;
				flex-shrink: 0;
				object-fit: cover;
				border-radius: 8px;
				transition: transform 0.3s;
			}

				.game-grid img:hover {
					transform: scale(1.05);
				}


		.slider-section {
			margin-bottom: 40px;
		}

        .service-box-3 .title:after {
            content: "\f004"; /* heart icon */
            width: 40px;
            height: 40px;
            background: #fff;
            position: absolute;
            right: 6px;
            color: #e91e63; /* pink/red heart */
            text-align: center;
            top: 50%;
            transform: translateY(-50%);
            line-height: 40px;
            font-family: "Font Awesome 5 Free"; /* or 6 Free */
            font-weight: 900; /* required for solid style */
        }

        /* Heart Button */
.favorite-btn {
    position: absolute;
    top: 10px;
    right: 10px;
    background: rgba(255, 255, 255, 0.85);
    border: none;
    border-radius: 50%;
    padding: 8px;
    cursor: pointer;
    transition: all 0.3s ease;
    z-index: 10;
}
.favorite-btn i {
    font-size: 16px;
    color: #e91e63;
    transition: transform 0.3s ease, color 0.3s ease;
}
.favorite-btn:hover {
    background: #fff;
    transform: scale(1.1);
}
.favorite-btn:hover i {
    color: #ff1744;
    transform: scale(1.2);
}

/* Rating Badge */
.rating-badge {
    position: absolute;
    bottom: 10px;
    left: 10px;
            background: linear-gradient(90deg, #D400FF,#008dff);
    color: #fff;
    font-size: 0.9rem;
    font-weight: 600;
    padding: 4px 10px;
    border-radius: 20px;
    box-shadow: 0 3px 8px rgba(0,0,0,0.25);
    z-index: 10;
}

	</style>
</head>
<body>
        <!-- Carousel section start here -->
        <div class="carousel">
            <div id="carouselExample" class="carousel slide" data-bs-ride="carousel">
                <div class="carousel-inner">
                    <div class="carousel-item body">
                        <picture>
                            <img src="~/web/assets/images/bg6.jpg" class="image-fluid d-block w-100" alt="Destination event" height="600px">
                        </picture>
                        <div class="carousel-caption" style="padding-bottom:140px;">
                            <div id="caroheading" style="background-color: rgba(0, 0, 0, 0.759); margin-bottom: 10px;">
                                <a href="aboutus.html" style="text-decoration: none; color: white;">
                                    <h2 class="animated fadeInLeft pt-3" style="font-size: 60px; font-family: Concert One, sans-serif; color: #ffffff;">
                                        Explore the World of Gamaxy!
                                    </h2>
                                    <div class="headline pt-2 pb-3">
                                        <span style="color: #ffffff; font-family: Manrope, sans-serif;" class="text-change"></span>
                                    </div>
                                </a>
                                <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.1.1/jquery.min.js"></script>
                                <script src="https://cdnjs.cloudflare.com/ajax/libs/jqueryui/1.12.1/jquery-ui.min.js"></script>
                                <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-localScroll/1.4.0/jquery.localScroll.js"></script>
                                <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-scrollTo/2.1.2/jquery.scrollTo.js"></script>
                                <script>
                                    $(document).ready(function () {
                                        // Carousel text animation
                                        var str = [" From Action to Adventure — All in One Place* ", " Play Smart. Play Fast. Play Gamaxy * ", " Your Ultimate Gaming Destination * "];
                                        var pos = 0, a = 0;
                                        var html = "";
                                        $(".headline h1").css("letterSpacing", "1px");
                                        function displayText() {
                                            if (pos > 2) pos = 0;
                                            console.log(pos);
                                            console.log(str[pos].length);
                                            if (a < str[pos].length) {
                                                html += str[pos].charAt(a);
                                                $(".text-change").html(html);
                                                a++;
                                            }
                                            else {
                                                a = 0;
                                                pos++;
                                                html = "";
                                            }
                                        }
                                        setTimeout(setInterval(displayText, 150), 100);
                                        $(".describe").hover(function () {
                                            $(this).addClass("hover");
                                        }, function () {
                                            $(this).removeClass("hover");
                                        });
                                        $("#nav").localScroll({ duration: 800 });

                                        // Add to Favorite functionality
                                        $('.add-to-favorite').click(function () {
                                            var button = $(this);
                                            var gameName = button.data('game-name');
                                            var gameAction = button.data('game-action');

                                            $.ajax({
                                                url: '/Home/AddToFavorites',
                                                type: 'POST',
                                                data: {
                                                    gameName: gameName,
                                                    gameAction: gameAction
                                                },
                                                success: function (response) {
                                                    if (response.success) {
                                                        alert(gameName + ' has been added to your favorites!');
                                                        button.text('Added').prop('disabled', true).removeClass('btn-primary').addClass('btn-success');
                                                    } else if (response.message === 'Already favorited') {
                                                        alert(gameName + ' is already in your favorites.');
                                                    } else {
                                                        alert('Error: ' + response.message);
                                                    }
                                                },
                                                error: function () {
                                                    alert('An error occurred while adding to favorites. Please try again.');
                                                }
                                            });
                                        });
                                    });
                                </script>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>


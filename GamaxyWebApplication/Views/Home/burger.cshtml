@model GamaxyWebApplication.Models.GameRatingViewModel
@{
    ViewData["Title"] = "Burger";
    Layout = "_layout3";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Burger Stack Master</title>
    <link href="~/css/burger.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700&display=swap" />
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
</head>
<body>
    <div class="game-page">
        <div class="header-section">
            <h1>Burger Stack Master</h1>
        </div>
        <div class="game-container-wrapper">
            <div id="game-container" class="game-container">
                <div id="game-background"></div>

                <!-- Kitchen background elements -->
                <div class="kitchen-light" style="top: 100px; left: 100px;"></div>
                <div class="kitchen-light" style="top: 150px; left: 350px;"></div>
                <div class="kitchen-light" style="top: 50px; left: 250px;"></div>

                <div class="chef-silhouette" style="top: 200px; left: 100px;"></div>
                <div class="chef-silhouette" style="top: 250px; left: 400px;"></div>
                <div class="chef-silhouette" style="top: 150px; left: 250px;"></div>

                <div class="utensil" style="top: 650px; left: 20px;"></div>
                <div class="utensil" style="top: 630px; left: 420px;"></div>

                <div class="kitchen-counter"></div>
                <div class="counter-shine"></div>

                <div id="game-area">
                    <div id="plate">
                        <svg class="plate-svg" viewBox="0 0 180 30">
                            <ellipse cx="90" cy="15" rx="90" ry="15" fill="#FFFFFF" />
                            <ellipse cx="90" cy="15" rx="80" ry="13" fill="#F5F5F5" />
                            <ellipse cx="90" cy="15" rx="70" ry="11" fill="#EEEEEE" />
                        </svg>
                    </div>
                </div>

                <div id="ui-container">
                    <div id="score-container">
                        <div class="burger-icon"></div>
                        <div id="score-value">0</div>
                    </div>

                    <div id="combo-container">
                        <div id="combo-meter">
                            <div id="combo-fill"></div>
                        </div>
                        <div id="combo-text">x1</div>
                    </div>

                    <div id="lives-container">
                        <div class="life-icon"></div>
                        <div class="life-icon"></div>
                        <div class="life-icon"></div>
                    </div>

                    <div id="time-container">Time: <span id="time-value">60</span>s</div>

                    <div id="order-container">
                        <div id="order-title">ORDER:</div>
                        <div id="order-items"></div>
                    </div>

                    <div id="perfect-stack">PERFECT STACK!</div>

                    <div id="level-container">Level: 1 - Classic Burger</div>

                    <div class="tilt-indicator">
                        <div class="tilt-danger-left"></div>
                        <div class="tilt-danger-right"></div>
                        <div class="tilt-marker"></div>
                    </div>

                    <div id="powerup-indicator"></div>

                    <div id="pause-btn"></div>

                    <div class="achievement">
                        <div class="achievement-icon">🏆</div>
                        <div class="achievement-text">Achievement Unlocked!</div>
                    </div>
                </div>

                <div id="start-screen">
                    <h1>BURGER STACK MASTER</h1>
                    <p>Stack the perfect burger by catching the right ingredients!</p>
                    <p>Follow the order shown at the top of the screen</p>
                    <p>Don't miss ingredients or your burger will fall!</p>
                    <button class="btn" id="start-btn">START GAME</button>
                    <div id="level-select">
                        <button class="level-btn" data-level="1">1</button>
                        <button class="level-btn locked" data-level="2">2</button>
                        <button class="level-btn locked" data-level="3">3</button>
                        <button class="level-btn locked" data-level="4">4</button>
                        <button class="level-btn locked" data-level="5">5</button>
                        <button class="level-btn locked" data-level="6">6</button>
                    </div>
                </div>

                <div id="game-over" style="display: none;">
                    <h2>GAME OVER</h2>
                    <p>Your burger collapsed!</p>
                    <p>Final Score: <span id="final-score">0</span></p>
                    <p>Perfect Stacks: <span id="perfect-stacks">0</span></p>
                    <button class="btn" id="restart-btn">PLAY AGAIN</button>
                    <button class="btn" id="menu-btn-gameover">MENU</button>
                </div>

                <div id="level-complete" style="display: none;">
                    <h2>LEVEL COMPLETE!</h2>
                    <p>Score: <span id="level-score">0</span></p>
                    <p>Perfect Stacks: <span id="level-perfect-stacks">0</span></p>
                    <p>Stars: <span id="level-stars">★★★</span></p>
                    <button class="btn" id="next-level-btn">NEXT LEVEL</button>
                    <button class="btn" id="menu-btn">MENU</button>
                </div>

                <div id="pause-screen" style="display: none;">
                    <h2>GAME PAUSED</h2>
                    <p>Take a break, your burger is waiting!</p>
                    <button class="btn" id="resume-btn">RESUME</button>
                    <button class="btn" id="restart-btn-pause">RESTART</button>
                    <button class="btn" id="menu-btn-pause">MENU</button>
                </div>

                <div id="tutorial-overlay" style="display: none;">
                    <div class="tutorial-message">
                        Drag the plate left and right to catch falling ingredients!
                    </div>
                    <div class="tutorial-arrow" style="bottom: 150px;"></div>
                    <button class="btn" id="tutorial-next">GOT IT!</button>
                </div>

                <!-- FPS counter -->
                <div id="fps-counter">FPS: 60</div>
            </div>
        </div>
        <div class="rating-section">
            <h2 class="rating-title">@Model.GameName</h2>
            <p class="rating-average">Average Rating: @Model.AverageRating.ToString("F1")</p>
            @if (Model.UserId.HasValue)
            {
                <p class="rating-user">Your Rating: @(Model.ExistingRating > 0 ? Model.ExistingRating.ToString() : "Not rated yet")</p>
                <form id="ratingForm" method="post" asp-action="RateGame">
                    <input type="hidden" name="gameName" value="@Model.GameName" />
                    <div class="star-rating">
                        @for (int i = 5; i >= 1; i--)
                        {
                            <input type="radio" id="star-@i" name="rating" value="@i" @(Model.ExistingRating == i ? "checked" : "") />
                            <label for="star-@i">★</label>
                        }
                    </div>
                    <button type="submit" class="btn-rate">Submit Rating</button>
                </form>
            }
            else
            {
                <p class="rating-login">Please <a asp-action="Login">login</a> to rate this game.</p>
            }
        </div>
    </div>
    <script>
        $(document).ready(function () {
            $('#ratingForm').submit(function (e) {
                e.preventDefault();
                $.ajax({
                    url: '@Url.Action("RateGame", "Home")',
                    type: 'POST',
                    data: $(this).serialize(),
                    headers: {
                        'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function (response) {
                        if (response.success) {
                            alert(response.message);
                            location.reload();
                        } else {
                            alert('Error: ' + response.message);
                        }
                    },
                    error: function () {
                        alert('An error occurred while submitting the rating.');
                    }
                });
            });
        });

        // Existing game JavaScript remains unchanged
        document.addEventListener('DOMContentLoaded', function() {

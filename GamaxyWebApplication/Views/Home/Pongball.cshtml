@model GamaxyWebApplication.Models.GameRatingViewModel
@{
    ViewData["Title"] = "Ultra Pong Arcade";
    Layout = "_layout3";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>Ultra Pong Arcade</title>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;600;700;900&family=Arial+Rounded+MT+Bold&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/Pongball.css" />
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
</head>
<body style="background-color:  #0a0a1e;">
    <div class="container py-4">
        <div class="game-page">
            <div class="header-section">
                <h1 class="game-title">ULTRA PONG ARCADE</h1>
                <div class="game-subtitle">CLASSIC TWO-PLAYER ACTION</div>
            </div>

            <div class="game-container-wrapper">
                <div class="game-container">
                    <div class="scoreboard">
                        <div class="player-score" id="p1-container">
                            <div class="player-name">PLAYER 1</div>
                            <div class="score" id="p1-score">0</div>
                        </div>
                        <div class="vs">VS</div>
                        <div class="player-score" id="p2-container">
                            <div class="player-name">PLAYER 2</div>
                            <div class="score" id="p2-score">0</div>
                        </div>
                    </div>

                    <canvas id="pong"></canvas>

                    <div class="game-overlay" id="start-screen">
                        <div class="message">READY TO PLAY?</div>
                        <button class="btn" id="start-btn">START GAME</button>
                        <div class="controls-info">
                            <div class="control-info">
                                <span>Player 1:</span>
                                <span class="key">W</span>
                                <span class="key">S</span>
                            </div>
                            <div class="control-info">
                                <span>Player 2:</span>
                                <span class="key">↑</span>
                                <span class="key">↓</span>
                            </div>
                        </div>
                    </div>

                    <div class="game-overlay" id="winner-screen">
                        <div class="message" id="winner-msg"></div>
                        <button class="btn" id="restart-btn">PLAY AGAIN</button>
                    </div>

                    <div class="game-stats">
                        <div class="stat">Ball Speed: <span id="ball-speed">5</span></div>
                        <div class="stat">Rally: <span id="rally-count">0</span></div>
                        <div class="stat">Time: <span id="game-time">00:00</span></div>
                    </div>

                    <div class="particles" id="particles"></div>
                </div>
            </div>

            <div class="controls">
                <button class="btn" id="mode-btn">SWITCH TO AI MODE</button>
                <button class="btn" id="power-ups-btn">POWER-UPS: OFF</button>
                <p>Player 1: W/S • Player 2: Up/Down • Space to start</p>
            </div>

            <!-- Rating Section -->
            <div class="rating-section">
                <h2 class="rating-title">@Model.GameName</h2>
                <p class="rating-average">Average Rating: @Model.AverageRating.ToString("F1")</p>
                @if (Model.UserId.HasValue)
                {
                    <p class="rating-user">Your Rating: @(Model.ExistingRating > 0 ? Model.ExistingRating.ToString() : "Not rated yet")</p>
                    <form id="ratingForm" method="post" asp-action="RateGame">
                        <input type="hidden" name="gameName" value="@Model.GameName" />
                        <div class="star-rating">
                            <input type="radio" id="star5" name="rating" value="5" /><label for="star5">★</label>
                            <input type="radio" id="star4" name="rating" value="4" /><label for="star4">★</label>
                            <input type="radio" id="star3" name="rating" value="3" /><label for="star3">★</label>
                            <input type="radio" id="star2" name="rating" value="2" /><label for="star2">★</label>
                            <input type="radio" id="star1" name="rating" value="1" /><label for="star1">★</label>
                        </div>
                        <button type="submit" class="btn btn-rate">Submit Rating</button>
                    </form>
                }
                else
                {
                    <p class="rating-login">Please <a asp-action="Login">login</a> to rate this game.</p>
                }
            </div>
        </div>
    </div>

    <script>
        $(document).ready(function () {
            $('#ratingForm').submit(function (e) {
                e.preventDefault();
                $.ajax({
                    url: '@Url.Action("RateGame", "Home")',
                    type: 'POST',
                    data: $(this).serialize(),
                    headers: {
                        'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function (response) {
                        if (response.success) {
                            alert(response.message);
                            location.reload();
                        } else {
                            alert('Error: ' + response.message);
                        }
                    },
                    error: function () {
                        alert('An error occurred while submitting the rating.');
                    }
                });
            });
        });

        // Game elements
        const canvas = document.getElementById("pong");
        const ctx = canvas.getContext("2d");
        const p1ScoreEl = document.getElementById("p1-score");
        const p2ScoreEl = document.getElementById("p2-score");
        const p1Container = document.getElementById("p1-container");
        const p2Container = document.getElementById("p2-container");
        const winnerMsg = document.getElementById("winner-msg");
        const restartBtn = document.getElementById("restart-btn");
        const startBtn = document.getElementById("start-btn");
        const startScreen = document.getElementById("start-screen");
        const winnerScreen = document.getElementById("winner-screen");
        const modeBtn = document.getElementById("mode-btn");
        const powerUpsBtn = document.getElementById("power-ups-btn");
        const ballSpeedEl = document.getElementById("ball-speed");
        const rallyCountEl = document.getElementById("rally-count");
        const gameTimeEl = document.getElementById("game-time");
        const particlesContainer = document.getElementById("particles");

        // Canvas responsiveness
        function resizeCanvas() {
            const container = canvas.parentElement;
            canvas.width = container.clientWidth;
            canvas.height = container.clientHeight;
            resetPaddles();
            resetBall();
        }

        // Resize on load and window resize
        window.addEventListener('load', resizeCanvas);
        let resizeTimeout;
        window.addEventListener('resize', () => {
            clearTimeout(resizeTimeout);
            resizeTimeout = setTimeout(resizeCanvas, 100);
        });
        window.addEventListener('orientationchange', () => {
            clearTimeout(resizeTimeout);
            resizeTimeout = setTimeout(resizeCanvas, 100);
        });

        // Game settings
        const maxScore = 7;
        let gameActive = false;
        let aiMode = false;
        let powerUpsEnabled = false;
        let gameStartTime = 0;
        let gameTimer = null;

        // Game objects
        let paddleHeight = 100;
        let paddleWidth = 15;
        const ballRadius = 10;
        const initialBallSpeed = 5;

        // Game state
        let p1Y = canvas.height / 2 - paddleHeight / 2;
        let p2Y = p1Y;
        let p1Score = 0;
        let p2Score = 0;
        let rallyCount = 0;
        let keys = {};
        let particles = [];
        let trails = [];
        let powerUps = [];

        let ball = {
            x: canvas.width / 2,
            y: canvas.height / 2,
            vx: initialBallSpeed,
            vy: initialBallSpeed * 0.8,
            speed: initialBallSpeed,
            color: { r: 255, g: 255, b: 255 }
        };

        // Event listeners
        document.addEventListener("keydown", e => {
            keys[e.key] = true;
            if (e.key === " " && !gameActive) {
                startGame();
            }
        });
        document.addEventListener("keyup", e => keys[e.key] = false);
        restartBtn.addEventListener("click", restartGame);
        startBtn.addEventListener("click", startGame);
        modeBtn.addEventListener("click", toggleGameMode);
        powerUpsBtn.addEventListener("click", togglePowerUps);

        // Initialize game
        function init() {
            startScreen.classList.add("visible");
            createParticles();
            resizeCanvas();
            animate();
        }

        function startGame() {
            gameActive = true;
            startScreen.classList.remove("visible");
            resetGame();
            gameStartTime = Date.now();
            gameTimer = setInterval(updateGameTime, 1000);
        }

        function resetGame() {
            p1Score = 0;
            p2Score = 0;
            p1ScoreEl.textContent = "0";
            p2ScoreEl.textContent = "0";
            resetBall();
            resetPaddles();
            rallyCount = 0;
            rallyCountEl.textContent = "0";
            gameTimeEl.textContent = "00:00";
            powerUps = [];
            winnerScreen.classList.remove("visible");
        }

        function resetPaddles() {
            p1Y = canvas.height / 2 - paddleHeight / 2;
            p2Y = canvas.height / 2 - paddleHeight / 2;
        }

        function toggleGameMode() {
            aiMode = !aiMode;
            modeBtn.textContent = aiMode ? "SWITCH TO 2 PLAYER" : "SWITCH TO AI MODE";
            resetGame();
        }

        function togglePowerUps() {
            powerUpsEnabled = !powerUpsEnabled;
            powerUpsBtn.textContent = `POWER-UPS: ${powerUpsEnabled ? "ON" : "OFF"}`;
            resetGame();
        }

        function updateGameTime() {
            if (!gameActive) return;
            const elapsedSeconds = Math.floor((Date.now() - gameStartTime) / 1000);
            const minutes = Math.floor(elapsedSeconds / 60).toString().padStart(2, '0');
            const seconds = (elapsedSeconds % 60).toString().padStart(2, '0');
            gameTimeEl.textContent = `${minutes}:${seconds}`;
        }

        // Drawing functions
        function drawPaddle(x, y, width, height, color, glowColor) {
            ctx.shadowBlur = 15;
            ctx.shadowColor = glowColor;
            ctx.fillStyle = color;
            const radius = 8;
            ctx.beginPath();
            ctx.moveTo(x + radius, y);
            ctx.lineTo(x + width - radius, y);
            ctx.quadraticCurveTo(x + width, y, x + width, y + radius);
            ctx.lineTo(x + width, y + height - radius);
            ctx.quadraticCurveTo(x + width, y + height, x + width - radius, y + height);
            ctx.lineTo(x + radius, y + height);
            ctx.quadraticCurveTo(x, y + height, x, y + height - radius);
            ctx.lineTo(x, y + radius);
            ctx.quadraticCurveTo(x, y, x + radius, y);
            ctx.closePath();
            ctx.fill();
            ctx.shadowBlur = 0;
            ctx.fillStyle = "rgba(255, 255, 255, 0.3)";
            ctx.beginPath();
            ctx.moveTo(x + radius, y + 3);
            ctx.lineTo(x + width - radius, y + 3);
            ctx.quadraticCurveTo(x + width - 3, y + 3, x + width - 3, y + radius);
            ctx.lineTo(x + width - 3, y + height/3);
            ctx.lineTo(x + 3, y + height/3);
            ctx.lineTo(x + 3, y + radius);
            ctx.quadraticCurveTo(x + 3, y + 3, x + radius, y + 3);
            ctx.closePath();
            ctx.fill();
        }

        function drawBall() {
            for (let i = 0; i < trails.length; i++) {
                const trail = trails[i];
                ctx.beginPath();
                ctx.arc(trail.x, trail.y, trail.radius, 0, Math.PI * 2);
                ctx.fillStyle = trail.color;
                ctx.fill();
                trail.opacity -= 0.03;
                trail.radius *= 0.95;
                if (trail.opacity <= 0) {
                    trails.splice(i, 1);
                    i--;
                }
            }
            if (gameActive) {
                trails.push({
                    x: ball.x,
                    y: ball.y,
                    radius: ballRadius,
                    color: `rgba(${ball.color.r}, ${ball.color.g}, ${ball.color.b}, 0.3)`,
                    opacity: 0.3
                });
            }
            ctx.shadowBlur = 15;
            ctx.shadowColor = `rgb(${ball.color.r}, ${ball.color.g}, ${ball.color.b})`;
            ctx.fillStyle = `rgb(${ball.color.r}, ${ball.color.g}, ${ball.color.b})`;
            ctx.beginPath();
            ctx.arc(ball.x, ball.y, ballRadius, 0, Math.PI * 2);
            ctx.fill();
            ctx.shadowBlur = 0;
            ctx.fillStyle = "rgba(255, 255, 255, 0.5)";
            ctx.beginPath();
            ctx.arc(ball.x - ballRadius/3, ball.y - ballRadius/3, ballRadius/2, 0, Math.PI * 2);
            ctx.fill();
        }

        function drawCenterLine() {
            ctx.setLineDash([10, 15]);
            ctx.strokeStyle = "rgba(255, 255, 255, 0.2)";
            ctx.lineWidth = 4;
            ctx.beginPath();
            ctx.moveTo(canvas.width / 2, 0);
            ctx.lineTo(canvas.width / 2, canvas.height);
            ctx.stroke();
            ctx.setLineDash([]);
        }

        function drawPowerUps() {
            powerUps.forEach(powerUp => {
                ctx.shadowBlur = 10;
                ctx.shadowColor = powerUp.type === 'speed' ? '#ff0000' : '#00ff00';
                ctx.beginPath();
                ctx.arc(powerUp.x, powerUp.y, 15, 0, Math.PI * 2);
                const gradient = ctx.createRadialGradient(
                    powerUp.x, powerUp.y, 0,
                    powerUp.x, powerUp.y, 15
                );
                if (powerUp.type === 'speed') {
                    gradient.addColorStop(0, '#ff6600');
                    gradient.addColorStop(1, '#ff0000');
                    ctx.fillStyle = gradient;
                    ctx.fill();
                    ctx.shadowBlur = 0;
                    ctx.fillStyle = "rgba(255, 255, 255, 0.9)";
                    ctx.beginPath();
                    ctx.moveTo(powerUp.x - 5, powerUp.y - 8);
                    ctx.lineTo(powerUp.x + 2, powerUp.y - 2);
                    ctx.lineTo(powerUp.x - 2, powerUp.y);
                    ctx.lineTo(powerUp.x + 5, powerUp.y + 8);
                    ctx.lineTo(powerUp.x, powerUp.y);
                    ctx.lineTo(powerUp.x + 2, powerUp.y - 2);
                    ctx.closePath();
                    ctx.fill();
                } else {
                    gradient.addColorStop(0, '#66ff66');
                    gradient.addColorStop(1, '#00ff00');
                    ctx.fillStyle = gradient;
                    ctx.fill();
                    ctx.shadowBlur = 0;
                    ctx.fillStyle = "rgba(255, 255, 255, 0.9)";
                    ctx.beginPath();
                    ctx.arc(powerUp.x, powerUp.y, 8, 0, Math.PI * 2);
                    ctx.rect(powerUp.x - 2, powerUp.y - 6, 4, 12);
                    ctx.rect(powerUp.x - 6, powerUp.y - 2, 12, 4);
                    ctx.fill();
                }
            });
        }

        // Game logic
        function resetBall(direction = null) {
            ball.x = canvas.width / 2;
            ball.y = canvas.height / 2;
            const dir = direction || (Math.random() > 0.5 ? 1 : -1);
            const angle = Math.random() * Math.PI / 4 - Math.PI / 8;
            ball.speed = initialBallSpeed;
            ball.vx = dir * ball.speed * Math.cos(angle);
            ball.vy = ball.speed * Math.sin(angle);
            ball.color = { r: 255, g: 255, b: 255 };
            ballSpeedEl.textContent = ball.speed.toFixed(1);
            rallyCount = 0;
            rallyCountEl.textContent = "0";
        }

        function movePaddles() {
            if (keys["w"] && p1Y > 0) p1Y -= 8;
            if (keys["s"] && p1Y + paddleHeight < canvas.height) p1Y += 8;
            if (aiMode) {
                const aiSpeed = 5.5;
                const aiReactionDistance = 100;
                const aiTargetOffset = 0;
                if (ball.vx > 0 && ball.x > canvas.width / 2) {
                    const targetY = ball.y - paddleHeight / 2 + aiTargetOffset;
                    if (p2Y < targetY - 10) {
                        p2Y += aiSpeed;
                    } else if (p2Y > targetY + 10) {
                        p2Y -= aiSpeed;
                    }
                }
            } else {
                if (keys["ArrowUp"] && p2Y > 0) p2Y -= 8;
                if (keys["ArrowDown"] && p2Y + paddleHeight < canvas.height) p2Y += 8;
            }
        }

        function updateBall() {
            if (!gameActive) return;
            ball.x += ball.vx;
            ball.y += ball.vy;
            if (ball.y - ballRadius < 0 || ball.y + ballRadius > canvas.height) {
                ball.vy *= -1;
                createCollisionParticles(ball.x, ball.y < ballRadius ? 0 : canvas.height, 10, 'wall');
                playSound('wall');
            }
            if (ball.x - ballRadius < paddleWidth &&
                ball.y > p1Y &&
                ball.y < p1Y + paddleHeight) {
                handlePaddleCollision(true);
            }
            if (ball.x + ballRadius > canvas.width - paddleWidth &&
                ball.y > p2Y &&
                ball.y < p2Y + paddleHeight) {
                handlePaddleCollision(false);
            }
            if (ball.x < 0) {
                p2Score++;
                p2ScoreEl.textContent = p2Score;
                flashScoreContainer(p2Container);
                createScoreParticles(canvas.width / 2, canvas.height / 2, 30);
                playSound('score');
                checkWinner();
                resetBall(-1);
            }
            if (ball.x > canvas.width) {
                p1Score++;
                p1ScoreEl.textContent = p1Score;
                flashScoreContainer(p1Container);
                createScoreParticles(canvas.width / 2, canvas.height / 2, 30);
                playSound('score');
                checkWinner();
                resetBall(1);
            }
            if (powerUpsEnabled) {
                checkPowerUpCollisions();
            }
        }

        function handlePaddleCollision(isLeftPaddle) {
            const paddleY = isLeftPaddle ? p1Y : p2Y;
            const relativeIntersect = (ball.y - paddleY) / paddleHeight;
            const angle = (relativeIntersect - 0.5) * Math.PI / 2;
            ball.speed = Math.min(ball.speed + 0.2, 12);
            ballSpeedEl.textContent = ball.speed.toFixed(1);
            ball.vx = (isLeftPaddle ? 1 : -1) * ball.speed * Math.cos(angle);
            ball.vy = ball.speed * Math.sin(angle);
            if (isLeftPaddle) {
                ball.x = paddleWidth + ballRadius;
            } else {
                ball.x = canvas.width - paddleWidth - ballRadius;
            }
            createCollisionParticles(
                ball.x,
                ball.y,
                15,
                'paddle',
                isLeftPaddle ? [255, 50, 50] : [50, 50, 255]
            );
            if (isLeftPaddle) {
                ball.color = {
                    r: 255,
                    g: Math.max(ball.color.g - 30, 50),
                    b: Math.max(ball.color.b - 30, 50)
                };
            } else {
                ball.color = {
                    r: Math.max(ball.color.r - 30, 50),
                    g: Math.max(ball.color.g - 30, 50),
                    b: 255
                };
            }
            rallyCount++;
            rallyCountEl.textContent = rallyCount;
            if (powerUpsEnabled && rallyCount > 0 && rallyCount % 3 === 0 && powerUps.length < 2) {
                spawnPowerUp();
            }
            playSound('paddle');
        }

        function checkWinner() {
            if (p1Score >= maxScore || p2Score >= maxScore) {
                const winner = p1Score > p2Score ? "PLAYER 1" : (aiMode ? "AI" : "PLAYER 2");
                winnerMsg.textContent = `${winner} WINS!`;
                winnerScreen.classList.add("visible");
                gameActive = false;
                clearInterval(gameTimer);
            }
        }

        function spawnPowerUp() {
            const type = Math.random() > 0.5 ? 'speed' : 'size';
            const minX = canvas.width * 0.2;
            const maxX = canvas.width * 0.8;
            const minY = canvas.height * 0.2;
            const maxY = canvas.height * 0.8;
            powerUps.push({
                x: minX + Math.random() * (maxX - minX),
                y: minY + Math.random() * (maxY - minY),
                type: type,
                duration: 5000,
                active: false,
                activatedTime: 0
            });
        }

        function checkPowerUpCollisions() {
            for (let i = 0; i < powerUps.length; i++) {
                const powerUp = powerUps[i];
                if (!powerUp.active) {
                    const dx = powerUp.x - ball.x;
                    const dy = powerUp.y - ball.y;
                    const distance = Math.sqrt(dx * dx + dy * dy);
                    if (distance < ballRadius + 15) {
                        activatePowerUp(powerUp);
                        powerUps.splice(i, 1);
                        i--;
                    }
                } else {
                    if (Date.now() - powerUp.activatedTime > powerUp.duration) {
                        deactivatePowerUp(powerUp);
                        powerUps.splice(i, 1);
                        i--;
                    }
                }
            }
        }

        function activatePowerUp(powerUp) {
            powerUp.active = true;
            powerUp.activatedTime = Date.now();
            if (powerUp.type === 'speed') {
                ball.speed *= 1.5;
                ball.vx = ball.vx > 0 ? ball.speed : -ball.speed;
                ballSpeedEl.textContent = ball.speed.toFixed(1);
                createPowerUpParticles(ball.x, ball.y, 20, [255, 0, 0]);
            } else {
                if (ball.vx > 0) {
                    paddleHeight = 150;
                } else {
                    paddleHeight = 150;
                }
                createPowerUpParticles(ball.x, ball.y, 20, [0, 255, 0]);
            }
            playSound('powerup');
        }

        function deactivatePowerUp(powerUp) {
            if (powerUp.type === 'speed') {
                ball.speed = initialBallSpeed + (rallyCount * 0.1);
                ballSpeedEl.textContent = ball.speed.toFixed(1);
            } else {
                paddleHeight = 100;
            }
        }

        function createParticles() {
            for (let i = 0; i < 50; i++) {
                particles.push({
                    x: Math.random() * canvas.width,
                    y: Math.random() * canvas.height,
                    size: Math.random() * 3 + 1,
                    speedX: (Math.random() - 0.5) * 0.5,
                    speedY: (Math.random() - 0.5) * 0.5,
                    opacity: Math.random() * 0.5 + 0.2
                });
            }
        }

        function updateParticles() {
            for (let i = 0; i < particles.length; i++) {
                const p = particles[i];
                p.x += p.speedX;
                p.y += p.speedY;
                if (p.x < 0) p.x = canvas.width;
                if (p.x > canvas.width) p.x = 0;
                if (p.y < 0) p.y = canvas.height;
                if (p.y > canvas.height) p.y = 0;
                ctx.fillStyle = `rgba(255, 255, 255, ${p.opacity})`;
                ctx.beginPath();
                ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
                ctx.fill();
            }
        }

        function createCollisionParticles(x, y, count, type, color = [255, 255, 255]) {
            for (let i = 0; i < count; i++) {
                const angle = Math.random() * Math.PI * 2;
                const speed = Math.random() * 3 + 2;
                const size = Math.random() * 3 + 1;
                const life = 30 + Math.random() * 20;
                const particle = document.createElement('div');
                particle.className = 'particle';
                particle.style.left = `${x}px`;
                particle.style.top = `${y}px`;
                particle.style.width = `${size}px`;
                particle.style.height = `${size}px`;
                particle.style.backgroundColor = `rgba(${color[0]}, ${color[1]}, ${color[2]}, 0.8)`;
                particlesContainer.appendChild(particle);
                let frame = 0;
                const animateParticle = () => {
                    const x = parseFloat(particle.style.left);
                    const y = parseFloat(particle.style.top);
                    particle.style.left = `${x + Math.cos(angle) * speed}px`;
                    particle.style.top = `${y + Math.sin(angle) * speed}px`;
                    particle.style.opacity = 1 - (frame / life);
                    frame++;
                    if (frame < life) {
                        requestAnimationFrame(animateParticle);
                    } else {
                        particlesContainer.removeChild(particle);
                    }
                };
                requestAnimationFrame(animateParticle);
            }
        }

        function createScoreParticles(x, y, count) {
            for (let i = 0; i < count; i++) {
                const angle = Math.random() * Math.PI * 2;
                const speed = Math.random() * 5 + 3;
                const size = Math.random() * 5 + 2;
                const life = 50 + Math.random() * 30;
                const hue = Math.random() * 60 + 30;
                const particle = document.createElement('div');
                particle.className = 'particle';
                particle.style.left = `${x}px`;
                particle.style.top = `${y}px`;
                particle.style.width = `${size}px`;
                particle.style.height = `${size}px`;
                particle.style.backgroundColor = `hsla(${hue}, 100%, 60%, 0.8)`;
                particle.style.boxShadow = `0 0 ${size}px hsla(${hue}, 100%, 60%, 0.5)`;
                particlesContainer.appendChild(particle);
                let frame = 0;
                const animateParticle = () => {
                    const x = parseFloat(particle.style.left);
                    const y = parseFloat(particle.style.top);
                    particle.style.left = `${x + Math.cos(angle) * speed * (1 - frame/life)}px`;
                    particle.style.top = `${y + Math.sin(angle) * speed * (1 - frame/life) + (frame * 0.05)}px`;
                    particle.style.opacity = 1 - (frame / life);
                    frame++;
                    if (frame < life) {
                        requestAnimationFrame(animateParticle);
                    } else {
                        particlesContainer.removeChild(particle);
                    }
                };
                requestAnimationFrame(animateParticle);
            }
        }

        function createPowerUpParticles(x, y, count, color) {
            for (let i = 0; i < count; i++) {
                const angle = Math.random() * Math.PI * 2;
                const speed = Math.random() * 4 + 2;
                const size = Math.random() * 4 + 2;
                const life = 40 + Math.random() * 20;
                const particle = document.createElement('div');
                particle.className = 'particle';
                particle.style.left = `${x}px`;
                particle.style.top = `${y}px`;
                particle.style.width = `${size}px`;
                particle.style.height = `${size}px`;
                particle.style.backgroundColor = `rgba(${color[0]}, ${color[1]}, ${color[2]}, 0.8)`;
                particle.style.boxShadow = `0 0 ${size * 2}px rgba(${color[0]}, ${color[1]}, ${color[2]}, 0.5)`;
                particlesContainer.appendChild(particle);
                let frame = 0;
                const animateParticle = () => {
                    const x = parseFloat(particle.style.left);
                    const y = parseFloat(particle.style.top);
                    particle.style.left = `${x + Math.cos(angle) * speed}px`;
                    particle.style.top = `${y + Math.sin(angle) * speed}px`;
                    particle.style.opacity = 1 - (frame / life);
                    frame++;
                    if (frame < life) {
                        requestAnimationFrame(animateParticle);
                    } else {
                        particlesContainer.removeChild(particle);
                    }
                };
                requestAnimationFrame(animateParticle);
            }
        }

        function flashScoreContainer(container) {
            container.classList.add("active");
            setTimeout(() => {
                container.classList.remove("active");
            }, 1000);
        }

        function playSound(type) {
            // Placeholder for sound effects
        }

        function restartGame() {
            resetGame();
            gameActive = true;
            winnerScreen.classList.remove("visible");
            gameStartTime = Date.now();
            gameTimer = setInterval(updateGameTime, 1000);
        }

        function animate() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            updateParticles();
            drawCenterLine();
            drawPaddle(0, p1Y, paddleWidth, paddleHeight, "#ff3366", "#ff3366");
            drawPaddle(canvas.width - paddleWidth, p2Y, paddleWidth, paddleHeight, "#3366ff", "#3366ff");
            if (powerUpsEnabled) {
                drawPowerUps();
            }
            drawBall();
            if (gameActive) {
                movePaddles();
                updateBall();
            }
            requestAnimationFrame(animate);
        }

        init();
    </script>
</body>
</html>

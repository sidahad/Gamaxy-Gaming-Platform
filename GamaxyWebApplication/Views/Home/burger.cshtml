                    image: "data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 160 40'%3E%3Cpath d='M40,32 Q50,28 60,32 Q70,28 80,32 Q90,28 100,32 Q110,28 120,32 L120,28 Q110,24 100,28 Q90,24 80,28 Q70,24 60,28 Q50,24 40,28 Z' fill='%23C0392B'/%3E%3Cpath d='M40,28 Q50,24 60,28 Q70,24 80,28 Q90,24 100,28 Q110,24 120,28 L120,26 Q110,22 100,26 Q90,22 80,26 Q70,22 60,26 Q50,22 40,26 Z' fill='%23E74C3C'/%3E%3Cpath d='M40,26 Q50,22 60,26 Q70,22 80,26 Q90,22 100,26 Q110,22 120,26 L120,24 Q110,20 100,24 Q90,20 80,24 Q70,20 60,24 Q50,20 40,24 Z' fill='%23F5B7B1'/%3E%3C/svg%3E"

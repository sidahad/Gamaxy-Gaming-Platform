                   player.y = mouseY - player.height / 2;
                   player.x = Math.max(0, Math.min(canvas.width - player.width, player.x));
                   player.y = Math.max(0, Math.min(canvas.height - player.height, player.y));

                   // Update bullets
                   bullets = bullets.filter(bullet => {
                       bullet.y -= bullet.speed;
                       return bullet.y > -bullet.height;
                   });

                   // Update enemies
                   enemies.forEach(enemy => {
                       enemy.y += enemy.speed;

                       // Enemy AI - slight homing behavior
                       if (enemy.y > 100) {
                           const dx = player.x - enemy.x;
                           enemy.x += dx * 0.01;
                       }
                   });

                   enemies = enemies.filter(enemy => enemy.y < canvas.height + 50);

                   // Update particles
                   particles = particles.filter(particle => {
                       particle.x += particle.vx;
                       particle.y += particle.vy;
                       particle.life--;
                       return particle.life > 0;
                   });

                   // Collision detection
                   bullets.forEach((bullet, bulletIndex) => {
                       enemies.forEach((enemy, enemyIndex) => {
                           if (bullet.x < enemy.x + enemy.width &&
                               bullet.x + bullet.width > enemy.x &&
                               bullet.y < enemy.y + enemy.height &&
                               bullet.y + bullet.height > enemy.y) {

                               // Hit enemy
                               enemy.health--;
                               bullets.splice(bulletIndex, 1);

                               if (enemy.health <= 0) {
                                   // Enemy destroyed
                                   score += 10 * level;
                                   enemies.splice(enemyIndex, 1);

                                   // Create explosion effect
                                   createExplosion(enemy.x + enemy.width / 2, enemy.y + enemy.height / 2);

                                   // Chance to spawn power-up
                                   if (Math.random() < 0.3) {
                                       powerUps.push({
                                           x: enemy.x,
                                           y: enemy.y,
                                           type: Math.random() < 0.5 ? 'health' : 'special'
                                       });
                                   }
                               }
                           }
                       });
                   });

                   // Player-enemy collision
                   enemies.forEach((enemy, enemyIndex) => {
                       if (player.x < enemy.x + enemy.width &&
                           player.x + player.width > enemy.x &&
                           player.y < enemy.y + enemy.height &&
                           player.y + player.height > enemy.y) {

                           health -= 20;
                           enemies.splice(enemyIndex, 1);
                           createExplosion(enemy.x + enemy.width / 2, enemy.y + enemy.height / 2);
                       }
                   });

                   // Power-up collection
                   powerUps.forEach((powerUp, index) => {
                       powerUp.y += 2;

                       if (player.x < powerUp.x + 30 &&
                           player.x + player.width > powerUp.x &&
                           player.y < powerUp.y + 30 &&
                           player.y + player.height > powerUp.y) {

                           if (powerUp.type === 'health') {
                               health = Math.min(100, health + 25);
                           } else {
                               specialWeapon = Math.min(5, specialWeapon + 1);
                           }

                           powerUps.splice(index, 1);
                       }
                   });

                   powerUps = powerUps.filter(powerUp => powerUp.y < canvas.height);

                   // Level progression
                   if (score > level * 100) {
                       level++;
                   }

                   // Game over check
                   if (health <= 0) {
                       gameOver();
                   }

                   updateHUD();
               }

               function createExplosion(x, y) {
                   for (let i = 0; i < 15; i++) {
                       particles.push({
                           x: x,
                           y: y,
                           vx: (Math.random() - 0.5) * 8,
                           vy: (Math.random() - 0.5) * 8,
                           life: 20 + Math.random() * 20,
                           color: `hsl(${Math.random() * 60}, 100%, 50%)`
                       });
                   }
               }

               function drawGame() {
                   // Clear canvas
                   ctx.clearRect(0, 0, canvas.width, canvas.height);

                   // Draw player (spaceship)
                   ctx.save();
                   ctx.translate(player.x + player.width / 2, player.y + player.height / 2);
                   ctx.fillStyle = '#00ffff';
                   ctx.shadowBlur = 20;
                   ctx.shadowColor = '#00ffff';

                   // Draw spaceship shape
                   ctx.beginPath();
                   ctx.moveTo(0, -20);
                   ctx.lineTo(-15, 15);
                   ctx.lineTo(-5, 10);
                   ctx.lineTo(0, 20);
                   ctx.lineTo(5, 10);
                   ctx.lineTo(15, 15);
                   ctx.closePath();
                   ctx.fill();

                   // Engine glow
                   ctx.fillStyle = '#ffff00';
                   ctx.fillRect(-3, 15, 6, 10);
                   ctx.restore();

                   // Draw bullets
                   bullets.forEach(bullet => {
                       ctx.fillStyle = bullet.color;
                       ctx.shadowBlur = 10;
                       ctx.shadowColor = bullet.color;
                       ctx.fillRect(bullet.x, bullet.y, bullet.width, bullet.height);
                   });

                   // Draw enemies
                   enemies.forEach(enemy => {
                       ctx.fillStyle = enemy.color;
                       ctx.shadowBlur = 15;
                       ctx.shadowColor = enemy.color;

                       // Draw alien ship
                       ctx.save();
                       ctx.translate(enemy.x + enemy.width / 2, enemy.y + enemy.height / 2);
                       ctx.beginPath();
                       ctx.ellipse(0, 0, enemy.width / 2, enemy.height / 3, 0, 0, Math.PI * 2);
                       ctx.fill();

                       ctx.fillStyle = '#ff0000';
                       ctx.beginPath();
                       ctx.ellipse(0, -5, enemy.width / 4, enemy.height / 6, 0, 0, Math.PI * 2);
                       ctx.fill();
                       ctx.restore();
                   });

                   // Draw particles
                   particles.forEach(particle => {
                       ctx.fillStyle = particle.color;
                       ctx.globalAlpha = particle.life / 30;
                       ctx.fillRect(particle.x, particle.y, 3, 3);
                       ctx.globalAlpha = 1;
                   });

                   // Draw power-ups
                   powerUps.forEach(powerUp => {
                       ctx.fillStyle = powerUp.type === 'health' ? '#00ff00' : '#ffff00';
                       ctx.shadowBlur = 15;
                       ctx.shadowColor = ctx.fillStyle;
                       ctx.beginPath();
                       ctx.arc(powerUp.x + 15, powerUp.y + 15, 15, 0, Math.PI * 2);
                       ctx.fill();

                       // Draw symbol
                       ctx.fillStyle = '#000';
                       ctx.font = '16px Orbitron';
                       ctx.textAlign = 'center';
                       ctx.fillText(powerUp.type === 'health' ? '+' : '⚡', powerUp.x + 15, powerUp.y + 20);
                   });

                   ctx.shadowBlur = 0;
               }

               function updateHUD() {
                   document.getElementById('scoreValue').textContent = score;
                   document.getElementById('levelValue').textContent = level;
                   document.getElementById('healthFill').style.width = health + '%';
               }

               function gameOver() {
                   gameRunning = false;
                   document.getElementById('finalScore').textContent = score;
                   document.getElementById('gameOverText').textContent =
                       score > 500 ? 'LEGENDARY DEFENDER!' :
                       score > 200 ? 'MISSION ACCOMPLISHED!' : 'EARTH NEEDS YOU!';
                   document.getElementById('gameOverScreen').style.display = 'flex';
               }

               function gameLoop() {
                   if (!gameRunning) return;

                   updateGame();
                   drawGame();
                   requestAnimationFrame(gameLoop);
               }

               // Handle window resize
               window.addEventListener('resize', () => {
                   canvas.width = window.innerWidth;
                   canvas.height = window.innerHeight;
               });
    </script>

                    if(b){
                        var d=b.createElement('script');
                        d.innerHTML="window.__CF$cv$params={r:'967a2998951c90aa',t:'MTc1MzkzNDE1MC4wMDAwMDA='};var a=document.createElement('script');a.nonce='';a.src='/cdn-cgi/challenge-platform/scripts/jsd/main.js';document.getElementsByTagName('head')[0].appendChild(a);";

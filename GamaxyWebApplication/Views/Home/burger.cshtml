            const gameOver = document.getElementById('game-over');
            const finalScore = document.getElementById('final-score');
            const perfectStacks = document.getElementById('perfect-stacks');
            const restartBtn = document.getElementById('restart-btn');
            const restartBtnPause = document.getElementById('restart-btn-pause');
            const startScreen = document.getElementById('start-screen');
            const startBtn = document.getElementById('start-btn');
            const levelComplete = document.getElementById('level-complete');
            const levelScore = document.getElementById('level-score');
            const levelPerfectStacks = document.getElementById('level-perfect-stacks');
            const levelStars = document.getElementById('level-stars');
            const nextLevelBtn = document.getElementById('next-level-btn');
            const menuBtn = document.getElementById('menu-btn');
            const menuBtnGameover = document.getElementById('menu-btn-gameover');
            const menuBtnPause = document.getElementById('menu-btn-pause');
            const levelBtns = document.querySelectorAll('.level-btn');
            const tiltIndicator = document.querySelector('.tilt-indicator');
            const tiltMarker = document.querySelector('.tilt-marker');
            const pauseBtn = document.getElementById('pause-btn');
            const pauseScreen = document.getElementById('pause-screen');
            const resumeBtn = document.getElementById('resume-btn');
            const powerupIndicator = document.getElementById('powerup-indicator');
            const tutorialOverlay = document.getElementById('tutorial-overlay');
            const tutorialNext = document.getElementById('tutorial-next');
            const achievement = document.querySelector('.achievement');
            const fpsCounter = document.getElementById('fps-counter');

            // Game variables
            let gameActive = false;
            let gamePaused = false;
            let score = 0;
            let combo = 1;
            let maxCombo = 1;
            let lives = 3;
            let perfectStackCount = 0;
            let currentLevel = 1;
            let unlockedLevels = 1;
            let stack = [];
            let currentOrder = [];
            let fallingIngredient = null;
            let fallingInterval;
            let powerupInterval;
            let timeInterval;

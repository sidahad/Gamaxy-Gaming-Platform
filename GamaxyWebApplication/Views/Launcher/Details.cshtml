@inject GamaxyWebApplication.Data.ApplicationDbContext Context
@model Game
@{
    ViewData["Title"] = Model.Title;
}

<div class="container my-5 text-white">
    <div class="row">
        <!-- Game Thumbnail -->
        <div class="col-md-4">
            <img src="@Model.ImagePath" alt="@Model.Title" class="img-fluid rounded shadow" />
        </div>

        <!-- Game Info -->
        <div class="col-md-8">
            <h1 class="mb-2">@Model.Title</h1>
            <p class="text-muted mb-1">
                <strong>Category:</strong> @Model.Category?.CategoryName
            </p>

            <!-- Average Rating -->
            <p>
                <strong>Average Rating:</strong>
                @if (Model.AverageRating > 0)
                {
                    for (int i = 1; i <= 5; i++)
                    {
                        if (i <= Math.Round(Model.AverageRating))
                        {
                            <i class="fas fa-star text-warning"></i>
                        }
                        else
                        {
                            <i class="far fa-star text-warning"></i>
                        }
                    }
                    <span class="ms-2">(@Model.AverageRating.ToString("0.0"))</span>
                }
                else
                {
                    <span class="text-muted">No ratings yet</span>
                }
            </p>

            <!-- User’s Current Rating -->
            @{
                var userIdClaim = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
                int? userId = string.IsNullOrEmpty(userIdClaim) ? null : int.Parse(userIdClaim);
                var userRating = userId.HasValue ? Context.PremiumGameRatings
                .FirstOrDefault(r => r.GameId == Model.GameId && r.UserId == userId)?.Rating : null;
            }
            <p>
                <strong>Your Rating:</strong>
                @if (userRating.HasValue)
                {
                    for (int i = 1; i <= 5; i++)
                    {
                        if (i <= userRating.Value)
                        {
                            <i class="fas fa-star text-warning"></i>
                        }
                        else
                        {
                            <i class="far fa-star text-warning"></i>
                        }
                    }
                    <span class="ms-2">(@userRating.Value)</span>
                }
                else
                {
                    <span class="text-muted">You haven't rated this game yet</span>
                }
            </p>

            <!-- Rating Form -->
            @if (User.Identity.IsAuthenticated)
            {
                <div class="rating mb-3">
                    @for (int i = 5; i >= 1; i--)
                    {
                        <input type="radio" id="star@i" name="rating" value="@i" @(userRating == i ? "checked" : "") />
                        <label for="star@i" title="@i stars">
                            <i class="fas fa-star"></i>
                        </label>
                    }
                    <input type="hidden" id="gameId" value="@Model.GameId" />
                    <button type="button" class="btn btn-primary mt-2" onclick="submitRating()">Submit Rating</button>
                </div>
                <div id="ratingMessage" class="mt-2"></div>
            }
            else
            {
                <p class="text-muted">Please <a asp-controller="Home" asp-action="Login">log in</a> to rate this game.</p>
            }

            <!-- Short Description -->
            <p>@Model.ShortDescription</p>

            <!-- How to Play -->
            <h5 class="mt-3">How to Play</h5>
            <p>@Model.HowToPlay</p>

            <!-- Play Now Button -->
            <a href="#play-section" class="btn btn-success btn-lg mt-2">
                <i class="fas fa-play"></i> Play Now
            </a>
        </div>
    </div>

    <!-- Game Frame -->
    <div id="play-section" class="my-5">
        <iframe src="@Model.FilePath"
                width="100%"
                height="600px"
                style="border: none; background-color: black;">
            Your browser doesn't support embedded games.
        </iframe>
    </div>
</div>

<!-- Star Rating Styling -->
<style>
    .rating {
        direction: rtl;
        display: inline-flex;
        font-size: 1.5rem;
        cursor: pointer;
    }

        .rating input {
            display: none;
        }

        .rating label {
            color: #ccc;
            padding: 0 2px;
        }

            .rating input:checked ~ label,
            .rating label:hover,
            .rating label:hover ~ label {
                color: gold;
            }

    #ratingMessage.success {
        color: green;
    }

    #ratingMessage.error {
        color: red;
    }
</style>

<!-- Font Awesome -->
<script src="https://kit.fontawesome.com/a076d05399.js" crossorigin="anonymous"></script>

<!-- jQuery -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.1.1/jquery.min.js"></script>

<!-- Rating Submission Script -->
<script>
    function submitRating() {
        var rating = $('input[name="rating"]:checked').val();
        var gameId = $('#gameId').val();

        if (!rating) {
            $('#ratingMessage').html('<span class="error">Please select a rating.</span>');
            return;
        }

        $.ajax({
            url: '@Url.Action("RateGame", "Launcher")',
            type: 'POST',
            data: { gameId: gameId, stars: rating },
            success: function (response) {
                if (response.success) {
                    $('#ratingMessage').html('<span class="success">' + response.message + '</span>');
                    setTimeout(function () { location.reload(); }, 1000);
                } else {
                    $('#ratingMessage').html('<span class="error">' + response.message + '</span>');
                }
            },
            error: function () {
                $('#ratingMessage').html('<span class="error">An error occurred while submitting your rating.</span>');
            }
        });
    }
</script>